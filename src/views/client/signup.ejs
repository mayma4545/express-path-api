<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="description" content="Sign up for PAEMA — your Programs & Events Navigator." />
  <title>PAEMA — Sign Up</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#1DA1F2',
              dark: '#0d8fd9',
              light: '#e8f5fe',
            },
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui'],
          },
          keyframes: {
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(24px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            },
            ripple: {
              '0%': { transform: 'scale(0)', opacity: '0.5' },
              '100%': { transform: 'scale(4)', opacity: '0' },
            },
          },
          animation: {
            'fade-up': 'fadeUp 0.55s cubic-bezier(.22,1,.36,1) both',
            'fade-up-slow': 'fadeUp 0.7s 0.1s cubic-bezier(.22,1,.36,1) both',
            ripple: 'ripple 0.55s linear',
          },
        },
      },
    };
  </script>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ── Utility overrides ─────────────────────────────── */
    html,
    body {
      overscroll-behavior: none;
      -webkit-tap-highlight-color: transparent;
    }

    /* Ripple effect container */
    .btn-ripple {
      position: relative;
      overflow: hidden;
    }

    .ripple-circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.35);
      width: 10px;
      height: 10px;
      margin-top: -5px;
      margin-left: -5px;
      animation: ripple 0.55s linear;
      pointer-events: none;
    }

    /* Input focus ring */
    .input-field:focus {
      outline: none;
      border-color: #1DA1F2;
      box-shadow: 0 0 0 3px rgba(29, 161, 242, 0.18);
    }

    /* Password toggle (no default browser icon) */
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
      display: none;
    }

    /* Subtle scrollbar for very small screens */
    ::-webkit-scrollbar {
      width: 4px;
    }

    ::-webkit-scrollbar-thumb {
      background: #d1d5db;
      border-radius: 99px;
    }
  </style>
</head>

<body class="font-sans bg-white min-h-screen flex items-center justify-center">

  <main id="signup-screen"
    class="relative w-full max-w-sm min-h-screen bg-white flex flex-col justify-between px-6 pt-14 pb-10 overflow-hidden">

    <!-- Back button -->
    <a href="/" aria-label="Go back"
       class="absolute top-5 left-5 flex items-center justify-center w-10 h-10 rounded-full transition-colors active:bg-gray-100 hover:bg-gray-50 text-gray-400 hover:text-gray-700 z-10 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>

    <!-- ── HEADER ───────────────────────────────────── -->
    <header class="relative flex flex-col items-center gap-4 animate-fade-up">

      <!-- Logo mark -->
      <div class="relative flex items-center justify-center">
        <div class="w-14 h-14 rounded-2xl bg-brand flex items-center justify-center shadow-lg shadow-brand/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Zm3.5-11.5-5 2.5-2.5 5 5-2.5Z" />
          </svg>
        </div>
      </div>

      <div class="text-center">
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">Create an account</h1>
        <p class="mt-1 text-sm text-gray-400">Join <span class="text-brand font-semibold">PAEMA</span> today</p>
      </div>
    </header>

    <!-- ── FORM ─────────────────────────────────────── -->
    <section id="form-section" class="relative flex-1 flex flex-col justify-center gap-5 animate-fade-up-slow my-6">

      <form id="signup-form" novalidate class="flex flex-col gap-4" aria-label="Signup form">
        <!-- (Form content same as before) -->
        <div class="flex gap-3">
          <div class="flex flex-col gap-1 flex-1">
            <label for="firstName" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">First Name</label>
            <input id="firstName" name="firstName" type="text" autocomplete="given-name" placeholder="Juan"
              value="<%= typeof firstName !== 'undefined' ? firstName : '' %>"
              class="input-field w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200"
              required />
            <p id="firstname-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
          </div>

          <div class="flex flex-col gap-1 flex-1">
            <label for="middleName" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Middle Name</label>
            <input id="middleName" name="middleName" type="text" autocomplete="additional-name" placeholder="A."
              class="input-field w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200" />
          </div>

          <div class="flex flex-col gap-1 flex-1">
            <label for="lastName" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Last Name</label>
            <input id="lastName" name="lastName" type="text" autocomplete="family-name" placeholder="Dela Cruz"
              value="<%= typeof lastName !== 'undefined' ? lastName : '' %>"
              class="input-field w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200"
              required />
            <p id="lastname-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
          </div>
        </div>

        <div class="flex flex-col gap-1">
          <label for="email" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Email Address</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </span>
            <input id="email" name="email" type="email" autocomplete="email" placeholder="e.g. juan@example.com"
              value="<%= typeof email !== 'undefined' ? email : '' %>" <%= typeof email !== 'undefined' && email ? 'readonly' : '' %>
              class="input-field w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200 <%= typeof email !== 'undefined' && email ? 'opacity-70 cursor-not-allowed' : '' %>"
              required />
          </div>
          <p id="email-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
        </div>

        <div class="flex flex-col gap-1">
          <label for="password" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Password</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </span>
            <input id="password" name="password" type="password" autocomplete="new-password" placeholder="••••••••"
              class="input-field w-full pl-10 pr-11 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200"
              required />
            <button type="button" id="toggle-password" aria-label="Toggle password visibility"
              class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-brand focus:outline-none transition-colors duration-150">
              <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" />
              </svg>
              <svg id="eye-off-icon" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 hidden" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 3l18 18M10.477 10.477A3 3 0 0 0 13.523 13.523M6.228 6.228A10.45 10.45 0 0 0 2.458 12C3.732 16.057 7.523 19 12 19c1.688 0 3.274-.42 4.658-1.163M9.342 4.222A10.45 10.45 0 0 1 12 3c4.478 0 8.268 2.943 9.542 7a10.49 10.49 0 0 1-1.84 3.434" />
              </svg>
            </button>
          </div>
          <p id="password-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
        </div>

        <button type="submit" id="signup-btn"
          class="btn-ripple mt-2 w-full py-3.5 rounded-xl bg-brand text-white font-bold text-sm tracking-wide shadow-md shadow-brand/30 hover:bg-brand-dark active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed"
          aria-live="polite">
          <span id="btn-label">Sign Up</span>
          <svg id="btn-spinner" class="hidden animate-spin inline-block w-4 h-4 ml-2 text-white"
            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v8H4Z" />
          </svg>
        </button>
      </form>

      <div id="divider-section">
        <div class="flex items-center gap-3">
          <span class="flex-1 h-px bg-gray-200"></span>
          <span class="text-xs text-gray-400 font-medium">or continue with</span>
          <span class="flex-1 h-px bg-gray-200"></span>
        </div>
        <button id="google-btn" type="button"
          class="btn-ripple w-full mt-5 flex items-center justify-center gap-3 py-3.5 rounded-xl border border-gray-200 bg-white text-gray-700 font-semibold text-sm shadow-sm hover:bg-gray-50 hover:border-gray-300 active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5Z" />
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65Z" />
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19Z" />
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48Z" />
            <path fill="none" d="M0 0h48v48H0Z" />
          </svg>
          Continue with Google
        </button>
      </div>

    </section>

    <!-- ── OTP SECTION (HIDDEN BY DEFAULT) ─────────── -->
    <section id="otp-section" class="relative flex-1 flex flex-col justify-center gap-6 animate-fade-up-slow my-6 hidden">
      <div class="text-center">
        <h2 class="text-xl font-bold text-gray-900">Verify your email</h2>
        <p class="mt-2 text-sm text-gray-500">We sent a 6-digit code to <br><span id="display-email" class="font-semibold text-gray-700"></span></p>
      </div>

      <form id="otp-form" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <label for="otp" class="text-xs font-semibold text-gray-500 uppercase tracking-wider text-center">Enter Code</label>
          <input id="otp" name="otp" type="text" maxlength="6" inputmode="numeric" placeholder="000000"
            class="w-full px-4 py-4 rounded-xl border border-gray-200 bg-gray-50 text-center text-2xl font-bold tracking-[0.5em] text-gray-800 focus:outline-none focus:border-brand focus:ring-4 focus:ring-brand/10 transition-all"
            required />
          <p id="otp-error" class="hidden text-xs text-red-500 text-center mt-1" role="alert"></p>
        </div>

        <button type="submit" id="verify-btn"
          class="btn-ripple mt-2 w-full py-3.5 rounded-xl bg-brand text-white font-bold text-sm tracking-wide shadow-md shadow-brand/30 hover:bg-brand-dark active:scale-95 transition-all duration-150 disabled:opacity-60">
          <span id="verify-label">Verify & Create Account</span>
          <svg id="verify-spinner" class="hidden animate-spin inline-block w-4 h-4 ml-2 text-white"
            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v8H4Z" />
          </svg>
        </button>
      </form>

      <div class="text-center">
        <p class="text-sm text-gray-400">Didn't receive the code?</p>
        <button id="resend-btn" type="button" class="mt-1 text-sm font-bold text-brand hover:underline focus:outline-none">
          Resend Code
        </button>
        <p id="resend-timer" class="mt-1 text-xs text-gray-400 hidden">Resend available in <span id="timer-sec">30</span>s</p>
      </div>

      <button id="change-email-btn" type="button" class="text-xs text-gray-400 hover:text-gray-600 underline">
        Entered wrong email? Edit
      </button>
    </section>

    <!-- ── FOOTER ────────────────────────────────────── -->
    <footer class="relative text-center animate-fade-up-slow">
      <p class="text-sm text-gray-400">
        Already have an account?
        <a id="signin-link" href="/login"
          class="text-brand font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded">
          Sign in
        </a>
      </p>
    </footer>

  </main>

  <!-- ══════════════════════════════════════════════════
       Toast Notification
  ══════════════════════════════════════════════════ -->
  <div id="toast" role="status" aria-live="polite" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50
              bg-gray-900 text-white text-xs font-medium px-4 py-2.5 rounded-full
              shadow-xl opacity-0 pointer-events-none
              transition-all duration-300 ease-out whitespace-nowrap">
  </div>

  <!-- ══════════════════════════════════════════════════
       JavaScript
  ══════════════════════════════════════════════════ -->
  <script>
    /* ─── Ripple helper ────────────────────────────── */
    function addRipple(btn, e) {
      const rect = btn.getBoundingClientRect();
      const circle = document.createElement('span');
      circle.classList.add('ripple-circle');
      circle.style.left = (e.clientX - rect.left) + 'px';
      circle.style.top = (e.clientY - rect.top) + 'px';
      btn.appendChild(circle);
      circle.addEventListener('animationend', () => circle.remove());
    }
    document.querySelectorAll('.btn-ripple').forEach(btn => {
      btn.addEventListener('pointerdown', e => addRipple(btn, e));
    });

    /* ─── Toast helper ─────────────────────────────── */
    let toastTimer;
    function showToast(msg, duration = 2800) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.remove('opacity-0');
      toast.classList.add('opacity-100');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0');
      }, duration);
    }

    /* ─── Password toggle ──────────────────────────── */
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon');
    const eyeOffIcon = document.getElementById('eye-off-icon');
    const toggleBtn = document.getElementById('toggle-password');

    toggleBtn.addEventListener('click', () => {
      const shown = passwordInput.type === 'text';
      passwordInput.type = shown ? 'password' : 'text';
      eyeIcon.classList.toggle('hidden', !shown);
      eyeOffIcon.classList.toggle('hidden', shown);
      toggleBtn.setAttribute('aria-label', shown ? 'Show password' : 'Hide password');
    });

    /* ─── Inline validation helpers ────────────────── */
    function setError(inputId, errorId, message) {
      const input = document.getElementById(inputId);
      const error = document.getElementById(errorId);
      input.classList.add('border-red-400', 'bg-red-50');
      input.classList.remove('border-gray-200', 'bg-gray-50');
      error.textContent = message;
      error.classList.remove('hidden');
    }
    function clearError(inputId, errorId) {
      const input = document.getElementById(inputId);
      const error = document.getElementById(errorId);
      input.classList.remove('border-red-400', 'bg-red-50');
      input.classList.add('border-gray-200', 'bg-gray-50');
      error.classList.add('hidden');
    }

    function validateEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function validate() {
      let valid = true;
      const firstName = document.getElementById('firstName').value.trim();
      const lastName = document.getElementById('lastName').value.trim();
      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;

      if (!firstName) {
        setError('firstName', 'firstname-error', 'Required.');
        valid = false;
      } else {
        clearError('firstName', 'firstname-error');
      }

      if (!lastName) {
        setError('lastName', 'lastname-error', 'Required.');
        valid = false;
      } else {
        clearError('lastName', 'lastname-error');
      }

      if (!email) {
        setError('email', 'email-error', 'Email is required.');
        valid = false;
      } else if (!validateEmail(email)) {
        setError('email', 'email-error', 'Enter a valid email.');
        valid = false;
      } else {
        clearError('email', 'email-error');
      }

      if (!password) {
        setError('password', 'password-error', 'Password is required.');
        valid = false;
      } else if (password.length < 6) {
        setError('password', 'password-error', 'Must be at least 6 characters.');
        valid = false;
      } else {
        clearError('password', 'password-error');
      }

      return valid;
    }

    /* Clear errors on input */
    document.getElementById('firstName').addEventListener('input', () => clearError('firstName', 'firstname-error'));
    document.getElementById('lastName').addEventListener('input', () => clearError('lastName', 'lastname-error'));
    document.getElementById('email').addEventListener('input', () => clearError('email', 'email-error'));
    document.getElementById('password').addEventListener('input', () => clearError('password', 'password-error'));

    /* ─── Signup form submit ─────────────────────────── */
    const signupForm = document.getElementById('signup-form');
    const signupBtn = document.getElementById('signup-btn');
    const btnLabel = document.getElementById('btn-label');
    const btnSpinner = document.getElementById('btn-spinner');

    const formSection = document.getElementById('form-section');
    const otpSection = document.getElementById('otp-section');
    const displayEmail = document.getElementById('display-email');

    signupForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) return;

      /* API Call */
      signupBtn.disabled = true;
      btnLabel.textContent = 'Sending code…';
      btnSpinner.classList.remove('hidden');

      const emailVal = document.getElementById('email').value.trim();
      const formData = {
        firstName: document.getElementById('firstName').value.trim(),
        middleName: document.getElementById('middleName').value.trim(),
        lastName: document.getElementById('lastName').value.trim(),
        email: emailVal,
        password: document.getElementById('password').value
      };

      try {
        const response = await fetch('/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (response.ok) {
          if (data.requiresOtp) {
            displayEmail.textContent = emailVal;
            formSection.classList.add('hidden');
            otpSection.classList.remove('hidden');
            showToast('✓ ' + data.message);
          } else {
            showToast('✓ Registration successful!');
            setTimeout(() => window.location.href = '/login', 2000);
          }
        } else {
          showToast('⚠ ' + (data.error || 'Failed to initiate signup'));
        }
      } catch (error) {
        showToast('⚠ An error occurred during signup.');
      } finally {
        btnLabel.textContent = 'Sign Up';
        btnSpinner.classList.add('hidden');
        signupBtn.disabled = false;
      }
    });

    /* ─── OTP form submit ─────────────────────────── */
    const otpForm = document.getElementById('otp-form');
    const verifyBtn = document.getElementById('verify-btn');
    const verifyLabel = document.getElementById('verify-label');
    const verifySpinner = document.getElementById('verify-spinner');
    const otpError = document.getElementById('otp-error');

    otpForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const otp = document.getElementById('otp').value.trim();
      
      if (otp.length !== 6) {
        otpError.textContent = 'Please enter the 6-digit code.';
        otpError.classList.remove('hidden');
        return;
      }
      otpError.classList.add('hidden');

      verifyBtn.disabled = true;
      verifyLabel.textContent = 'Verifying…';
      verifySpinner.classList.remove('hidden');

      try {
        const response = await fetch('/signup/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ otp })
        });
        
        const data = await response.json();
        
        if (response.ok) {
          showToast('✓ Verified! Redirecting...');
          setTimeout(() => {
            window.location.href = '/login?message=' + encodeURIComponent('Registration successful. You can now log in.');
          }, 2000);
        } else {
          otpError.textContent = data.error || 'Verification failed';
          otpError.classList.remove('hidden');
        }
      } catch (error) {
        showToast('⚠ Connection error during verification.');
      } finally {
        verifyLabel.textContent = 'Verify & Create Account';
        verifySpinner.classList.add('hidden');
        verifyBtn.disabled = false;
      }
    });

    /* ─── Resend OTP ──────────────────────────────── */
    const resendBtn = document.getElementById('resend-btn');
    const resendTimer = document.getElementById('resend-timer');
    const timerSec = document.getElementById('timer-sec');

    resendBtn.addEventListener('click', async () => {
      resendBtn.disabled = true;
      resendBtn.classList.add('opacity-50', 'cursor-not-allowed');

      try {
        const response = await fetch('/signup/resend-otp', { method: 'POST' });
        const data = await response.json();
        
        if (response.ok) {
          showToast('✓ New code sent!');
          startResendTimer();
        } else {
          showToast('⚠ ' + (data.error || 'Failed to resend code'));
          resendBtn.disabled = false;
          resendBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      } catch (error) {
        showToast('⚠ Connection error.');
        resendBtn.disabled = false;
      }
    });

    function startResendTimer() {
      resendBtn.classList.add('hidden');
      resendTimer.classList.remove('hidden');
      let sec = 30;
      timerSec.textContent = sec;
      
      const interval = setInterval(() => {
        sec--;
        timerSec.textContent = sec;
        if (sec <= 0) {
          clearInterval(interval);
          resendTimer.classList.add('hidden');
          resendBtn.classList.remove('hidden');
          resendBtn.disabled = false;
          resendBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }, 1000);
    }

    /* ─── Change Email ────────────────────────────── */
    document.getElementById('change-email-btn').addEventListener('click', () => {
      otpSection.classList.add('hidden');
      formSection.classList.remove('hidden');
    });

    /* ─── Google sign-in ────────────────────────────── */
    document.getElementById('google-btn').addEventListener('click', () => {
      showToast('Redirecting to Google…');
      window.location.href = '/auth/google?flow=signup';
    });

  </script>
</body>

</html>