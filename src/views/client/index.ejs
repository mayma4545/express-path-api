<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Program &amp; Events Navigator — Find the Event. Reach the Venue.</title>
  <meta name="description"
    content="Knowing about an event is only half the battle. Discover what's happening around Masbate and get guided straight to the exact venue location." />
  <meta property="og:title" content="Program &amp; Events Navigator" />
  <meta property="og:description"
    content="Discover what's happening around Masbate and get guided straight to the exact venue location." />

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- Tailwind CSS via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#1DA1F2',
            'primary-dark': '#1a8fd8',
            'primary-light': '#e8f5fd',
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
          animation: {
            'fade-up': 'fadeUp 0.6s ease both',
            'fade-up-delay': 'fadeUp 0.6s ease 0.15s both',
            'fade-up-delay2': 'fadeUp 0.6s ease 0.3s both',
            'fade-up-delay3': 'fadeUp 0.6s ease 0.45s both',
            'pulse-dot': 'pulseDot 2s ease-in-out infinite',
            'float': 'float 6s ease-in-out infinite',
            'float-slow': 'float 8s ease-in-out infinite 1s',
            'glow': 'glow 3s ease-in-out infinite',
          },
          keyframes: {
            fadeUp: {
              from: { opacity: '0', transform: 'translateY(20px)' },
              to: { opacity: '1', transform: 'translateY(0)' },
            },
            pulseDot: {
              '0%, 100%': { opacity: '1', transform: 'scale(1)' },
              '50%': { opacity: '0.4', transform: 'scale(1.5)' },
            },
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%': { transform: 'translateY(-10px)' },
            },
            glow: {
              '0%, 100%': { boxShadow: '0 0 20px rgba(29,161,242,0.3)' },
              '50%': { boxShadow: '0 0 40px rgba(29,161,242,0.6)' },
            },
          },
          boxShadow: {
            'primary-sm': '0 4px 14px rgba(29,161,242,0.35)',
            'primary-md': '0 8px 28px rgba(29,161,242,0.45)',
            'primary-lg': '0 14px 40px rgba(29,161,242,0.5)',
          },
        },
      },
    };
  </script>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet" />

  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --primary: #1DA1F2;
      --primary-dark: #1a8fd8;
      --primary-light: #e8f5fd;
      --primary-glow: rgba(29, 161, 242, 0.18);
      --surface: #ffffff;
      --surface-2: #f4f8fd;
      --surface-3: #eaf4fc;
      --text: #0f172a;
      --text-muted: #64748b;
      --glass: rgba(29, 161, 242, 0.06);
      --glass-border: rgba(29, 161, 242, 0.15);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #ffffff;
      color: var(--text);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ─── Background orbs ─── */
    .bg-orbs {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
    }

    .orb-1 {
      width: 560px;
      height: 560px;
      background: radial-gradient(circle, rgba(29, 161, 242, 0.12), transparent 70%);
      top: -140px;
      right: -120px;
      animation: orb-float 14s ease-in-out infinite;
    }

    .orb-2 {
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(29, 161, 242, 0.08), transparent 70%);
      bottom: 5%;
      left: -120px;
      animation: orb-float 18s ease-in-out infinite reverse;
    }

    .orb-3 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(29, 161, 242, 0.06), transparent 70%);
      top: 42%;
      left: 38%;
      animation: orb-float 22s ease-in-out infinite 5s;
    }

    @keyframes orb-float {

      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }

      33% {
        transform: translate(24px, -36px) scale(1.06);
      }

      66% {
        transform: translate(-18px, 20px) scale(0.96);
      }
    }

    /* dot grid overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(29, 161, 242, 0.07) 1px, transparent 1px);
      background-size: 42px 42px;
      pointer-events: none;
      z-index: 0;
    }

    /* ─── Navbar ─── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 20px 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.4s, backdrop-filter 0.4s;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 11px;
      text-decoration: none;
    }

    .nav-logo-text {
      font-weight: 700;
      font-size: 15px;
      color: var(--text);
      line-height: 1.2;
    }

    .nav-logo-text small {
      display: block;
      font-size: 10px;
      font-weight: 400;
      color: var(--text-muted);
      letter-spacing: 0.04em;
      margin-top: 1px;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn-nav-login {
      padding: 9px 22px;
      border-radius: 50px;
      border: 1px solid #d1e9fb;
      background: white;
      color: var(--text);
      font-size: 13.5px;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.22s;
      display: inline-flex;
      align-items: center;
    }

    .btn-nav-login:hover {
      background: var(--primary-light);
      border-color: var(--primary);
      color: var(--primary-dark);
    }

    .btn-nav-signup {
      padding: 9px 22px;
      border-radius: 50px;
      border: none;
      background: var(--primary);
      color: #fff;
      font-size: 13.5px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.22s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0 4px 16px rgba(29, 161, 242, 0.35);
    }

    .btn-nav-signup:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(29, 161, 242, 0.45);
    }

    /* ─── Hero ─── */
    .hero {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      padding: 118px 52px 80px;
      gap: 56px;
    }

    .hero-content {
      flex: 1;
      max-width: 600px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--primary-light);
      border: 1px solid rgba(29, 161, 242, 0.3);
      color: var(--primary-dark);
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      padding: 7px 16px;
      border-radius: 50px;
      margin-bottom: 26px;
      animation: fadeUp 0.55s ease both;
    }

    .badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--primary);
      animation: dot-pulse 2s ease-in-out infinite;
    }

    @keyframes dot-pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.45;
        transform: scale(1.6);
      }
    }

    .app-name {
      font-size: clamp(13px, 1.5vw, 17px);
      font-weight: 600;
      letter-spacing: 0.01em;
      color: var(--text-muted);
      margin-bottom: 10px;
      animation: fadeUp 0.55s ease 0.06s both;
    }

    .hero-headline {
      font-size: clamp(46px, 6vw, 76px);
      font-weight: 900;
      line-height: 1.04;
      margin-bottom: 28px;
      animation: fadeUp 0.55s ease 0.12s both;
      letter-spacing: -0.02em;
    }

    .hero-headline .line1 {
      color: var(--text);
    }

    .hero-headline .line2 {
      background: linear-gradient(130deg, var(--primary) 0%, #0ea5e9 60%, #38bdf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: block;
      text-shadow: none;
      filter: drop-shadow(0 0 22px rgba(29, 161, 242, 0.25));
    }

    .hero-desc {
      font-size: 17px;
      line-height: 1.75;
      color: var(--text-muted);
      margin-bottom: 42px;
      animation: fadeUp 0.55s ease 0.18s both;
      max-width: 520px;

    }

    /* CTA trio */
    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      animation: fadeUp 0.55s ease 0.24s both;
    }

    .btn-explore {
      padding: 15px 34px;
      border-radius: 50px;
      border: none;
      background: var(--primary);
      color: #fff;
      font-size: 15.5px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 9px;
      box-shadow: 0 6px 24px rgba(29, 161, 242, 0.4);
      transition: all 0.28s;
      position: relative;
      overflow: hidden;
    }

    .btn-explore::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
      opacity: 0;
      transition: opacity 0.28s;
    }

    .btn-explore:hover {
      background: var(--primary-dark);
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(29, 161, 242, 0.5);
    }

    .btn-explore:hover::after {
      opacity: 1;
    }

    .btn-explore:active {
      transform: translateY(-1px);
    }

    .btn-outline {
      padding: 15px 28px;
      border-radius: 50px;
      border: 1.5px solid #c8e6fb;
      background: #fff;
      color: var(--text);
      font-size: 14.5px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      transition: all 0.28s;
    }

    .btn-outline:hover {
      background: var(--primary-light);
      border-color: var(--primary);
      color: var(--primary-dark);
      transform: translateY(-2px);
    }

    /* Stats row */
    .hero-stats {
      display: flex;
      align-items: stretch;
      gap: 32px;
      margin-top: 52px;
      animation: fadeUp 0.55s ease 0.3s both;
    }

    .stat {
      text-align: left;
    }

    .stat-val {
      font-size: 26px;
      font-weight: 800;
      color: var(--text);
      line-height: 1;
    }

    .stat-val em {
      color: var(--primary);
      font-style: normal;
    }

    .stat-lbl {
      font-size: 11.5px;
      color: var(--text-muted);
      margin-top: 3px;
      font-weight: 500;
    }

    .stat-sep {
      width: 1px;
      background: #dde8f5;
      align-self: stretch;
    }

    /* ─── Phone mockup visual ─── */
    .hero-visual {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      animation: fadeUp 0.75s ease 0.16s both;
      min-width: 300px;
    }

    .phone-glow {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29, 161, 242, 0.14) 0%, transparent 68%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 0;
      animation: glow-breathe 4.5s ease-in-out infinite;
    }

    @keyframes glow-breathe {

      0%,
      100% {
        opacity: 0.7;
        transform: translate(-50%, -50%) scale(1);
      }

      50% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.08);
      }
    }

    .phone-wrap {
      position: relative;
      z-index: 2;
    }

    .phone-frame {
      width: 288px;
      height: 576px;
      background: #f8fafc;
      border-radius: 44px;
      border: 2px solid #dde8f5;
      box-shadow:
        0 30px 70px rgba(29, 161, 242, 0.13),
        0 4px 20px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      position: relative;
    }

    .phone-notch {
      width: 96px;
      height: 24px;
      background: #1e293b;
      border-radius: 0 0 14px 14px;
      margin: 0 auto;
    }

    .phone-body {
      padding: 12px 16px 18px;
      height: calc(100% - 24px);
      overflow: hidden;
    }

    .ph-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .ph-title {
      font-weight: 800;
      font-size: 14px;
      color: var(--text);
    }

    .ph-avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), #0ea5e9);
    }

    .ph-map {
      width: 100%;
      height: 162px;
      border-radius: 14px;
      background: linear-gradient(135deg, #dbeeff, #e0f2fe);
      margin-bottom: 11px;
      position: relative;
      overflow: hidden;
    }

    .ph-map::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(29, 161, 242, 0.12) 1px, transparent 1px),
        linear-gradient(90deg, rgba(29, 161, 242, 0.12) 1px, transparent 1px);
      background-size: 22px 22px;
    }

    .ph-route {
      position: absolute;
      top: 50%;
      left: 18%;
      width: 64%;
      height: 2px;
      background: linear-gradient(90deg, var(--primary), #0ea5e9);
      border-radius: 2px;
      opacity: 0.8;
    }

    .ph-pin {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .ph-pin-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      border: 2px solid #fff;
    }

    .ph-pin-stem {
      width: 2px;
      height: 7px;
    }

    .ph-pin.purple .ph-pin-dot {
      background: var(--primary);
      box-shadow: 0 0 8px rgba(29, 161, 242, 0.6);
    }

    .ph-pin.purple .ph-pin-stem {
      background: var(--primary);
    }

    .ph-pin.gold .ph-pin-dot {
      background: #f59e0b;
      box-shadow: 0 0 7px rgba(245, 158, 11, 0.5);
    }

    .ph-pin.gold .ph-pin-stem {
      background: #f59e0b;
    }

    .ph-pin.green .ph-pin-dot {
      background: #22C55E;
      box-shadow: 0 0 7px rgba(34, 197, 94, 0.5);
    }

    .ph-pin.green .ph-pin-stem {
      background: #22C55E;
    }

    .ph-card {
      background: #fff;
      border: 1px solid #e2eefa;
      border-radius: 13px;
      padding: 9px 11px;
      margin-bottom: 7px;
      display: flex;
      align-items: center;
      gap: 9px;
      box-shadow: 0 1px 6px rgba(29, 161, 242, 0.06);
    }

    .ph-card-img {
      width: 40px;
      height: 40px;
      border-radius: 9px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
    }

    .ph-card-info {
      flex: 1;
    }

    .ph-card-name {
      font-size: 9.5px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 3px;
    }

    .ph-card-meta {
      font-size: 8.5px;
      color: var(--text-muted);
    }

    .ph-card-tag {
      font-size: 7.5px;
      font-weight: 700;
      padding: 3px 7px;
      border-radius: 50px;
      white-space: nowrap;
    }

    .tag-live {
      background: #fef2f2;
      color: #ef4444;
      border: 1px solid #fecaca;
    }

    .tag-soon {
      background: var(--primary-light);
      color: var(--primary-dark);
      border: 1px solid rgba(29, 161, 242, 0.25);
    }

    /* Floating info cards */
    .float-card {
      position: absolute;
      z-index: 3;
      background: #ffffff;
      border: 1px solid #dde8f5;
      border-radius: 16px;
      padding: 12px 16px;
      box-shadow: 0 8px 28px rgba(29, 161, 242, 0.12);
    }

    .float-card-1 {
      top: 50px;
      right: -68px;
      animation: fc1 7s ease-in-out infinite;
    }

    .float-card-2 {
      bottom: 110px;
      left: -76px;
      animation: fc2 9s ease-in-out infinite 1.8s;
    }

    @keyframes fc1 {

      0%,
      100% {
        transform: translateY(0) rotate(2deg);
      }

      50% {
        transform: translateY(-13px) rotate(2deg);
      }
    }

    @keyframes fc2 {

      0%,
      100% {
        transform: translateY(0) rotate(-3deg);
      }

      50% {
        transform: translateY(-10px) rotate(-3deg);
      }
    }

    .fc-icon {
      font-size: 19px;
      margin-bottom: 3px;
    }

    .fc-label {
      font-size: 8.5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    .fc-val {
      font-size: 17px;
      font-weight: 800;
      color: var(--text);
      line-height: 1;
      margin: 2px 0;
    }

    .fc-sub {
      font-size: 8.5px;
      color: var(--text-muted);
    }

    /* ─── Features ─── */
    .section {
      position: relative;
      z-index: 1;
      padding: 36px 52px;
    }

    .sec-label {
      text-align: center;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 14px;
    }

    .sec-title {
      text-align: center;
      font-size: clamp(28px, 3.8vw, 46px);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 56px;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .feat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 22px;
      max-width: 1080px;
      margin: 0 auto;
    }

    .feat-card {
      background: #fff;
      border: 1.5px solid #e2eefa;
      border-radius: 22px;
      padding: 30px;
      transition: all 0.32s;
      position: relative;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(29, 161, 242, 0.05);
    }

    .feat-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      opacity: 0;
      transition: opacity 0.32s;
    }

    .feat-card:hover {
      border-color: rgba(29, 161, 242, 0.3);
      transform: translateY(-5px);
      box-shadow: 0 16px 40px rgba(29, 161, 242, 0.12);
    }

    .feat-card:hover::after {
      opacity: 1;
    }

    .feat-icon {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      margin-bottom: 18px;
    }

    .feat-title {
      font-size: 17px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 9px;
    }

    .feat-desc {
      font-size: 13.5px;
      line-height: 1.65;
      color: var(--text-muted);
    }

    /* ─── How it works ─── */
    .how-section {
      position: relative;
      z-index: 1;
      padding: 80px 52px 96px;
      background: var(--surface-2);
    }

    .steps-v {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 660px;
      margin: 0 auto;
    }

    .step-row {
      display: flex;
      gap: 26px;
    }

    .step-left {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .step-num {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      background: var(--primary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(29, 161, 242, 0.35);
    }

    .step-line {
      width: 2px;
      flex: 1;
      min-height: 36px;
      background: linear-gradient(to bottom, rgba(29, 161, 242, 0.45), rgba(29, 161, 242, 0.05));
      margin: 5px 0;
    }

    .step-row:last-child .step-line {
      display: none;
    }

    .step-body {
      padding-bottom: 40px;
      flex: 1;
    }

    .step-title {
      font-size: 19px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 7px;
      margin-top: 9px;
    }

    .step-desc {
      font-size: 14.5px;
      color: var(--text-muted);
      line-height: 1.65;
    }

    /* ─── CTA banner ─── */
    .cta-section {
      position: relative;
      z-index: 1;
      padding: 0 52px 96px;
    }

    .cta-box {
      background: linear-gradient(135deg, var(--primary-light), #dbeeff);
      border: 1.5px solid rgba(29, 161, 242, 0.25);
      border-radius: 30px;
      padding: 70px 60px;
      text-align: center;
      position: relative;
      overflow: hidden;
      max-width: 880px;
      margin: 0 auto;
    }

    .cta-box::before {
      content: '';
      position: absolute;
      top: -1px;
      left: 22%;
      right: 22%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
    }

    .cta-box::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(29, 161, 242, 0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    .cta-title {
      font-size: clamp(26px, 3.8vw, 42px);
      font-weight: 900;
      color: var(--text);
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
      letter-spacing: -0.015em;
    }

    .cta-desc {
      font-size: 15.5px;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 auto 36px;
      line-height: 1.68;
      position: relative;
      z-index: 1;
    }

    .cta-btns {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    /* ─── Footer ─── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid #e2eefa;
      padding: 34px 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 14px;
      background: #fff;
    }

    footer .copy {
      font-size: 12.5px;
      color: var(--text-muted);
    }

    .ftr-links {
      display: flex;
      gap: 22px;
    }

    .ftr-links a {
      font-size: 12.5px;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .ftr-links a:hover {
      color: var(--primary);
    }

    /* ─── Animations ─── */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(22px);
      }

      to {
        opacity: 1;
        transform: none;
      }
    }

    .reveal {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    /* ─── Responsive ─── */
    @media (max-width: 920px) {
      nav {
        padding: 18px 24px;
      }

      .nav-logo-text {
        display: none;
      }

      .hero {
        flex-direction: column;
        text-align: center;
        padding: 108px 24px 60px;
        gap: 46px;
      }

      .hero-content {
        max-width: 100%;
      }

      .hero-desc {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-ctas {
        justify-content: center;
      }

      .hero-stats {
        justify-content: center;
      }

      .float-card-1 {
        right: -8px;
        top: -14px;
      }

      .float-card-2 {
        left: -8px;
        bottom: 52px;
      }

      .section,
      .how-section,
      .cta-section {
        padding-left: 24px;
        padding-right: 24px;
      }

      .cta-box {
        padding: 50px 28px;
      }

      footer {
        padding: 26px 24px;
        flex-direction: column;
        text-align: center;
      }
    }

    @media (max-width: 480px) {
      .phone-frame {
        width: 252px;
        height: 504px;
      }

      .hero-stats {
        gap: 18px;
      }

      .stat-val {
        font-size: 22px;
      }
    }
  </style>
</head>

<body>

  <!-- Background -->
  <div class="bg-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <!-- ═══ NAVBAR ════════════════════════════════════════════════ -->
  <nav id="main-nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Program & Events Navigator">
      <img src="/static/images/app-icon.jpg" alt="PEMWA Logo"
        style="width: 38px; height: 38px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
      <div class="nav-logo-text">
        Program &amp; Events Navigator
        <small>Masbate, Philippines</small>
      </div>
    </a>
    <div class="nav-actions">
      <a href="/login" class="btn-nav-login" id="nav-login-btn">Log In</a>
      <a href="/signup" class="btn-nav-signup" id="nav-signup-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24"
          stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
        </svg>
        Sign Up
      </a>
    </div>
  </nav>

  <!-- ═══ HERO ══════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-h1">
    <div class="hero-content">

      <p class="app-name">Program &amp; Events Navigator</p>

      <h1 class="hero-headline" id="hero-h1">
        <span class="line1">Find the Event.</span>
        <span class="line2">Reach the Venue.</span>
      </h1>

      <p class="hero-desc">
        Knowing about an event is only half the battle. Discover what's happening around Masbate City
        and get guided straight to the exact venue location.
      </p>

      <div class="hero-ctas">
        <!-- Explore Now -->
        <a href="/home" class="btn-explore" id="hero-explore-btn" role="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" />
          </svg>
          Explore Now
        </a>

      </div>

      <div class="hero-stats" role="list" aria-label="App stats">
        <div class="stat" role="listitem">
          <div class="stat-val">
            <%= eventCount %><em>+</em>
          </div>
          <div class="stat-lbl">Events</div>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat" role="listitem" style="text-align: center;">
          <div class="stat-val">
            <%= venueCount %><em>+</em>
          </div>
          <div class="stat-lbl">Mapped Venues</div>
        </div>
        <div class="stat-sep" aria-hidden="true"></div>
        <div class="stat" role="listitem">
          <div class="stat-val">
            <% if (guidedCount>= 1000) { %>
              <%= (guidedCount / 1000).toFixed(1).replace(/\.0$/, '' ) %><em>K+</em>
                <% } else { %>
                  <%= guidedCount %><em>+</em>
                    <% } %>
          </div>
          <div class="stat-lbl">Users Guided</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES ══════════════════════════════════════════════ -->
  <section class="section" id="features" aria-labelledby="feat-heading">
    <p class="sec-label reveal">Why use this app</p>
    <h2 class="sec-title reveal" id="feat-heading">
      More than a calendar.<br />It's your event guide.
    </h2>
  </section>

  <!-- ═══ HOW IT WORKS ══════════════════════════════════════════ -->
  <section class="how-section" aria-labelledby="how-heading">
    <p class="sec-label reveal">Simple &amp; intuitive</p>
    <h2 class="sec-title reveal" id="how-heading">
      From discovery to arrival<br />in 3 easy steps
    </h2>

    <div class="steps-v">
      <div class="step-row reveal">
        <div class="step-left" aria-hidden="true">
          <div class="step-num">1</div>
          <div class="step-line"></div>
        </div>
        <div class="step-body">
          <h3 class="step-title">Browse Events Near You</h3>
          <p class="step-desc">Open the app and instantly see what's happening around Masbate — from barangay fiestas to
            city-wide festivals. Filter by category or date.</p>
        </div>
      </div>

      <div class="step-row reveal" style="transition-delay:0.1s">
        <div class="step-left" aria-hidden="true">
          <div class="step-num">2</div>
          <div class="step-line"></div>
        </div>
        <div class="step-body">
          <h3 class="step-title">Tap an Event to Learn More</h3>
          <p class="step-desc">Read event details, see who's attending, check the schedule, and preview the exact venue
            on a live map before you even leave home.</p>
        </div>
      </div>

      <div class="step-row reveal" style="transition-delay:0.2s">
        <div class="step-left" aria-hidden="true">
          <div class="step-num">3</div>
          <div class="step-line"></div>
        </div>
        <div class="step-body">
          <h3 class="step-title">Get Guided Straight to the Venue</h3>
          <p class="step-desc">One tap starts navigation with step-by-step directions directly to the venue entrance —
            no confusion, no detours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ════════════════════════════════════════════════ -->
  <footer role="contentinfo" style="justify-content: center;">
    <div class="copy">
      &copy; 2026 Program &amp; Events Navigator. All rights reserved.
    </div>
  </footer>

  <script>
    /* Sticky nav */
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 24);
    }, { passive: true });

    /* Scroll reveal */
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>

  <!-- PWA Install App Banner -->
  <div id="install-banner"
    style="display: none; position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: white; padding: 16px 24px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 9999; align-items: center; gap: 16px; width: 90%; max-width: 400px; border: 1px solid var(--primary-light);">
    <div style="flex: 1;">
      <h4 style="margin: 0; font-size: 15px; font-weight: 700; color: var(--text);">Install EventNav App</h4>
      <p style="margin: 4px 0 0; font-size: 13px; color: var(--text-muted); line-height: 1.4;" id="install-hint">Add to
        your home screen for quick access and offline routing.</p>
    </div>
    <button id="install-btn"
      style="background: var(--primary); color: white; border: none; padding: 10px 16px; border-radius: 24px; font-weight: 600; font-size: 13px; cursor: pointer;">Install</button>
    <button id="install-close"
      style="background: none; border: none; font-size: 20px; color: #999; cursor: pointer; padding: 0 4px; line-height: 1;">&times;</button>
  </div>

  <script>
    // Service Worker Registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('Service Worker registered successfully.', reg))
          .catch(err => console.error('Service Worker registration failed: ', err));
      });
    }

    // Install App Logic
    let deferredPrompt;
    const installBanner = document.getElementById('install-banner');
    const installBtn = document.getElementById('install-btn');
    const installClose = document.getElementById('install-close');
    const installHint = document.getElementById('install-hint');

    // Detect iOS
    const isIos = () => {
      const userAgent = window.navigator.userAgent.toLowerCase();
      return /iphone|ipad|ipod/.test(userAgent);
    };

    const isIosInstallable = () => {
      return isIos() && !window.navigator.standalone;
    };

    window.addEventListener('beforeinstallprompt', (e) => {
      // Prevent the mini-infobar from appearing on mobile
      e.preventDefault();
      // Stash the event so it can be triggered later.
      deferredPrompt = e;
      // Update UI notify the user they can install the PWA
      installBanner.style.display = 'flex';
    });

    if (isIosInstallable()) {
      installBanner.style.display = 'flex';
      installBtn.style.display = 'none';
      installHint.innerHTML = "To install this app on your iOS device, tap the <strong>Share</strong> icon and then select <strong>Add to Home Screen</strong>.";
    }

    installBtn.addEventListener('click', async () => {
      if (deferredPrompt) {
        // Show the install prompt
        deferredPrompt.prompt();
        // Wait for the user to respond to the prompt
        const { outcome } = await deferredPrompt.userChoice;
        console.log(`User response to the install prompt: ${outcome}`);
        // We've used the prompt, and can't use it again, throw it away
        deferredPrompt = null;
      }
      // Hide the banner
      installBanner.style.display = 'none';
    });

    installClose.addEventListener('click', () => {
      installBanner.style.display = 'none';
    });
  </script>
</body>

</html>