<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>EventFlow — Discover Local Events</title>
  <meta name="description"
    content="Discover and explore the best local events near you. Filter by category and find what's happening around you." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#1DA1F2',
            'brand-dark': '#0d8de0',
            'brand-light': '#e8f5fe',
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * {
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      overscroll-behavior: none;
      background: #f8fafc;
    }

    @keyframes pulse-bg {

      0%,
      100% {
        background-color: #e5e7eb;
      }

      50% {
        background-color: #d1d5db;
      }
    }

    .skeleton {
      animation: pulse-bg 1.4s ease-in-out infinite;
      border-radius: 10px;
    }

    .chip-strip {
      display: flex;
      gap: .5rem;
      overflow-x: auto;
      padding: .25rem .25rem .5rem;
      scrollbar-width: none;
    }

    .chip-strip::-webkit-scrollbar {
      display: none;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .card-enter {
      animation: fadeUp .35s ease forwards;
    }

    .btn-ripple {
      position: relative;
      overflow: hidden;
    }

    .btn-ripple::after {
      content: '';
      position: absolute;
      inset: 0;
      background: white;
      opacity: 0;
      transition: opacity .3s;
      border-radius: inherit;
    }

    .btn-ripple:active::after {
      opacity: .25;
    }

    /* ── Ongoing strip ── */
    .ongoing-strip {
      display: flex;
      gap: .875rem;
      overflow-x: auto;
      padding: .25rem .25rem .75rem;
      scrollbar-width: none;
    }

    .ongoing-strip::-webkit-scrollbar {
      display: none;
    }

    /* Red live dot pulse */
    @keyframes live-pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: .5;
        transform: scale(1.5);
      }
    }

    .live-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #ef4444;
      animation: live-pulse 1.2s ease-in-out infinite;
      flex-shrink: 0;
    }

    /* Progress bar shimmer */
    @keyframes shimmer {
      from {
        background-position: -200% 0;
      }

      to {
        background-position: 200% 0;
      }
    }

    .progress-bar {
      height: 3px;
      border-radius: 99px;
      background: linear-gradient(90deg, #ef4444 0%, #f97316 50%, #ef4444 100%);
      background-size: 200% 100%;
      animation: shimmer 2s linear infinite;
    }
  </style>
</head>

<body class="min-h-screen max-w-md mx-auto bg-white" style="height:100dvh; display:flex; flex-direction:column;">

  <!-- ── Sticky Header ───────────────────────────────── -->
  <header class="sticky top-0 z-30 bg-white shadow-sm px-4 pt-5 pb-3">
    <div class="flex items-center justify-between mb-3">
      <div>
        <p class="text-xs text-gray-400 font-medium tracking-widest uppercase">Discover</p>
        <h1 class="text-2xl font-extrabold text-gray-900 leading-tight">EventFlow</h1>
      </div>
      <div class="w-10 h-10 rounded-full bg-brand flex items-center justify-center shadow-md shadow-brand/30">
        <span class="text-white font-bold text-sm">JD</span>
      </div>
    </div>
    <div class="relative">
      <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
          stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
        </svg>
      </span>
      <input id="search-input" type="search" placeholder="Search events, venues…" autocomplete="off"
        class="w-full pl-10 pr-4 py-3 bg-gray-100 rounded-2xl text-sm text-gray-800 placeholder-gray-400 outline-none focus:ring-2 focus:ring-brand/40 transition" />
    </div>
  </header>

  <!-- ── Scrollable Body ─────────────────────────────── -->
  <div class="flex-1 overflow-y-auto px-4 pb-10 space-y-5">

    <!-- Hot Events / Chip filter -->
    <div class="pt-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-base font-bold text-gray-900">Hot Events</h2>
      </div>
      <div class="chip-strip" id="chip-strip"></div>
    </div>

    <!-- ── Ongoing Events ───────────────────────────── -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-2">
          <h2 class="text-base font-bold text-gray-900">Ongoing Events</h2>

        </div>
        <span class="text-xs text-brand font-semibold cursor-pointer">See all</span>
      </div>

      <!-- Ongoing skeleton (3 cards) -->
      <div id="ongoing-skeleton" class="ongoing-strip">
        <div class="flex-shrink-0 rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100"
          style="width:200px;">
          <div class="skeleton w-full rounded-t-2xl" style="height:110px;"></div>
          <div class="p-3">
            <div class="skeleton h-3 w-3/4 mb-2"></div>
            <div class="skeleton h-2.5 w-1/2 mb-3"></div>
            <div class="skeleton h-7 w-full rounded-lg"></div>
          </div>
        </div>
        <div class="flex-shrink-0 rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100"
          style="width:200px;">
          <div class="skeleton w-full rounded-t-2xl" style="height:110px;"></div>
          <div class="p-3">
            <div class="skeleton h-3 w-2/3 mb-2"></div>
            <div class="skeleton h-2.5 w-1/3 mb-3"></div>
            <div class="skeleton h-7 w-full rounded-lg"></div>
          </div>
        </div>
        <div class="flex-shrink-0 rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100"
          style="width:200px;">
          <div class="skeleton w-full rounded-t-2xl" style="height:110px;"></div>
          <div class="p-3">
            <div class="skeleton h-3 w-1/2 mb-2"></div>
            <div class="skeleton h-2.5 w-2/5 mb-3"></div>
            <div class="skeleton h-7 w-full rounded-lg"></div>
          </div>
        </div>
      </div>

      <!-- Real ongoing cards -->
      <div id="ongoing-list" class="ongoing-strip hidden"></div>
    </div>

    <!-- Event list -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-bold text-gray-900">Upcoming Events</h2>
        <span id="event-count" class="text-xs text-gray-400 font-medium"></span>
      </div>

      <!-- Skeleton placeholders -->
      <div id="skeleton-list" class="space-y-4">
        <div class="rounded-3xl overflow-hidden bg-white shadow-sm border border-gray-100 p-3">
          <div class="skeleton w-full h-44 rounded-2xl mb-3"></div>
          <div class="skeleton h-4 w-3/4 mb-2"></div>
          <div class="skeleton h-3 w-1/2 mb-4"></div>
          <div class="skeleton h-10 w-full rounded-xl"></div>
        </div>
        <div class="rounded-3xl overflow-hidden bg-white shadow-sm border border-gray-100 p-3">
          <div class="skeleton w-full h-44 rounded-2xl mb-3"></div>
          <div class="skeleton h-4 w-2/3 mb-2"></div>
          <div class="skeleton h-3 w-1/3 mb-4"></div>
          <div class="skeleton h-10 w-full rounded-xl"></div>
        </div>
        <div class="rounded-3xl overflow-hidden bg-white shadow-sm border border-gray-100 p-3">
          <div class="skeleton w-full h-44 rounded-2xl mb-3"></div>
          <div class="skeleton h-4 w-1/2 mb-2"></div>
          <div class="skeleton h-3 w-2/5 mb-4"></div>
          <div class="skeleton h-10 w-full rounded-xl"></div>
        </div>
      </div>

      <!-- Real events -->
      <div id="event-list" class="space-y-4 hidden"></div>
      <div id="no-results" class="hidden text-center py-16">
        <div class="text-5xl mb-3">🎭</div>
        <p class="text-gray-500 font-medium">No events found</p>
        <p class="text-sm text-gray-400 mt-1">Try a different search or category</p>
      </div>
    </div>
  </div>

  <script src="/static/js/events-data.js"></script>
  <script>
    let activeCategory = sessionStorage.getItem('activeCategory') || 'All';
    let searchQuery = '';
    const CATEGORIES = ['All', 'Tech', 'Music', 'Sports', 'Food', 'Art', 'Gaming', 'Health'];

    /* ── Chips ── */
    function renderChips() {
      const strip = document.getElementById('chip-strip');
      strip.innerHTML = '';
      CATEGORIES.forEach(cat => {
        const btn = document.createElement('button');
        const active = cat === activeCategory;
        btn.className = `flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all active:scale-95 ${active ? 'bg-brand text-white shadow-md shadow-brand/30' : 'bg-gray-100 text-gray-600'
          }`;
        btn.textContent = cat;
        btn.onclick = () => {
          activeCategory = cat;
          sessionStorage.setItem('activeCategory', cat);
          renderChips();
          renderEvents();
        };
        strip.appendChild(btn);
      });
    }

    /* ── Helpers ── */
    function formatGoing(n) {
      return n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : String(n);
    }

    function filteredEvents() {
      return EVENTS.filter(ev => {
        const matchCat = activeCategory === 'All' || ev.category === activeCategory;
        const matchSearch = ev.name.toLowerCase().includes(searchQuery) ||
          ev.venue.toLowerCase().includes(searchQuery) ||
          ev.category.toLowerCase().includes(searchQuery);
        return matchCat && matchSearch;
      });
    }

    /* ── Event cards ── */
    function renderEvents() {
      const list = document.getElementById('event-list');
      const noResults = document.getElementById('no-results');
      const countEl = document.getElementById('event-count');
      const events = filteredEvents();

      countEl.textContent = `${events.length} event${events.length !== 1 ? 's' : ''}`;
      list.innerHTML = '';

      if (events.length === 0) {
        list.classList.add('hidden');
        noResults.classList.remove('hidden');
        return;
      }
      noResults.classList.add('hidden');
      list.classList.remove('hidden');

      events.forEach((ev, i) => {
        const card = document.createElement('div');
        card.className = 'card-enter rounded-3xl overflow-hidden bg-white shadow-sm border border-gray-100';
        card.style.animationDelay = `${i * 60}ms`;
        card.innerHTML = `
        <div class="relative">
          <img src="${ev.img}" alt="${ev.name}" class="w-full object-cover" style="height:180px;" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-wider bg-white/20 backdrop-blur-sm text-white border border-white/30 px-2.5 py-1 rounded-full">${ev.category}</span>
          <button
            id="heart-${ev.id}"
            class="heart-btn absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm border border-white/30 active:scale-90 transition-all ${ev.liked ? 'liked' : ''}"
            onclick="toggleHeart(event, ${ev.id})"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="${ev.liked ? '#ef4444' : 'none'}" stroke="${ev.liked ? '#ef4444' : 'white'}" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </button>
        </div>
        <div class="p-4">
          <h3 class="font-bold text-gray-900 text-base leading-tight mb-1">${ev.name}</h3>
          <p class="text-xs text-gray-400 mb-1 flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            ${ev.venue}
          </p>
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-3">
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              ${ev.date}
            </span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              ${ev.start} – ${ev.end}
            </span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5 text-xs font-medium text-gray-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span class="font-semibold text-gray-800">${formatGoing(ev.going)}</span> going
            </div>
            <button
              onclick="openDetails(${ev.id})"
              class="btn-ripple bg-brand text-white text-xs font-bold px-5 py-2.5 rounded-xl active:scale-95 transition-all shadow-sm shadow-brand/30"
            >
              View Details
            </button>
          </div>
        </div>
      `;
        list.appendChild(card);
      });
    }

    function toggleHeart(e, id) {
      e.stopPropagation();
      const ev = EVENTS.find(x => x.id === id);
      if (!ev) return;
      ev.liked = !ev.liked;
      ev.going += ev.liked ? 1 : -1;
      renderEvents();
    }

    /* ── Ongoing Cards ── */
    function renderOngoing() {
      const strip = document.getElementById('ongoing-list');
      strip.innerHTML = '';

      ONGOING_EVENTS.forEach((ev, i) => {
        const card = document.createElement('div');
        card.className = 'card-enter flex-shrink-0 rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100 cursor-pointer active:scale-[0.97] transition-all';
        card.style.width = '210px';
        card.style.animationDelay = `${i * 80}ms`;
        card.onclick = () => openOngoingDetails(ev.id);
        card.innerHTML = `
          <div class="relative" style="height:115px;">
            <img src="${ev.img}" alt="${ev.name}" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
            
            <!-- Attendance -->
            <div class="absolute top-2.5 right-2.5 flex items-center gap-1 bg-black/40 backdrop-blur-sm text-white text-[9px] font-semibold px-1.5 py-0.5 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"/></svg>
              ${formatGoing(ev.attendance)}
            </div>
            <!-- Time left -->
            <div class="absolute bottom-2.5 left-2.5 right-2.5">
              <p class="text-white text-[10px] font-semibold mb-1 drop-shadow">${ev.name}</p>
            </div>
          </div>
          <div class="px-3 pt-2.5 pb-3">
            <div class="flex items-center gap-1 text-red-500 text-[10px] font-bold mb-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              ${ev.timeLeft}
            </div>
            <p class="text-[11px] text-gray-400 truncate mb-2.5">${ev.venue}</p>
            <button
              onclick="event.stopPropagation(); openOngoingDetails(${ev.id})"
              class="btn-ripple w-full bg-brand text-white text-[11px] font-bold py-2 rounded-xl active:scale-95 transition-all shadow-sm shadow-brand/30"
            >View Details</button>
          </div>
        `;
        strip.appendChild(card);
      });
    }

    function openOngoingDetails(id) {
      sessionStorage.setItem('currentEventId', id);
      window.location.href = '/details';
    }

    function openDetails(id) {
      sessionStorage.setItem('currentEventId', id);
      window.location.href = '/details';
    }

    document.getElementById('search-input').addEventListener('input', function () {
      searchQuery = this.value.toLowerCase().trim();
      renderEvents();
    });

    /* ── Boot ── */
    renderChips();
    setTimeout(() => {
      document.getElementById('ongoing-skeleton').style.display = 'none';
      document.getElementById('ongoing-list').classList.remove('hidden');
      renderOngoing();
    }, 700);
    setTimeout(() => {
      document.getElementById('skeleton-list').style.display = 'none';
      renderEvents();
    }, 900);
  </script>
</body>

</html>