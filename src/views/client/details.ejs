          <!-- Comment 1 -->
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs flex-shrink-0">
              JD
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <span class="text-sm font-bold text-gray-900">John Doe</span>
                <span class="text-xs text-gray-400">2h ago</span>
              </div>
              <p class="text-sm text-gray-600 mt-1">This event looks amazing! Can't wait to be there. Will there be food stalls?</p>
              <div class="flex items-center gap-4 mt-2">
                <button class="text-xs font-semibold text-gray-500 hover:text-red-500 flex items-center gap-1 transition react-btn" onclick="toggleCommentReact(this)">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
