  <!-- ── Sticky CTA ──────────────────────────────────── -->
  <div
    class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-md bg-white/95 backdrop-blur-md border-t border-gray-100 px-5 py-4 flex gap-3 z-30"
    style="max-width:448px;">
    <button onclick="addToCalendar()"
      class="btn-ripple flex-1 flex items-center justify-center gap-2 border-2 border-brand text-brand font-bold py-3.5 rounded-2xl active:scale-95 transition-all text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      Add to Cal
    </button>
    <a id="map-btn" href="/map"
      class="btn-ripple flex-[2] bg-brand text-white font-bold py-3.5 rounded-2xl active:scale-95 transition-all shadow-lg shadow-brand/30 text-sm flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
        <line x1="8" y1="2" x2="8" y2="18" />
        <line x1="16" y1="6" x2="16" y2="22" />
      </svg>
      View in Map
