<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Event Details — EventFlow</title>
  <meta name="description" content="View full event details, add to your calendar, and get directions." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#1DA1F2',
            'brand-dark': '#0d8de0',
            'brand-light': '#e8f5fe',
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * {
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      overscroll-behavior-y: none;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .fade-up {
      animation: fadeUp .4s ease forwards;
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .slide-in {
      animation: slideInRight .35s cubic-bezier(.4, 0, .2, 1) forwards;
    }

    .btn-ripple {
      position: relative;
      overflow: hidden;
    }

    .btn-ripple::after {
      content: '';
      position: absolute;
      inset: 0;
      background: white;
      opacity: 0;
      transition: opacity .3s;
      border-radius: inherit;
    }

    .btn-ripple:active::after {
      opacity: .25;
    }

    .heart-btn.liked svg {
      fill: #ef4444;
      stroke: #ef4444;
    }

    /* Tab selector */
    .tab-btn {
      transition: all .2s;
    }

    .tab-btn.active {
      color: #1DA1F2;
      border-bottom: 2px solid #1DA1F2;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }
  </style>
</head>

<body class="bg-white min-h-screen max-w-md mx-auto overflow-x-hidden" style="padding-bottom: 90px;">

  <!-- ── Floating Nav Bar ────────────────────────────── -->
  <div
    class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-md z-40 px-4 pt-5 flex items-center justify-between pointer-events-none"
    style="max-width:448px;">
    <a href="/home"
      class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 text-gray-700 active:scale-95 transition-all flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
    <div class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-xl px-4 py-2">
      <p class="text-xs font-bold text-gray-500 text-center">Event Details</p>
    </div>
    <button id="heart-btn" onclick="toggleHeart()"
      class="pointer-events-auto heart-btn bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 active:scale-95 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
  </div>

  <!-- ── Hero Image ──────────────────────────────────── -->
  <div class="relative" style="height:300px;">
    <img id="detail-img" src="" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <!-- Category + going overlay -->
    <div class="absolute bottom-0 left-0 right-0 px-5 pb-5 flex items-end justify-between">
      <div>
        <span id="detail-category"
          class="text-xs font-bold uppercase tracking-widest text-white/80 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/30 mb-2 inline-block"></span>
        <h1 id="detail-name" class="text-2xl font-extrabold text-white leading-tight mt-1 drop-shadow-lg"></h1>
      </div>
      <div class="flex flex-col items-center bg-white/20 backdrop-blur-sm rounded-2xl px-3 py-2 border border-white/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-400 mb-0.5" fill="currentColor"
          viewBox="0 0 24 24">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
        <p id="detail-going" class="text-sm font-bold text-white leading-none"></p>
        <p class="text-[10px] text-white/70 font-medium">going</p>
      </div>
    </div>
  </div>

  <!-- ── Meta pills ──────────────────────────────────── -->
  <div class="fade-up px-5 pt-5 flex flex-wrap gap-2">
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-brand-light text-brand px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span id="detail-date"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span id="detail-time"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-green-50 text-green-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span id="detail-venue"></span>
    </span>
  </div>

  <!-- ── Tabs ─────────────────────────────────────────── -->
  <div class="slide-in mt-5 px-5">
    <div class="flex border-b border-gray-200 mb-4">
      <button id="tab-about" class="tab-btn active flex-1 py-2.5 text-sm font-semibold text-center"
