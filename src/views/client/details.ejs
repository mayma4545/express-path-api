<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Event Details — EventFlow</title>
  <meta name="description" content="View full event details, add to your calendar, and get directions." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#1DA1F2',
            'brand-dark': '#0d8de0',
            'brand-light': '#e8f5fe',
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * {
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      overscroll-behavior-y: none;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .fade-up {
      animation: fadeUp .4s ease forwards;
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .slide-in {
      animation: slideInRight .35s cubic-bezier(.4, 0, .2, 1) forwards;
    }

    .btn-ripple {
      position: relative;
      overflow: hidden;
    }

    .btn-ripple::after {
      content: '';
      position: absolute;
      inset: 0;
      background: white;
      opacity: 0;
      transition: opacity .3s;
      border-radius: inherit;
    }

    .btn-ripple:active::after {
      opacity: .25;
    }

    .heart-btn.liked svg {
      fill: #ef4444;
      stroke: #ef4444;
    }

    /* Tab selector */
    .tab-btn {
      transition: all .2s;
    }

    .tab-btn.active {
      color: #1DA1F2;
      border-bottom: 2px solid #1DA1F2;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }
  </style>
</head>

<body class="bg-white min-h-screen max-w-md mx-auto overflow-x-hidden" style="padding-bottom: 90px;">

  <!-- ── Floating Nav Bar ────────────────────────────── -->
  <div
    class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-md z-40 px-4 pt-5 flex items-center justify-between pointer-events-none"
    style="max-width:448px;">
    <a href="/home"
      class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 text-gray-700 active:scale-95 transition-all flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
    <div class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-xl px-4 py-2">
      <p class="text-xs font-bold text-gray-500 text-center">Event Details</p>
    </div>
    <button id="heart-btn" onclick="toggleHeart()"
      class="pointer-events-auto heart-btn bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 active:scale-95 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    </button>
  </div>

  <!-- ── Hero Image ──────────────────────────────────── -->
  <div class="relative" style="height:300px;">
    <img id="detail-img" src="" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <!-- Category + going overlay -->
    <div class="absolute bottom-0 left-0 right-0 px-5 pb-5 flex items-end justify-between">
      <div>
        <span id="detail-category"
          class="text-xs font-bold uppercase tracking-widest text-white/80 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/30 mb-2 inline-block"></span>
        <h1 id="detail-name" class="text-2xl font-extrabold text-white leading-tight mt-1 drop-shadow-lg"></h1>
      </div>
      <div class="flex flex-col items-center bg-white/20 backdrop-blur-sm rounded-2xl px-3 py-2 border border-white/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <p id="detail-going" class="text-sm font-bold text-white leading-none"></p>
        <p class="text-[10px] text-white/70 font-medium">visited</p>
      </div>
    </div>
  </div>

  <!-- ── Meta pills ──────────────────────────────────── -->
  <div class="fade-up px-5 pt-5 flex flex-wrap gap-2">
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-brand-light text-brand px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span id="detail-date"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span id="detail-time"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-green-50 text-green-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span id="detail-venue"></span>
    </span>
  </div>

  <!-- ── Tabs ─────────────────────────────────────────── -->
  <div class="slide-in mt-5 px-5">
    <div class="flex border-b border-gray-200 mb-4 overflow-x-auto no-scrollbar">
      <button id="tab-about" class="tab-btn active flex-1 py-2.5 text-sm font-semibold text-center whitespace-nowrap px-4"
        onclick="switchTab('about')">About</button>
      <button id="tab-organizer" class="tab-btn flex-1 py-2.5 text-sm font-semibold text-gray-400 text-center whitespace-nowrap px-4"
        onclick="switchTab('organizer')">Organizer</button>
      <button id="tab-gallery" class="tab-btn flex-1 py-2.5 text-sm font-semibold text-gray-400 text-center whitespace-nowrap px-4"
        onclick="switchTab('gallery')">Photos</button>
      <button id="tab-announcements" class="tab-btn flex-1 py-2.5 text-sm font-semibold text-gray-400 text-center whitespace-nowrap px-4"
        onclick="switchTab('announcements')">Announcements</button>
    </div>

    <!-- About -->
    <div id="tab-about-content" class="tab-content active">
      <p id="detail-desc" class="text-sm text-gray-600 leading-relaxed"></p>
      <!-- Tags -->
      <div id="detail-tags" class="flex flex-wrap gap-2 mt-4"></div>

      <!-- Comments Section -->
      <div id="rating-section" class="mt-6 border-t border-gray-100 pt-6">
        <h3 class="text-lg font-bold text-gray-900 mb-1">Event Rating</h3>
        <p id="rating-text" class="text-xs text-gray-500 mb-3">Loading ratings...</p>
        <div class="flex items-center gap-1 mb-4">
          <svg class="w-8 h-8 star text-gray-300 cursor-pointer transition" data-val="1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27l-5.18 3.73 1.64-6.81L3.64 9.64l6.81-.59L12 3l1.55 6.05 6.81.59-4.82 4.55 1.64 6.81z"/></svg>
          <svg class="w-8 h-8 star text-gray-300 cursor-pointer transition" data-val="2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27l-5.18 3.73 1.64-6.81L3.64 9.64l6.81-.59L12 3l1.55 6.05 6.81.59-4.82 4.55 1.64 6.81z"/></svg>
          <svg class="w-8 h-8 star text-gray-300 cursor-pointer transition" data-val="3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27l-5.18 3.73 1.64-6.81L3.64 9.64l6.81-.59L12 3l1.55 6.05 6.81.59-4.82 4.55 1.64 6.81z"/></svg>
          <svg class="w-8 h-8 star text-gray-300 cursor-pointer transition" data-val="4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27l-5.18 3.73 1.64-6.81L3.64 9.64l6.81-.59L12 3l1.55 6.05 6.81.59-4.82 4.55 1.64 6.81z"/></svg>
          <svg class="w-8 h-8 star text-gray-300 cursor-pointer transition" data-val="5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27l-5.18 3.73 1.64-6.81L3.64 9.64l6.81-.59L12 3l1.55 6.05 6.81.59-4.82 4.55 1.64 6.81z"/></svg>
        </div>
      </div>

      <div class="mt-4 border-t border-gray-100 pt-6 pb-2">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Comments (<span id="comment-count">2</span>)</h3>
        
        <!-- Add Comment -->
        <div class="flex gap-3 mb-6 relative">
          <div class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center font-bold text-xs flex-shrink-0">
            <%= (user && user.first_name) ? user.first_name.substring(0, 2).toUpperCase() : 'ME' %>
          </div>
          <div class="flex-1 bg-gray-50 rounded-2xl flex items-center pr-1 border border-gray-100 focus-within:border-brand transition-colors shadow-inner">
            <input type="text" id="new-comment-text" placeholder="Add a comment..." class="flex-1 bg-transparent px-3 py-2 text-sm outline-none text-gray-700 placeholder-gray-400" />
            <button onclick="postComment()" class="text-brand font-bold text-xs px-3 py-1.5 rounded-xl hover:bg-brand-light transition">Post</button>
          </div>
        </div>

        <!-- Comment List -->
        <div class="space-y-5" id="comments-list">
          <p class="text-sm text-gray-500 text-center py-4">Loading comments...</p>
        </div>
      </div>
    </div>

    <!-- Organizer -->
    <div id="tab-organizer-content" class="tab-content">
      <div class="bg-gray-50 rounded-2xl p-4 flex items-center gap-4">
        <div id="org-avatar"
          class="w-14 h-14 rounded-2xl bg-brand flex items-center justify-center flex-shrink-0 shadow-md shadow-brand/20">
          <span id="org-initial" class="text-white text-xl font-extrabold"></span>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium mb-0.5">Event Organizer</p>
          <p id="detail-organizer" class="text-base font-bold text-gray-900"></p>
          <p class="text-xs text-brand font-medium mt-0.5">View all events →</p>
        </div>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3">
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <p class="text-lg font-extrabold text-gray-900">12</p>
          <p class="text-xs text-gray-400">Past Events</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <p class="text-lg font-extrabold text-brand">4.9 ★</p>
          <p class="text-xs text-gray-400">Avg Rating</p>
        </div>
      </div>
    </div>

    <!-- Gallery -->
    <div id="tab-gallery-content" class="tab-content">
      <div id="gallery-container" class="grid grid-cols-2 gap-2">
        <p class="text-sm text-gray-500 text-center py-4 col-span-2">Loading photos...</p>
      </div>
    </div>

    <div id="tab-announcements-content" class="tab-content">
      <div id="detail-announcements-list" class="space-y-4">
        <!-- Announcements pushed via JS -->
        <p class="text-sm text-gray-500 text-center py-4">Loading announcements...</p>
      </div>
    </div>
  </div>

  <!-- ── Sticky CTA ──────────────────────────────────── -->
  <div
    class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-md bg-white/95 backdrop-blur-md border-t border-gray-100 px-5 py-4 flex gap-3 z-30"
    style="max-width:448px;">
    <button onclick="addToCalendar()"
      class="btn-ripple flex-1 flex items-center justify-center gap-2 border-2 border-brand text-brand font-bold py-3.5 rounded-2xl active:scale-95 transition-all text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      Add to Cal
    </button>
    <button id="map-btn" onclick="checkLocationBeforeMap()"
      class="btn-ripple flex-[2] bg-brand text-white font-bold py-3.5 rounded-2xl active:scale-95 transition-all shadow-lg shadow-brand/30 text-sm flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
        <line x1="8" y1="2" x2="8" y2="18" />
        <line x1="16" y1="6" x2="16" y2="22" />
      </svg>
      View in Map
    </button>
  </div>

  <!-- ── Location Prompt Modal ──────────────────────── -->
  <div id="location-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeLocationModal()"></div>
    <div class="relative bg-white w-full max-w-sm rounded-3xl overflow-hidden shadow-2xl animate-fade-up">
      <div class="bg-brand/10 p-8 flex justify-center">
        <div class="w-20 h-20 bg-brand rounded-full flex items-center justify-center shadow-lg shadow-brand/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
      </div>
      <div class="p-6 text-center">
        <h3 class="text-xl font-extrabold text-gray-900 mb-2">Enable Location</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          To show your position on the map and get accurate directions, please enable your device's location services.
        </p>
        <div class="flex flex-col gap-2">
          <button onclick="requestLocationAccess()" class="w-full bg-brand text-white font-bold py-3.5 rounded-2xl active:scale-95 transition-all shadow-md">
            Enable Now
          </button>
          <button onclick="closeLocationModal()" class="w-full text-sm text-gray-400 font-semibold py-3 hover:text-gray-600 transition-colors">
            Maybe Later
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Calendar Modal ──────────────────────────────── -->
  <div id="cal-modal" class="hidden fixed inset-0 z-50 flex items-end justify-center"
    style="max-width:448px;left:50%;transform:translateX(-50%);">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeCalModal()"></div>
    <div class="relative bg-white w-full rounded-t-3xl px-6 pt-5 pb-10 space-y-3 shadow-2xl z-10">
      <div class="w-10 h-1 bg-gray-300 rounded-full mx-auto mb-4"></div>
      <h3 class="text-lg font-bold text-gray-900 text-center mb-4">Add to Calendar</h3>
      <button onclick="downloadICS()"
        class="w-full flex items-center gap-4 p-4 rounded-2xl border border-gray-200 active:bg-gray-50 transition">
        <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
        </div>
        <div class="text-left">
          <p class="text-sm font-semibold text-gray-900">Download .ics File</p>
          <p class="text-xs text-gray-400">Apple Calendar, Outlook &amp; more</p>
        </div>
      </button>
      <button onclick="openGoogleCalendar()"
        class="w-full flex items-center gap-4 p-4 rounded-2xl border border-gray-200 active:bg-gray-50 transition">
        <div class="w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center">
          <span class="text-lg font-extrabold text-red-500">G</span>
        </div>
        <div class="text-left">
          <p class="text-sm font-semibold text-gray-900">Google Calendar</p>
          <p class="text-xs text-gray-400">Open in your browser</p>
        </div>
      </button>
      <button onclick="closeCalModal()"
        class="w-full text-sm text-gray-400 font-medium py-2 active:text-gray-600">Cancel</button>
    </div>
  </div>
  <a id="ics-link" style="display:none;"></a>

  <script src="/static/js/events-data.js"></script>
  <script>
      const RAW_EVENT = <%- typeof dbEvent !== 'undefined' ? JSON.stringify(dbEvent) : 'null' %>;
      let ev = null;
      
      if (RAW_EVENT) {
        const evCat = RAW_EVENT.category ? RAW_EVENT.category.name : (RAW_EVENT.tags ? RAW_EVENT.tags.split(',')[0] : "Other");
        ev = {
          id: RAW_EVENT.id,
          cat: evCat,
          category: evCat,
          name: RAW_EVENT.title,
          desc: RAW_EVENT.description || "No description",
          description: RAW_EVENT.description || "No description",
          venue: RAW_EVENT.venue || "TBA",
          img: RAW_EVENT.image_url || "https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800",
          date: RAW_EVENT.event_date ? new Date(RAW_EVENT.event_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : "TBA",
          start: RAW_EVENT.start_time ? RAW_EVENT.start_time.substring(0, 5) : "",
          end: RAW_EVENT.end_time ? RAW_EVENT.end_time.substring(0, 5) : "",
          going: (RAW_EVENT.analytics ? RAW_EVENT.analytics.page_view_count : 0),
          organizer: RAW_EVENT.organizer ? RAW_EVENT.organizer.name : "Event Organizer",
          liked: false,
          views: (RAW_EVENT.analytics ? RAW_EVENT.analytics.page_view_count : 0),
          coords: RAW_EVENT.latitude && RAW_EVENT.longitude ? { lat: parseFloat(RAW_EVENT.latitude), lng: parseFloat(RAW_EVENT.longitude) } : null
        };
        sessionStorage.setItem('currentEventId', ev.id);
        sessionStorage.setItem('currentEventData', JSON.stringify(ev));
      }
    if (!ev) {
      window.location.href = '/home';
    } else {
      /* ── Populate ── */
      document.title = `${ev.name} — EventFlow`;
      document.getElementById('detail-img').src = ev.img;
      document.getElementById('detail-img').alt = ev.name;
      document.getElementById('detail-name').textContent = ev.name;
      document.getElementById('detail-category').textContent = ev.category;
      document.getElementById('detail-date').textContent = ev.date;
      document.getElementById('detail-time').textContent = `Starts at ${ev.start} – Ends at ${ev.end}`;
      document.getElementById('detail-venue').textContent = `Location: ${ev.venue}`;
      document.getElementById('detail-desc').textContent = ev.description;
      document.getElementById('detail-going').textContent = formatGoing(ev.going);
      document.getElementById('detail-organizer').textContent = ev.organizer;
      document.getElementById('org-initial').textContent = ev.organizer[0];

      // heart
      if (ev.liked) document.getElementById('heart-btn').classList.add('liked');

      // tags
      const tags = [ev.category];
      if (RAW_EVENT && RAW_EVENT.tags) {
        tags.push(...RAW_EVENT.tags.split(',').map(t => t.trim()).filter(Boolean));
      }
      const tagContainer = document.getElementById('detail-tags');
      [...new Set(tags)].forEach(t => {
        if (!t || t.toLowerCase() === 'other') return;
        const el = document.createElement('span');
        el.className = 'text-xs font-medium bg-gray-100 text-gray-500 px-3 py-1 rounded-full';
        el.textContent = t;
        tagContainer.appendChild(el);
      });

      // announcements
      fetch(`/api/events/${ev.id}/announcements`)
        .then(r => r.json())
        .then(data => {
            const list = document.getElementById('detail-announcements-list');
            list.innerHTML = '';
            if (data.announcements && data.announcements.length > 0) {
                data.announcements.forEach(a => {
                    const div = document.createElement('div');
                    div.className = 'bg-white rounded-2xl p-4 border border-gray-100 shadow-sm mb-3';
                    div.innerHTML = `
                      <h5 class="font-bold text-gray-900 text-sm mb-1">${a.title}</h5>
                      <p class="text-xs text-gray-600 mb-2">${a.body}</p>
                      <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-1 rounded inline-block">
                        ${new Date(a.created_at).toLocaleDateString()}
                      </span>
                    `;
                    list.appendChild(div);
                });
            } else {
                list.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">No announcements yet.</p>';
            }
        })
        .catch(err => {
            console.error(err);
            document.getElementById('detail-announcements-list').innerHTML = '<p class="text-sm text-red-500 text-center py-4">Error loading announcements.</p>';
        });
    }

    function formatGoing(n) {
      return n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : String(n);
    }

    /* ── Heart ── */
    function toggleHeart() {
      if (!ev) return;
      ev.liked = !ev.liked;
        // Commented out going changes for bookmarks
        // ev.going += ev.liked ? 1 : -1;
        document.getElementById('heart-btn').classList.toggle('liked', ev.liked);
        document.getElementById('detail-going').textContent = formatGoing(ev.going);
        
        // Notify backend about bookmark toggle
        fetch(`/api/events/${ev.id}/bookmark`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: ev.liked ? 'bookmark' : 'unbookmark' })
        }).catch(err => console.error('Error toggling bookmark:', err));
    }

    function switchTab(name) {
      ['about', 'organizer', 'gallery', 'announcements'].forEach(t => {
        const btn = document.getElementById(`tab-${t}`);
        const content = document.getElementById(`tab-${t}-content`);
        
        if (t === name) {
          btn.classList.add('active', 'text-brand');
          btn.classList.remove('text-gray-400');
          content.classList.add('active');
        } else {
          btn.classList.remove('active', 'text-brand');
          btn.classList.add('text-gray-400');
          content.classList.remove('active');
        }
      });
    }

    /* ── Calendar ── */
    function addToCalendar() {
      document.getElementById('cal-modal').classList.remove('hidden');
    }
    function closeCalModal() {
      document.getElementById('cal-modal').classList.add('hidden');
    }
    function toICSDate(dt) {
      return dt.toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '');
    }
    function downloadICS() {
      if (!ev) return;
      const start = new Date(`${ev.date} ${ev.start}`);
      const end = new Date(`${ev.date} ${ev.end}`);
      const ics = [
        'BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//EventFlow//EN',
        'BEGIN:VEVENT',
        `UID:eventflow-${ev.id}@app`,
        `DTSTART:${toICSDate(start)}`, `DTEND:${toICSDate(end)}`,
        `SUMMARY:${ev.name}`,
        `DESCRIPTION:${ev.description.replace(/\n/g, '\\n')}`,
        `LOCATION:${ev.venue}`,
        'END:VEVENT', 'END:VCALENDAR',
      ].join('\r\n');
      const url = URL.createObjectURL(new Blob([ics], { type: 'text/calendar' }));
      const a = document.getElementById('ics-link');
      a.href = url; a.download = `${ev.name.replace(/\s+/g, '-')}.ics`; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      closeCalModal();
    }
    function openGoogleCalendar() {
      if (!ev) return;
      const start = new Date(`${ev.date} ${ev.start}`);
      const end = new Date(`${ev.date} ${ev.end}`);
      const fmt = d => d.toISOString().replace(/[-:]/g, '').replace(/\.\d{3}Z/, 'Z');
      const p = new URLSearchParams({ action: 'TEMPLATE', text: ev.name, dates: `${fmt(start)}/${fmt(end)}`, details: ev.description, location: ev.venue });
      window.open(`https://calendar.google.com/calendar/render?${p}`, '_blank');
      closeCalModal();
    }

    /* ── Comments ── */
    function toggleCommentReact(btn, commentId) {
      fetch(`/api/comments/${commentId}/react`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        // Using session-based auth now
        body: JSON.stringify({})
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          const countSpan = btn.querySelector('.react-count');
          let count = parseInt(countSpan.textContent, 10);
          const svg = btn.querySelector('svg');

          if (data.reacted) {
            btn.classList.add('reacted', 'text-red-500');
            svg.setAttribute('fill', 'currentColor');
            count++;
          } else {
            btn.classList.remove('reacted', 'text-red-500');
            svg.setAttribute('fill', 'none');
            count--;
          }
          countSpan.textContent = count;
        }
      })
      .catch(console.error);
    }

    function showReplyInput(btn) {
      const commentDiv = btn.closest('.flex-1');
      const replyBox = commentDiv.querySelector('.reply-box');
      if (replyBox) {
        replyBox.classList.toggle('hidden');
        if (!replyBox.classList.contains('hidden')) {
          replyBox.querySelector('input').focus();
        }
      }
    }

    function loadComments() {
      fetch(`/api/events/${ev.id}/comments`)
        .then(res => res.json())
        .then(data => {
          const list = document.getElementById('comments-list');
          list.innerHTML = '';
          const commentsCount = document.getElementById('comment-count');
          
          if (!data.comments || data.comments.length === 0) {
            list.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">No comments yet. Be the first to comment!</p>';
            commentsCount.textContent = '0';
            return;
          }
          
          commentsCount.textContent = data.comments.length;
          
          // Separate top-level comments and replies
          const organizerId = data.organizer_id;
          const topLevel = data.comments.filter(c => !c.parent_comment_id);
          const replies = data.comments.filter(c => c.parent_comment_id);
          
          topLevel.forEach(c => {
             const userInitials = (c.user && c.user.first_name) ? c.user.first_name.substring(0, 2).toUpperCase() : 'AN';
               const userName = (c.user && c.user.first_name) ? c.user.first_name + ' ' + (c.user.last_name || '') : 'Anonymous';
               const isOrganizer = c.user && (c.user.id === organizerId);
               const reactionCount = c.reacted_by_users ? c.reacted_by_users.length : 0;
               const currentUserId = <%= user ? user.id : 'null' %>;
               const isReacted = c.reacted_by_users && c.reacted_by_users.some(r => r.id === currentUserId);
             const cReplies = replies.filter(r => r.parent_comment_id === c.id);
             
             const div = document.createElement('div');
             div.className = `flex gap-3 ${isOrganizer ? 'bg-brand-light/30 p-2 rounded-2xl -mx-2' : ''}`;
             div.innerHTML = `
              <div class="w-8 h-8 rounded-full ${isOrganizer ? 'bg-brand text-white' : 'bg-blue-100 text-blue-600'} flex items-center justify-center font-bold text-xs flex-shrink-0 shadow-sm">
                ${userInitials}
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-bold text-gray-900">${userName}</span>
                  ${isOrganizer ? '<span class="text-[9px] font-black uppercase tracking-tighter bg-brand text-white px-1.5 py-0.5 rounded-md">Organizer</span>' : ''}
                  <span class="text-xs text-gray-400 ml-auto">${new Date(c.created_at).toLocaleDateString()}</span>
                </div>
                <p class="text-sm text-gray-600 mt-1">${c.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
                <div class="flex items-center gap-4 mt-2">
                  <button class="text-xs font-semibold text-gray-500 hover:text-red-500 flex items-center gap-1 transition react-btn ${isReacted ? 'reacted text-red-500' : ''}" onclick="toggleCommentReact(this, ${c.id})">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="${isReacted ? 'currentColor' : 'none'}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                    <span class="react-count">${reactionCount}</span>
                  </button>
                  <button class="text-xs font-semibold text-gray-500 hover:text-brand transition flex items-center gap-1" onclick="showReplyInput(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                    </svg>
                    Reply
                  </button>
                </div>
                
                <!-- Replies -->
                <div class="mt-3 pl-4 border-l-2 border-gray-100 space-y-4" id="replies-${c.id}">
                </div>

                <!-- Hidden Reply Input -->
                <div class="mt-3 hidden reply-box">
                  <div class="flex gap-2">
                    <div class="flex-1 bg-gray-50 rounded-xl flex items-center pr-1 border border-gray-100 focus-within:border-brand transition-colors">
                      <input type="text" id="reply-input-${c.id}" placeholder="Write a reply..." class="flex-1 bg-transparent px-3 py-1.5 text-xs outline-none text-gray-700" />
                      <button onclick="postComment(${c.id})" class="text-brand font-bold text-[10px] px-2 py-1 rounded-lg hover:bg-brand-light transition">Send</button>
                    </div>
                  </div>
                </div>
              </div>
             `;
             list.appendChild(div);
             
             const repliesContainer = div.querySelector(`#replies-${c.id}`);
             cReplies.forEach(r => {
               const rUserInitials = (r.user && r.user.first_name) ? r.user.first_name.substring(0, 2).toUpperCase() : 'AN';
                 const rUserName = (r.user && r.user.first_name) ? r.user.first_name + ' ' + (r.user.last_name || '') : 'Anonymous';
                 const rIsOrganizer = r.user && (r.user.id === organizerId);
                 const rReactCount = r.reacted_by_users ? r.reacted_by_users.length : 0;
                 const currentUserId = <%= user ? user.id : 'null' %>;
                 const rIsReacted = r.reacted_by_users && r.reacted_by_users.some(x => x.id === currentUserId);
               
               const rDiv = document.createElement('div');
               rDiv.className = `flex gap-2.5 ${rIsOrganizer ? 'bg-brand-light/20 p-1.5 rounded-xl' : ''}`;
               rDiv.innerHTML = `
                  <div class="w-6 h-6 rounded-full ${rIsOrganizer ? 'bg-brand text-white' : 'bg-gray-200 text-gray-700'} flex items-center justify-center font-bold text-[10px] flex-shrink-0 shadow-sm">
                    ${rUserInitials}
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-xs font-bold text-gray-900">${rUserName}</span>
                      ${rIsOrganizer ? '<span class="text-[8px] font-black uppercase tracking-tighter bg-brand text-white px-1 py-0.5 rounded-md">Organizer</span>' : ''}
                      <span class="text-[10px] text-gray-400 ml-auto">${new Date(r.created_at).toLocaleDateString()}</span>
                    </div>
                    <p class="text-xs text-gray-600 mt-0.5">${r.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
                    <div class="flex items-center gap-3 mt-1.5">
                      <button class="text-[10px] font-semibold text-gray-500 hover:text-red-500 flex items-center gap-1 transition react-btn ${rIsReacted ? 'reacted text-red-500' : ''}" onclick="toggleCommentReact(this, ${r.id})">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="${rIsReacted ? 'currentColor' : 'none'}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                        <span class="react-count">${rReactCount}</span>
                      </button>
                    </div>
                  </div>
               `;
               repliesContainer.appendChild(rDiv);
             });
          });
        })
        .catch(err => {
          console.error(err);
          document.getElementById('comments-list').innerHTML = '<p class="text-sm text-red-500 text-center py-4">Error loading comments.</p>';
        });
    }

    function postComment(parentId = null) {
      const inputId = parentId ? `reply-input-${parentId}` : 'new-comment-text';
      const inputEl = document.getElementById(inputId);
      const text = inputEl.value.trim();
      
      if (!text) return;
      
      fetch(`/api/events/${ev.id}/comment`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          text: text,
          parent_comment_id: parentId
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          inputEl.value = '';
          if (parentId) {
            const btn = inputEl.closest('.reply-box').previousElementSibling; // Button section
            showReplyInput(inputEl.parentElement.querySelector('button')); // close reply box
          }
          loadComments(); // Reload comments
        }
      })
      .catch(alert);
    }

    function loadPhotos() {
      fetch(`/api/events/${ev.id}/photos`)
        .then(res => res.json())
        .then(data => {
            const container = document.getElementById('gallery-container');
            container.innerHTML = '';
            
            // Add poster as main
            const mainDiv = document.createElement('div');
            mainDiv.id = 'gallery-main';
            mainDiv.className = 'col-span-2 rounded-2xl overflow-hidden';
            mainDiv.style.height = '160px';
            mainDiv.innerHTML = `<img src="${ev.img}" class="w-full h-full object-cover" />`;
            container.appendChild(mainDiv);

            if (data.photos && data.photos.length > 0) {
                const limit = Math.min(data.photos.length, 2);
                for (let i = 0; i < limit; i++) {
                  const pDiv = document.createElement('div');
                  pDiv.className = 'rounded-xl overflow-hidden bg-gray-100 relative';
                  pDiv.style.height = '100px';
                  
                  let contents = `<img src="${data.photos[i].image_url}" class="w-full h-full object-cover" />`;
                  
                  if (i === 1 && data.photos.length > 2) {
                    contents += `
                      <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                        <p class="text-white font-bold text-sm">+${data.photos.length - 2} more</p>
                      </div>`;
                  }
                  pDiv.innerHTML = contents;
                  container.appendChild(pDiv);
                }
            } else {
               // Show default empty state if no extra photos
               const p1 = document.createElement('div');
               p1.className = 'rounded-xl border border-dashed border-gray-300 flex items-center justify-center';
               p1.style.height = '100px';
               p1.innerHTML = '<span class="text-xs text-gray-400">No photos</span>';
               container.appendChild(p1);
            }
        })
        .catch(console.error);
    }
    
    // Call loaders on init!
    loadComments();
    loadPhotos();

    // Auto-log visit and grab status
    fetch(`/api/events/${ev.id}/status`)
      .then(res => res.json())
      .then(data => {
        if (data.bookmarked) {
          ev.liked = true;
          document.getElementById('heart-btn').classList.add('liked');
        } else {
          ev.liked = false;
          document.getElementById('heart-btn').classList.remove('liked');
        }
        
        if (data.visits !== undefined) {
           document.getElementById('detail-going').textContent = formatGoing(data.visits);
        }

        // Setup Rating UI
        setupRating(data.rating, data.avgRating, data.totalRatings);
      }).catch(console.error);

    // Log the visit independently and update UI
    fetch(`/api/events/${ev.id}/visit`, { method: 'POST' })
      .then(res => res.json())
      .then(data => {
        if (data.success && data.visits !== undefined) {
           document.getElementById('detail-going').textContent = formatGoing(data.visits);
        }
      });

    function setupRating(userRating, avgRating, total) {
      const parent = document.getElementById('rating-section');
      if (!parent) return;

      const stars = parent.querySelectorAll('.star');
      const text = document.getElementById('rating-text');
      
      if (userRating) {
        text.innerHTML = `You rated this <b>${userRating} stars</b>! (Avg: ${avgRating}★ from ${total})`;
        highlightStars(stars, userRating);
      } else {
        text.innerHTML = `Click to rate! (Avg: ${avgRating}★ from ${total})`;
      }
      
      stars.forEach(star => {
        star.onclick = () => {
          if (userRating) return; // already rated
          const val = parseInt(star.getAttribute('data-val'));
          fetch(`/api/events/${ev.id}/rate`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rating: val })
          }).then(r => r.json()).then(d => {
            if (d.success) {
              userRating = val;
              text.innerHTML = `You rated this <b>${val} stars</b>!`;
              highlightStars(stars, val);
            } else {
              alert(d.error);
            }
          });
        }
      });
    }

    function highlightStars(stars, val) {
      stars.forEach(s => {
        if (parseInt(s.getAttribute('data-val')) <= val) {
          s.classList.add('text-yellow-400');
          s.classList.remove('text-gray-300');
        } else {
          s.classList.remove('text-yellow-400');
          s.classList.add('text-gray-300');
        }
      });
    }

    /* ── Location Logic ── */
    function checkLocationBeforeMap() {
      if (!navigator.geolocation) {
        // Fallback for browsers that don't support geolocation
        window.location.href = '/map';
        return;
      }

      // Check permission status if API is available
      if (navigator.permissions && navigator.permissions.query) {
        navigator.permissions.query({ name: 'geolocation' }).then(result => {
          if (result.state === 'granted') {
            // Already granted, proceed to map
            window.location.href = '/map';
          } else {
            // Not granted or prompt needed, show our custom modal
            document.getElementById('location-modal').classList.remove('hidden');
          }
        });
      } else {
        // Fallback: just show the modal to be safe
        document.getElementById('location-modal').classList.remove('hidden');
      }
    }

    function closeLocationModal() {
      document.getElementById('location-modal').classList.add('hidden');
    }

    function requestLocationAccess() {
      // Trigger the browser's native location prompt
      navigator.geolocation.getCurrentPosition(
        (position) => {
          // Success! Permission granted and location retrieved.
          // We don't necessarily need the coordinates here as the map page will fetch them.
          closeLocationModal();
          window.location.href = '/map';
        },
        (error) => {
          // User denied or error occurred
          console.error('Location error:', error);
          // Even if they deny, we might want to let them view the map without their current location,
          // OR we show a message. Usually, navigation apps need location.
          // For now, let's just proceed to the map - the map page should handle the empty state.
          // But based on user request: "prompt first... if not turn on"
          alert("Please enable location services in your device settings to use the navigation features.");
          closeLocationModal();
          // We still let them go to the map, but they've been warned.
          window.location.href = '/map';
        },
        { enableHighAccuracy: true, timeout: 5000, maximumAge: 0 }
      );
    }
  </script>
</body>

</html>