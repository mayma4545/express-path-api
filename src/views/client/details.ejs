          class="w-14 h-14 rounded-2xl bg-brand flex items-center justify-center flex-shrink-0 shadow-md shadow-brand/20">
          <span id="org-initial" class="text-white text-xl font-extrabold"></span>
        </div>
        <div>
          <p class="text-xs text-gray-400 font-medium mb-0.5">Event Organizer</p>
          <p id="detail-organizer" class="text-base font-bold text-gray-900"></p>
          <p class="text-xs text-brand font-medium mt-0.5">View all events →</p>
