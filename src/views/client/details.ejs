              </div>
              
              <!-- Replies -->
              <div class="mt-3 pl-4 border-l-2 border-gray-100 space-y-4">
                <div class="flex gap-2.5">
                  <div class="w-6 h-6 rounded-full bg-brand text-white flex items-center justify-center font-bold text-[10px] flex-shrink-0 shadow-md">
                    EV
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center justify-between">
                      <span class="text-xs font-bold text-gray-900">Event Organizer</span>
                      <span class="text-[10px] text-gray-400">1h ago</span>
                    </div>
                    <p class="text-xs text-gray-600 mt-0.5">Yes, there will be multiple food stalls serving local delicacies!</p>
                    <div class="flex items-center gap-3 mt-1.5">
                      <button class="text-[10px] font-semibold text-gray-500 hover:text-red-500 flex items-center gap-1 transition react-btn" onclick="toggleCommentReact(this)">
