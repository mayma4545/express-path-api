          <p class="text-lg font-extrabold text-gray-900">12</p>
          <p class="text-xs text-gray-400">Past Events</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3 text-center">
          <p class="text-lg font-extrabold text-brand">4.9 ★</p>
