<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="description" content="Log in to OhSee — your Programs & Events Navigator for Masbate." />
  <title>OhSee — Log In</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#1DA1F2',
              dark: '#0d8fd9',
              light: '#e8f5fe',
            },
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui'],
          },
          keyframes: {
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(24px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            },
            ripple: {
              '0%': { transform: 'scale(0)', opacity: '0.5' },
              '100%': { transform: 'scale(4)', opacity: '0' },
            },
          },
          animation: {
            'fade-up': 'fadeUp 0.55s cubic-bezier(.22,1,.36,1) both',
            'fade-up-slow': 'fadeUp 0.7s 0.1s cubic-bezier(.22,1,.36,1) both',
            ripple: 'ripple 0.55s linear',
          },
        },
      },
    };
  </script>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ── Utility overrides ─────────────────────────────── */
    html,
    body {
      overscroll-behavior: none;
      -webkit-tap-highlight-color: transparent;
    }

    /* Ripple effect container */
    .btn-ripple {
      position: relative;
      overflow: hidden;
    }

    .ripple-circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.35);
      width: 10px;
      height: 10px;
      margin-top: -5px;
      margin-left: -5px;
      animation: ripple 0.55s linear;
      pointer-events: none;
    }

    /* Input focus ring */
    .input-field:focus {
      outline: none;
      border-color: #1DA1F2;
      box-shadow: 0 0 0 3px rgba(29, 161, 242, 0.18);
    }

    /* Password toggle (no default browser icon) */
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
      display: none;
    }

    /* Subtle scrollbar for very small screens */
    ::-webkit-scrollbar {
      width: 4px;
    }

    ::-webkit-scrollbar-thumb {
      background: #d1d5db;
      border-radius: 99px;
    }
  </style>
</head>

<body class="font-sans bg-white min-h-screen flex items-center justify-center">

  <!-- ══════════════════════════════════════════════════
       Mobile shell — max-w-sm centres content on wide
       desktops while staying full-width on phones
  ══════════════════════════════════════════════════ -->
  <main id="login-screen"
    class="relative w-full max-w-sm min-h-screen bg-white flex flex-col justify-between px-6 pt-14 pb-10 overflow-hidden">

    <!-- Back button -->
    <a href="/landing" aria-label="Go back"
      class="absolute top-5 left-5 flex items-center justify-center w-10 h-10 rounded-full transition-colors active:bg-gray-100 hover:bg-gray-50 text-gray-400 hover:text-gray-700 z-10 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>

    <!-- ── HEADER ───────────────────────────────────── -->
    <header class="relative flex flex-col items-center gap-4 animate-fade-up">

      <!-- Logo mark -->
      <div class="relative flex items-center justify-center">
        <!-- Pulse ring -->
        <span aria-hidden="true" class="pulse-ring absolute w-16 h-16 rounded-full bg-brand opacity-20"></span>
        <div class="w-14 h-14 rounded-2xl bg-brand flex items-center justify-center shadow-lg shadow-brand/30">
          <!-- Simple compass icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Zm3.5-11.5-5 2.5-2.5 5 5-2.5Z" />
          </svg>
        </div>
      </div>

      <div class="text-center">
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">Welcome back</h1>
        <p class="mt-1 text-sm text-gray-400">Sign in to continue to <span class="text-brand font-semibold">PAEMA</span>
        </p>
      </div>
    </header>

    <!-- ── FORM ─────────────────────────────────────── -->
    <section class="relative flex-1 flex flex-col justify-center gap-5 animate-fade-up-slow">

      <form id="login-form" action="/login" method="POST" novalidate class="flex flex-col gap-4" aria-label="Login form">

        <!-- Username -->
        <div class="flex flex-col gap-1">
          <label for="username" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</label>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0ZM12 14a7 7 0 0 0-7 7h14a7 7 0 0 0-7-7Z" />
              </svg>
            </span>
            <input id="username" name="email" type="email" autocomplete="email" placeholder="e.g. juan@example.com"
              class="input-field w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200"
              required />
          </div>
          <p id="username-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
        </div>

        <!-- Password -->
        <div class="flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <label for="password" class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Password</label>
            <button type="button" id="forgot-btn"
              class="text-xs text-brand font-medium hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded">
              Forgot password?
            </button>
          </div>
          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </span>
            <input id="password" name="password" type="password" autocomplete="current-password" placeholder="••••••••"
              class="input-field w-full pl-10 pr-11 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-800 placeholder-gray-300 transition-all duration-200"
              required />
            <!-- show/hide toggle -->
            <button type="button" id="toggle-password" aria-label="Toggle password visibility"
              class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-brand focus:outline-none transition-colors duration-150">
              <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" />
              </svg>
              <svg id="eye-off-icon" xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 hidden" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 3l18 18M10.477 10.477A3 3 0 0 0 13.523 13.523M6.228 6.228A10.45 10.45 0 0 0 2.458 12C3.732 16.057 7.523 19 12 19c1.688 0 3.274-.42 4.658-1.163M9.342 4.222A10.45 10.45 0 0 1 12 3c4.478 0 8.268 2.943 9.542 7a10.49 10.49 0 0 1-1.84 3.434" />
              </svg>
            </button>
          </div>
          <p id="password-error" class="hidden text-xs text-red-500 mt-0.5 ml-1" role="alert"></p>
        </div>

        <!-- Login button -->
        <button type="submit" id="login-btn"
          class="btn-ripple mt-2 w-full py-3.5 rounded-xl bg-brand text-white font-bold text-sm tracking-wide shadow-md shadow-brand/30 hover:bg-brand-dark active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 disabled:opacity-60 disabled:cursor-not-allowed"
          aria-live="polite">
          <span id="btn-label">Log In</span>
          <!-- Spinner (hidden by default) -->
          <svg id="btn-spinner" class="hidden animate-spin inline-block w-4 h-4 ml-2 text-white"
            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v8H4Z" />
          </svg>
        </button>
      </form>

      <!-- Divider -->
      <div class="flex items-center gap-3">
        <span class="flex-1 h-px bg-gray-200"></span>
        <span class="text-xs text-gray-400 font-medium">or continue with</span>
        <span class="flex-1 h-px bg-gray-200"></span>
      </div>

      <!-- Google button -->
      <button id="google-btn" type="button"
        class="btn-ripple w-full flex items-center justify-center gap-3 py-3.5 rounded-xl border border-gray-200 bg-white text-gray-700 font-semibold text-sm shadow-sm hover:bg-gray-50 hover:border-gray-300 active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">
        <!-- Google "G" logo -->
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#EA4335"
            d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5Z" />
          <path fill="#4285F4"
            d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65Z" />
          <path fill="#FBBC05"
            d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19Z" />
          <path fill="#34A853"
            d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48Z" />
          <path fill="none" d="M0 0h48v48H0Z" />
        </svg>
        Continue with Google
      </button>

    </section>

    <!-- ── FOOTER ────────────────────────────────────── -->
    <footer class="relative text-center animate-fade-up-slow space-y-3">
      <p class="text-sm text-gray-400">
        Don't have an account?
        <a id="signup-link" href="#"
          class="text-brand font-semibold hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded">
          Sign up
        </a>
      </p>
      <div class="pt-2 border-t border-gray-100">
        <p class="text-xs text-gray-400">
          Are you an organizer? 
          <a href="/organizer/login" class="text-gray-600 font-bold hover:text-brand transition-colors">
            Login to Portal
          </a>
        </p>
      </div>
    </footer>

  </main>

  <!-- ══════════════════════════════════════════════════
       Google Auth Error Modal
  ══════════════════════════════════════════════════ -->
  <div id="google-error-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-6" aria-modal="true" role="dialog">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    <!-- Card -->
    <div class="relative w-full max-w-xs bg-white rounded-2xl shadow-2xl p-6 flex flex-col items-center gap-4 animate-fade-up">
      <!-- Icon -->
      <div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
        </svg>
      </div>
      <!-- Text -->
      <div class="text-center">
        <h2 class="text-base font-extrabold text-gray-900">Account Not Found</h2>
        <p id="modal-message" class="mt-1.5 text-sm text-gray-500 leading-snug">The Google account you selected is not registered in our system. Please sign up first or use a registered account.</p>
      </div>
      <!-- Actions -->
      <div class="flex gap-3 w-full mt-1">
        <button id="modal-signup-btn" type="button"
          class="flex-1 py-2.5 rounded-xl bg-brand text-white font-bold text-sm hover:bg-brand-dark active:scale-95 transition-all">
          Sign Up
        </button>
        <button id="modal-close-btn" type="button"
          class="flex-1 py-2.5 rounded-xl border border-gray-200 text-gray-600 font-semibold text-sm hover:bg-gray-50 active:scale-95 transition-all">
          Try Again
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       Toast Notification
  ══════════════════════════════════════════════════ -->
  <div id="toast" role="status" aria-live="polite" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50
              bg-gray-900 text-white text-xs font-medium px-4 py-2.5 rounded-full
              shadow-xl opacity-0 pointer-events-none
              transition-all duration-300 ease-out whitespace-nowrap">
  </div>

  <!-- ══════════════════════════════════════════════════
       JavaScript
  ══════════════════════════════════════════════════ -->
  <script>
    /* ─── Ripple helper ────────────────────────────── */
    function addRipple(btn, e) {
      const rect = btn.getBoundingClientRect();
      const circle = document.createElement('span');
      circle.classList.add('ripple-circle');
      circle.style.left = (e.clientX - rect.left) + 'px';
      circle.style.top = (e.clientY - rect.top) + 'px';
      btn.appendChild(circle);
      circle.addEventListener('animationend', () => circle.remove());
    }
    document.querySelectorAll('.btn-ripple').forEach(btn => {
      btn.addEventListener('pointerdown', e => addRipple(btn, e));
    });

    /* ─── Toast helper ─────────────────────────────── */
    let toastTimer;
    function showToast(msg, duration = 2800) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.remove('opacity-0');
      toast.classList.add('opacity-100');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0');
      }, duration);
    }

    /* ─── Password toggle ──────────────────────────── */
    const passwordInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eye-icon');
    const eyeOffIcon = document.getElementById('eye-off-icon');
    const toggleBtn = document.getElementById('toggle-password');

    toggleBtn.addEventListener('click', () => {
      const shown = passwordInput.type === 'text';
      passwordInput.type = shown ? 'password' : 'text';
      eyeIcon.classList.toggle('hidden', !shown);
      eyeOffIcon.classList.toggle('hidden', shown);
      toggleBtn.setAttribute('aria-label', shown ? 'Show password' : 'Hide password');
    });

    /* ─── Inline validation helpers ────────────────── */
    function setError(inputId, errorId, message) {
      const input = document.getElementById(inputId);
      const error = document.getElementById(errorId);
      input.classList.add('border-red-400', 'bg-red-50');
      input.classList.remove('border-gray-200', 'bg-gray-50');
      error.textContent = message;
      error.classList.remove('hidden');
    }
    function clearError(inputId, errorId) {
      const input = document.getElementById(inputId);
      const error = document.getElementById(errorId);
      input.classList.remove('border-red-400', 'bg-red-50');
      input.classList.add('border-gray-200', 'bg-gray-50');
      error.classList.add('hidden');
    }
    function validate() {
      let valid = true;
      const username = document.getElementById('username').value.trim();
      const password = document.getElementById('password').value;

      if (!username) {
        setError('username', 'username-error', 'Username is required.');
        valid = false;
      } else if (username.length < 3) {
        setError('username', 'username-error', 'Must be at least 3 characters.');
        valid = false;
      } else {
        clearError('username', 'username-error');
      }

      if (!password) {
        setError('password', 'password-error', 'Password is required.');
        valid = false;
      } else if (password.length < 6) {
        setError('password', 'password-error', 'Must be at least 6 characters.');
        valid = false;
      } else {
        clearError('password', 'password-error');
      }

      return valid;
    }

    /* Clear errors on input */
    document.getElementById('username').addEventListener('input', () => clearError('username', 'username-error'));
    document.getElementById('password').addEventListener('input', () => clearError('password', 'password-error'));

    /* ─── Login form submit ─────────────────────────── */
    const loginForm = document.getElementById('login-form');
    const loginBtn = document.getElementById('login-btn');
    const btnLabel = document.getElementById('btn-label');
    const btnSpinner = document.getElementById('btn-spinner');

    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validate()) return;

      loginBtn.disabled = true;
      btnLabel.textContent = 'Logging in…';
      btnSpinner.classList.remove('hidden');

      try {
        const formData = new FormData(loginForm);
        const data = Object.fromEntries(formData.entries());

        const response = await fetch('/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          const errorMsg = result.error || 'Invalid email or password';
          
          // Show error inline under the email field to indicate it's not a valid user
          setError('username', 'username-error', errorMsg);
          
          loginBtn.disabled = false;
          btnLabel.textContent = 'Log In';
          btnSpinner.classList.add('hidden');
          return;
        }

        showToast('✓ Logged in successfully!');
        window.location.href = '/home';
      } catch (err) {
        showToast('An error occurred. Please try again.', true);
        loginBtn.disabled = false;
        btnLabel.textContent = 'Log In';
        btnSpinner.classList.add('hidden');
      }
    });

    /* ─── Forgot password ───────────────────────────── */
    document.getElementById('forgot-btn').addEventListener('click', () => {
      showToast('Password reset link sent to your email.');
    });

    /* ─── Google sign-in ────────────────────────────── */
    document.getElementById('google-btn').addEventListener('click', () => {
      showToast('Redirecting to Google…');
      window.location.href = '/auth/google?flow=login';
    });

    /* ─── Sign up link ──────────────────────────────── */
    document.getElementById('signup-link').addEventListener('click', (e) => {
      e.preventDefault();
      window.location.href = '/signup';
    });

    /* ─── Google Error Modal ────────────────────────── */
    const googleErrorModal = document.getElementById('google-error-modal');
    const modalBackdrop   = document.getElementById('modal-backdrop');
    const modalCloseBtn   = document.getElementById('modal-close-btn');
    const modalSignupBtn  = document.getElementById('modal-signup-btn');
    let modalTimer;

    function showGoogleErrorModal(msg) {
      if (msg) document.getElementById('modal-message').textContent = msg;
      googleErrorModal.classList.remove('hidden');
      // Auto-dismiss after 6 seconds
      modalTimer = setTimeout(closeGoogleErrorModal, 6000);
    }

    function closeGoogleErrorModal() {
      clearTimeout(modalTimer);
      googleErrorModal.classList.add('hidden');
      // Clean the URL so refreshing doesn't re-show the modal
      const cleanUrl = window.location.pathname;
      window.history.replaceState({}, document.title, cleanUrl);
    }

    modalCloseBtn.addEventListener('click', closeGoogleErrorModal);
    modalBackdrop.addEventListener('click', closeGoogleErrorModal);
    modalSignupBtn.addEventListener('click', () => { window.location.href = '/signup'; });

    /* ─── Handle initial state from URL ─────────────── */
    window.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const error = urlParams.get('error');
      const message = urlParams.get('message');

      if (error) {
        // Google auth failures → show prominent modal with the server's specific message
        if (error.toLowerCase().includes('invalid user') || error.toLowerCase().includes('not registered') || error.toLowerCase().includes('organizer')) {
          showGoogleErrorModal(error);
        } else {
          showToast(error, 4000);
        }
      }

      if (message) {
        showToast(message);
      }
    });
  </script>
</body>

</html>