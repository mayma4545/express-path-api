<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>My Profile � EventFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { brand: '#1DA1F2', 'brand-dark': '#0d8de0', 'brand-light': '#e8f5fe' },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
    .fade-up { animation: fadeUp .4s ease forwards; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .tab-btn { transition: all .2s; }
    .tab-btn.active { color: #1DA1F2; border-bottom: 2px solid #1DA1F2; font-weight: bold; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* Toast Styles */
    #toast-container {
      position: fixed;
      bottom: 100px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      width: 90%;
      max-width: 350px;
      pointer-events: none;
    }
    .toast {
      background: white;
      border-radius: 16px;
      padding: 12px 16px;
      margin-top: 10px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      display: flex;
      align-items: center;
      gap: 12px;
      animation: toastIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
      border: 1px solid #f1f5f9;
      pointer-events: auto;
    }
    @keyframes toastIn {
      from { opacity: 0; transform: translateY(20px) scale(0.9); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .toast.hide {
      animation: toastOut 0.3s ease forwards;
    }
    @keyframes toastOut {
      from { opacity: 1; transform: scale(1); }
      to { opacity: 0; transform: scale(0.9); }
    }

    /* Loader Styles */
    .spinner {
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 50%;
      border-top-color: #fff;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body class="min-h-screen max-w-md mx-auto overflow-x-hidden relative pb-[90px]">
  
  <div id="toast-container"></div>

  <!-- Header -->
  <div class="bg-white px-5 pt-6 pb-6 shadow-sm sticky top-0 z-40">
    <div class="flex items-center justify-between">
      <a href="/home" class="bg-gray-100 rounded-full p-2.5 text-gray-700 active:scale-95 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-lg font-bold text-gray-900">My Profile</h1>
      <a href="/logout" class="bg-red-50 rounded-full p-2.5 text-red-600 active:scale-95 transition-all" title="Logout">
         <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
           <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
         </svg>
      </a>
    </div>
    
    <!-- Profile Info -->
    <div class="flex items-center gap-4 mt-6">
      <div class="w-16 h-16 rounded-full bg-brand text-white flex items-center justify-center text-xl font-bold shadow-md overflow-hidden">
        <% if (user.avatar_url) { %>
          <img src="<%= user.avatar_url %>" class="w-full h-full object-cover" alt="Profile" />
        <% } else { %>
          <%= user.first_name ? user.first_name[0].toUpperCase() : 'U' %>
        <% } %>
      </div>
      <div>
        <h2 class="text-xl font-extrabold text-gray-900"><%= user.first_name %> <%= user.last_name %></h2>
        <p class="text-xs text-gray-500 font-medium mt-0.5"><%= user.email %></p>
      </div>
    </div>
  </div>

  <div class="mt-2 bg-white px-5 pt-3 shadow-sm mb-4">
    <!-- Tabs -->
    <div class="flex border-b border-gray-100 overflow-x-auto no-scrollbar">
      <button id="tab-bookmarks" class="tab-btn active flex-1 py-3 text-sm text-center whitespace-nowrap" onclick="switchTab('bookmarks')">Bookmarks</button>
      <button id="tab-history" class="tab-btn flex-1 py-3 text-sm text-gray-400 text-center whitespace-nowrap" onclick="switchTab('history')">History</button>
      <button id="tab-edit" class="tab-btn flex-1 py-3 text-sm text-gray-400 text-center whitespace-nowrap" onclick="switchTab('edit')">Edit Profile</button>
      <button id="tab-security" class="tab-btn flex-1 py-3 text-sm text-gray-400 text-center whitespace-nowrap" onclick="switchTab('security')">Security</button>
    </div>
  </div>

  <div class="px-5 fade-up">
    <!-- Bookmarks Tab -->
    <div id="tab-bookmarks-content" class="tab-content active space-y-4">
      <% if (bookmarkedEvents && bookmarkedEvents.length > 0) { %>
        <% bookmarkedEvents.forEach(ev => { %>
          <div id="bookmark-<%= ev.id %>" class="bg-white rounded-2xl p-4 flex flex-col gap-3 shadow-sm border border-gray-100 active:scale-[0.99] transition cursor-pointer" onclick="window.location.href='/details?id=<%= ev.id %>'">
            <div class="flex gap-4">
              <img src="<%= ev.image_url || 'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800' %>" 
                   onerror="this.src='https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800'; this.onerror=null;"
                   class="w-20 h-20 rounded-xl object-cover shadow-sm" alt="Event Image" />
              <div class="flex-1 py-1">
                <span class="text-[10px] font-bold text-brand uppercase tracking-wider bg-brand-light px-2 py-0.5 rounded-full"><%= new Date(ev.event_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                <h4 class="text-sm font-extrabold text-gray-900 mt-1.5 leading-tight"><%= ev.title %></h4>
                <div class="flex items-start gap-1 mt-2 text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <p class="text-xs font-medium leading-relaxed"><%= ev.venue %></p>
                </div>
              </div>
            </div>
            <div class="flex gap-2 pt-1 border-t border-gray-50 mt-1">
               <button class="flex-1 bg-brand-light text-brand text-[11px] font-bold py-2 rounded-xl transition hover:bg-brand/10" onclick="event.stopPropagation(); window.location.href='/details?id=<%= ev.id %>'">View Details</button>
               <button class="px-4 bg-red-50 text-red-500 text-[11px] font-bold py-2 rounded-xl transition hover:bg-red-100 flex items-center gap-1" onclick="unbookmarkEvent(event, <%= ev.id %>)">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                 Unbookmark
               </button>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="text-center py-10">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
             <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <p class="text-sm font-bold text-gray-900">No bookmarks yet</p>
          <p class="text-xs text-gray-500 mt-1">Tap the heart on an event to save it here.</p>
        </div>
      <% } %>
    </div>

    <!-- History Tab -->
    <div id="tab-history-content" class="tab-content space-y-4">
      <% if (visitedEvents && visitedEvents.length > 0) { %>
        <% visitedEvents.forEach(ev => { %>
          <div class="bg-white rounded-3xl p-4 flex flex-col gap-3 shadow-sm border border-gray-100 active:scale-[0.99] transition cursor-pointer" onclick="window.location.href='/details?id=<%= ev.id %>'">
            <div class="flex gap-4">
              <div class="relative w-16 h-16 flex-shrink-0">
                <img src="<%= ev.image_url || 'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800' %>" 
                     onerror="this.src='https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800'; this.onerror=null;"
                     class="w-full h-full rounded-2xl object-cover" alt="Event Image" />
                <div class="absolute inset-0 bg-black/10 rounded-2xl"></div>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-extrabold text-gray-900 truncate leading-tight"><%= ev.title %></h4>
                <p class="text-[10px] text-gray-400 font-medium mt-1">Visited on <%= new Date(ev.visited_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                
                <!-- Activities Badge -->
                <div class="flex flex-wrap gap-1.5 mt-2">
                  <% if (ev.activity.liked) { %>
                    <span class="flex items-center gap-1 text-[9px] font-bold bg-pink-50 text-red-500 px-2 py-0.5 rounded-lg">
                      <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                      Liked
                    </span>
                  <% } %>
                  <% if (ev.activity.bookmarked) { %>
                    <span class="flex items-center gap-1 text-[9px] font-bold bg-blue-50 text-brand px-2 py-0.5 rounded-lg">
                      <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                      Bookmarked
                    </span>
                  <% } %>
                  <% if (ev.activity.commentCount > 0) { %>
                    <span class="flex items-center gap-1 text-[9px] font-bold bg-green-50 text-green-600 px-2 py-0.5 rounded-lg">
                      <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                      <%= ev.activity.commentCount %> Comment<%= ev.activity.commentCount > 1 ? 's' : '' %>
                    </span>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>

        <!-- Pagination UI -->
        <% if (pagination.totalPages > 1) { %>
          <div class="flex items-center justify-center gap-2 pt-6 pb-2">
            <% if (pagination.hasPrev) { %>
              <a href="/profile?page=<%= pagination.currentPage - 1 %>&tab=history" class="w-10 h-10 flex items-center justify-center rounded-2xl bg-white border border-gray-100 text-gray-600 shadow-sm active:scale-90 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
              </a>
            <% } %>

            <div class="flex items-center gap-1.5 px-4 h-10 bg-white border border-gray-100 rounded-2xl shadow-sm">
               <span class="text-xs font-extrabold text-gray-900"><%= pagination.currentPage %></span>
               <span class="text-[10px] font-bold text-gray-300 uppercase tracking-tighter">of</span>
               <span class="text-xs font-extrabold text-gray-400"><%= pagination.totalPages %></span>
            </div>

            <% if (pagination.hasNext) { %>
              <a href="/profile?page=<%= pagination.currentPage + 1 %>&tab=history" class="w-10 h-10 flex items-center justify-center rounded-2xl bg-white border border-gray-100 text-gray-600 shadow-sm active:scale-90 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            <% } %>
          </div>
        <% } %>

      <% } else { %>
        <div class="text-center py-10">
          <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
             <svg class="w-8 h-8 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-12 0 9 9 0 0112 0z"/></svg>
          </div>
          <p class="text-sm font-bold text-gray-900">No activity history</p>
          <p class="text-xs text-gray-500 mt-1">Events you visit will appear here.</p>
        </div>
      <% } %>
    </div>

    <!-- Edit Profile Tab -->
    <div id="tab-edit-content" class="tab-content">
      <form id="edit-profile-form" class="space-y-5 bg-white p-6 rounded-3xl border border-gray-100 shadow-sm" onsubmit="updateProfile(event)">
        <!-- Avatar Upload -->
        <div class="flex flex-col items-center mb-6">
            <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-input').click()">
                <div class="w-24 h-24 rounded-full bg-gray-100 border-2 border-dashed border-gray-200 flex items-center justify-center overflow-hidden">
                    <% if (user.avatar_url) { %>
                        <img id="avatar-preview" src="<%= user.avatar_url %>" class="w-full h-full object-cover" />
                    <% } else { %>
                        <div id="avatar-placeholder" class="text-gray-300">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <img id="avatar-preview" class="w-full h-full object-cover hidden" />
                    <% } %>
                </div>
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 rounded-full flex items-center justify-center transition-opacity">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <input type="file" id="avatar-input" name="avatar" class="hidden" accept="image/*" onchange="previewAvatar(this)" />
            </div>
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-3">Change Profile Photo</p>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">First Name</label>
          <input type="text" name="first_name" value="<%= user.first_name %>" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm font-medium focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" required />
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Last Name</label>
          <input type="text" name="last_name" value="<%= user.last_name %>" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm font-medium focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" required />
        </div>
        <div class="pt-4">
          <button type="submit" id="save-btn" class="w-full bg-brand text-white font-bold py-4 rounded-2xl shadow-lg shadow-brand/20 active:scale-95 transition-all text-sm">Save Changes</button>
        </div>
      </form>
    </div>

    <!-- Security Tab -->
    <div id="tab-security-content" class="tab-content">
      <form id="security-form" class="space-y-5 bg-white p-6 rounded-3xl border border-gray-100 shadow-sm" onsubmit="updateSecurity(event)">
        <% if (user.password_hash) { %>
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Current Password</label>
          <div class="relative">
            <input type="password" name="currentPassword" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm font-medium focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" required />
            <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors" onclick="togglePassword(this)">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>
        <% } %>
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">New Password</label>
          <div class="relative">
            <input type="password" name="newPassword" id="newPassword" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm font-medium focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" required />
            <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors" onclick="togglePassword(this)">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Confirm New Password</label>
          <div class="relative">
            <input type="password" id="confirmPassword" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-4 py-3.5 text-sm font-medium focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all" required />
            <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors" onclick="togglePassword(this)">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>
        <div class="pt-4">
          <button type="submit" id="security-save-btn" class="w-full bg-gray-900 text-white font-bold py-4 rounded-2xl shadow-lg shadow-gray-900/10 active:scale-95 transition-all text-sm">Update Password</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.parentElement.querySelector('input');
      const icon = btn.querySelector('svg');
      if (input.type === 'password') {
        input.type = 'text';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />';
      } else {
        input.type = 'password';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
      }
    }

    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = `toast ${type === 'success' ? 'text-green-600' : 'text-red-600'}`;
      
      const icon = type === 'success' 
        ? '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>'
        : '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>';

      toast.innerHTML = `
        ${icon}
        <span class="text-xs font-bold">${message}</span>
      `;
      
      container.appendChild(toast);
      
      setTimeout(() => {
        toast.classList.add('hide');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('avatar-preview');
                const placeholder = document.getElementById('avatar-placeholder');
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                if (placeholder) placeholder.classList.add('hidden');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    function switchTab(name) {
      ['bookmarks', 'history', 'edit', 'security'].forEach(t => {
        const btn = document.getElementById('tab-' + t);
        const content = document.getElementById('tab-' + t + '-content');
        if (!btn || !content) return;

        if (t === name) {
          btn.classList.add('active', 'text-brand');
          btn.classList.remove('text-gray-400');
          content.classList.add('active');
        } else {
          btn.classList.remove('active', 'text-brand');
          btn.classList.add('text-gray-400');
          content.classList.remove('active');
        }
      });
    }

    async function unbookmarkEvent(e, id) {
      e.stopPropagation();
      if (!confirm('Remove this event from your bookmarks?')) return;

      try {
        const res = await fetch(`/api/events/${id}/bookmark`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        if (data.success && !data.bookmarked) {
          const card = document.getElementById(`bookmark-${id}`);
          card.style.opacity = '0';
          card.style.transform = 'translateY(10px)';
          setTimeout(() => {
            card.remove();
            if (document.querySelectorAll('#tab-bookmarks-content > div[id^="bookmark-"]').length === 0) {
              location.reload(); // Show empty state
            }
          }, 300);
        }
      } catch (err) {
        console.error(err);
      }
    }

    async function updateProfile(e) {
      e.preventDefault();
      const btn = document.getElementById('save-btn');
      const oldHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<div class="flex items-center justify-center gap-2"><div class="spinner"></div><span>Saving...</span></div>';

      const formData = new FormData(e.target);

      try {
        const res = await fetch('/profile/update', {
          method: 'POST',
          body: formData
        });
        const result = await res.json();
        if (result.success) {
          showToast('Profile updated successfully!');
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(result.error || 'Update failed', 'error');
          btn.disabled = false;
          btn.innerHTML = oldHtml;
        }
      } catch (err) {
        console.error(err);
        showToast('An error occurred', 'error');
        btn.disabled = false;
        btn.innerHTML = oldHtml;
      }
    }

    async function updateSecurity(e) {
      e.preventDefault();
      const newPwd = document.getElementById('newPassword').value;
      const confirmPwd = document.getElementById('confirmPassword').value;
      
      if (newPwd !== confirmPwd) {
        showToast('Passwords do not match', 'error');
        return;
      }

      const btn = document.getElementById('security-save-btn');
      const oldHtml = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<div class="flex items-center justify-center gap-2"><div class="spinner"></div><span>Updating...</span></div>';

      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());

      try {
        const res = await fetch('/profile/security', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) {
          showToast('Password updated successfully!');
          setTimeout(() => location.reload(), 1000);
        } else {
          showToast(result.error || 'Update failed', 'error');
          btn.disabled = false;
          btn.innerHTML = oldHtml;
        }
      } catch (err) {
        console.error(err);
        showToast('An error occurred', 'error');
        btn.disabled = false;
        btn.innerHTML = oldHtml;
      }
    }
  </script>
</body>
</html>
