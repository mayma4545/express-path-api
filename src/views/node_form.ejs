<%- include('partials/header', { title: (typeof node !== 'undefined' && node ? 'Edit Node' : 'Create Node') + ' - Campus Navigation' }) %>

<div class="page-header">
    <h1><%= typeof node !== 'undefined' && node ? '✏️ Edit Node' : '➕ Create Node' %></h1>
    <a href="/nodes" class="btn-secondary">← Back to Nodes</a>
</div>

<div class="form-container">
    <form action="<%= typeof node !== 'undefined' && node ? '/nodes/' + node.node_id + '/edit' : '/nodes/create' %>" method="POST" enctype="multipart/form-data" class="styled-form">

        <!-- ===== Basic Information ===== -->
        <div class="form-section">
            <div class="form-section-header">
                <span class="form-section-icon">📋</span>
                <div>
                    <h3 class="form-section-title">Basic Information</h3>
                    <p class="form-section-subtitle">Essential details about this node</p>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="node_code">Node Code <span class="required">*</span></label>
                    <input type="text" id="node_code" name="node_code"
                        value="<%= typeof node !== 'undefined' && node ? node.node_code : '' %>"
                        placeholder="e.g., NODE-20260101-120000"
                        <%= typeof node !== 'undefined' && node ? 'readonly style="background:#f5f5f5;color:#888;"' : '' %>
                        required>
                    <% if (!node) { %>
                        <small class="help-text">Auto-generated. You may customize it if needed.</small>
                    <% } else { %>
                        <small class="help-text">Node code cannot be changed after creation.</small>
                    <% } %>
                </div>
                <div class="form-group">
                    <label for="name">Name <span class="required">*</span></label>
                    <input type="text" id="name" name="name"
                        value="<%= typeof node !== 'undefined' && node ? node.name : '' %>"
                        placeholder="e.g., Computer Lab 1" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="building">Building <span class="required">*</span></label>
                    <input type="text" id="building" name="building"
                        value="<%= typeof node !== 'undefined' && node ? (node.building || '') : '' %>"
                        placeholder="e.g., Engineering Building" required>
                </div>
                <div class="form-group">
                    <label for="floor_level">Floor Level <span class="required">*</span></label>
                    <input type="number" id="floor_level" name="floor_level"
                        value="<%= typeof node !== 'undefined' && node ? (node.floor_level || 1) : 1 %>"
                        placeholder="e.g., 1" required>
                    <small class="help-text">Use negative numbers for basement levels</small>
                </div>
            </div>

            <div class="form-group">
                <label for="type_of_node">Node Type</label>
                <select id="type_of_node" name="type_of_node">
                    <option value="room"      <%= (typeof node !== 'undefined' && node && node.type_of_node === 'room')      ? 'selected' : '' %>>🚪 Room</option>
                    <option value="hallway"   <%= (typeof node !== 'undefined' && node && node.type_of_node === 'hallway')   ? 'selected' : '' %>>🚶 Hallway</option>
                    <option value="entrance"  <%= (typeof node !== 'undefined' && node && node.type_of_node === 'entrance')  ? 'selected' : '' %>>🚪 Entrance</option>
                    <option value="staircase" <%= (typeof node !== 'undefined' && node && node.type_of_node === 'staircase') ? 'selected' : '' %>>🪜 Staircase</option>
                    <option value="elevator"  <%= (typeof node !== 'undefined' && node && node.type_of_node === 'elevator')  ? 'selected' : '' %>>🛗 Elevator</option>
                    <option value="landmark"  <%= (typeof node !== 'undefined' && node && node.type_of_node === 'landmark')  ? 'selected' : '' %>>📍 Landmark</option>
                </select>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Additional information..."><%= typeof node !== 'undefined' && node ? (node.description || '') : '' %></textarea>
            </div>
        </div>

        <!-- ===== Media & Images ===== -->
        <div class="form-section">
            <div class="form-section-header">
                <span class="form-section-icon">🖼️</span>
                <div>
                    <h3 class="form-section-title">Media &amp; Images</h3>
                    <p class="form-section-subtitle">360° panorama image for this location</p>
                </div>
            </div>

            <div class="form-group">
                <label for="image_360">360° Panorama Image</label>
                <input type="file" id="image_360" name="image_360" accept="image/*">
                <% if (typeof node !== 'undefined' && node && node.image360) { %>
                    <div class="current-image-info">
                        <span>✓ Current 360° image is set — </span><a href="<%= node.image360 %>" target="_blank">View Image</a>
                        <span style="color:#888;"> | Upload a new file to replace it.</span>
                    </div>
                <% } %>
            </div>

            <div class="form-group">
                <label for="annotation">Initial View Angle (0–360°)</label>
                <input type="number" id="annotation" name="annotation"
                    step="0.1" min="0" max="360"
                    value="<%= typeof node !== 'undefined' && node && node.annotation !== null ? node.annotation : '' %>"
                    placeholder="e.g., 90 (facing East)">
                <small class="help-text">The angle in the 360° image where this room entrance faces. 0° = North, 90° = East, 180° = South, 270° = West</small>
            </div>
        </div>

        <!-- ===== Map Position ===== -->
        <div class="form-section">
            <div class="form-section-header">
                <span class="form-section-icon">🗺️</span>
                <div>
                    <h3 class="form-section-title">Map Position</h3>
                    <p class="form-section-subtitle">Coordinates on the campus map (0–100%)</p>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="map_x">Map X Coordinate (0–100%)</label>
                    <input type="number" id="map_x" name="map_x" step="0.01" min="0" max="100"
                        value="<%= typeof node !== 'undefined' && node ? (node.map_x !== null ? node.map_x : '') : '' %>"
                        placeholder="e.g., 45.5">
                </div>
                <div class="form-group">
                    <label for="map_y">Map Y Coordinate (0–100%)</label>
                    <input type="number" id="map_y" name="map_y" step="0.01" min="0" max="100"
                        value="<%= typeof node !== 'undefined' && node ? (node.map_y !== null ? node.map_y : '') : '' %>"
                        placeholder="e.g., 32.1">
                </div>
            </div>
        </div>

        <!-- ===== QR Code ===== -->
        <div class="form-section">
            <div class="form-section-header">
                <span class="form-section-icon">📲</span>
                <div>
                    <h3 class="form-section-title">QR Code</h3>
                    <p class="form-section-subtitle">Auto-generated for mobile scanning</p>
                </div>
            </div>

            <% if (typeof node !== 'undefined' && node && node.qrcode) { %>
                <div class="qr-preview">
                    <img src="<%= node.qrcode %>" alt="QR Code" style="width:120px;height:120px;border:2px solid #e0e0e0;border-radius:8px;">
                    <div class="form-group checkbox-group" style="margin-top:12px;">
                        <label>
                            <input type="checkbox" name="regenerate_qr">
                            Regenerate QR Code
                        </label>
                        <small class="help-text">Only check if you've changed the Node Code</small>
                    </div>
                </div>
            <% } else { %>
                <p class="help-text">A QR code will be automatically generated when this node is created.</p>
            <% } %>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary"><%= typeof node !== 'undefined' && node ? '💾 Update Node' : '✨ Create Node' %></button>
            <a href="/nodes" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
// Auto-generate a date-time-based node code for new nodes
(function() {
    var nodeCodeInput = document.getElementById('node_code');
    if (nodeCodeInput && !nodeCodeInput.readOnly && !nodeCodeInput.value) {
        var now = new Date();
        var pad = function(n) { return String(n).padStart(2, '0'); };
        nodeCodeInput.value = 'NODE-' +
            now.getFullYear() +
            pad(now.getMonth() + 1) +
            pad(now.getDate()) + '-' +
            pad(now.getHours()) +
            pad(now.getMinutes()) +
            pad(now.getSeconds());
    }
})();
</script>

<%- include('partials/footer') %>
