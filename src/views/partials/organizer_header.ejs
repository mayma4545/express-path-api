
<header class="flex justify-between items-center shrink-0 pt-2 mb-4">
  <div class="flex items-center gap-3">
    <% if (typeof backUrl !== 'undefined' && backUrl) { %>
      <a href="<%= backUrl %>" class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-textMain shadow-sm border border-slate-200 hover:bg-slate-50 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </a>
    <% } %>
    <div>
      <h1 class="text-xl font-bold tracking-tight text-textMain flex items-center gap-2">
        <%= typeof headerTitle !== 'undefined' ? headerTitle : 'Command Center' %>
        <% if (typeof showPulse === 'undefined' || showPulse) { %>
        <span class="flex h-2.5 w-2.5 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand"></span>
        </span>
        <% } %>
      </h1>
      <p class="text-xs text-textMuted mt-0.5"><%= typeof headerSubtitle !== 'undefined' ? headerSubtitle : 'Organizer Portal' %> • <%= sessionAuth.organizerName %></p>
    </div>
  </div>
  
  <!-- Notification Circle & Actions -->
  <div class="flex items-center gap-2 relative">
    <% if (typeof customActions !== 'undefined' && customActions) { %>
      <%- customActions %>
    <% } %>

    <div class="relative">
      <button id="notif-toggle" class="h-10 w-10 rounded-full bg-white border border-brand/20 flex items-center justify-center text-brand shadow-[0_4px_15px_rgba(29,161,242,0.15)] overflow-visible hover:bg-brand-light transition-colors relative">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
      <div id="notif-badge" class="hidden absolute -top-1 -right-1 h-5 min-w-[20px] px-1 bg-red-500 text-white text-[10px] font-bold rounded-full border-2 border-white flex items-center justify-center">0</div>
    </button>

    <!-- Notification Dropdown -->
    <div id="notif-dropdown" class="hidden absolute right-0 mt-3 w-72 max-h-[450px] overflow-hidden bg-white/95 backdrop-blur-xl border border-white rounded-3xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.15)] z-[100] flex flex-col scale-95 opacity-0 origin-top-right transition-all duration-200">
      <div class="p-4 border-b border-gray-100 flex justify-between items-center bg-slate-50/50">
        <div>
          <h3 class="font-bold text-sm text-slate-800">Notifications</h3>
          <p id="unread-count-text" class="text-[10px] text-brand font-bold">0 New</p>
        </div>
        <button id="mark-all-read-btn" class="text-[10px] font-bold text-slate-400 hover:text-brand transition-colors">Mark all as read</button>
      </div>
      <div id="notif-list" class="overflow-y-auto no-scrollbar flex-1 divide-y divide-gray-50">
        <div class="p-8 text-center">
          <div class="w-12 h-12 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
          </div>
          <p class="text-xs text-slate-400">Loading notifications...</p>
        </div>
      </div>
      <a href="/organizer/notifications" class="p-3 text-center text-xs font-bold text-brand bg-slate-50 hover:bg-brand-light transition-colors">
        View All Notifications
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('notif-toggle');
    const dropdown = document.getElementById('notif-dropdown');
    const list = document.getElementById('notif-list');
    const badge = document.getElementById('notif-badge');
    const unreadCountText = document.getElementById('unread-count-text');

    let isOpen = false;

    function updateBadge(count) {
      if (count > 0) {
        badge.textContent = count;
        badge.classList.remove('hidden');
        if (unreadCountText) unreadCountText.textContent = `${count} New`;
      } else {
        badge.classList.add('hidden');
        if (unreadCountText) unreadCountText.textContent = 'No New';
      }
    }

    function toggleDropdown() {
      isOpen = !isOpen;
      if (isOpen) {
        dropdown.classList.remove('hidden');
        setTimeout(() => {
          dropdown.classList.remove('scale-95', 'opacity-0');
          dropdown.classList.add('scale-100', 'opacity-100');
        }, 10);
        loadNotifications();
      } else {
        dropdown.classList.remove('scale-100', 'opacity-100');
        dropdown.classList.add('scale-95', 'opacity-0');
        setTimeout(() => dropdown.classList.add('hidden'), 200);
      }
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleDropdown();
    });

    const markAllBtn = document.getElementById('mark-all-read-btn');
    if (markAllBtn) {
        markAllBtn.addEventListener('click', async (e) => {
            e.stopPropagation();
            try {
                const response = await fetch('/organizer/notifications/mark-all-read', { method: 'POST' });
                if (response.ok) {
                    updateBadge(0);
                    document.querySelectorAll('#notif-list a').forEach(el => {
                        el.classList.remove('bg-brand/5');
                        const dot = el.querySelector('.unread-dot');
                        if (dot) dot.remove();
                    });
                }
            } catch (err) {
                console.error('Error marking all as read:', err);
            }
        });
    }

    document.addEventListener('click', (e) => {
      if (isOpen && !dropdown.contains(e.target) && !toggle.contains(e.target)) {
        toggleDropdown();
      }
    });

    async function loadNotifications() {
      try {
        const response = await fetch('/organizer/api/notifications');
        const data = await response.json();
        
        updateBadge(data.unreadCount);

        if (data.notifications && data.notifications.length > 0) {
          list.innerHTML = data.notifications.map(n => {
            const time = new Date(n.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const date = new Date(n.created_at).toLocaleDateString([], { month: 'short', day: 'numeric' });
            
            let redirectUrl = '/organizer/events/' + n.event_id;
            const sep = redirectUrl.includes('?') ? '&' : '?';
            
            if (n.type === 'comment' || n.type === 'comment_reaction') {
              redirectUrl += sep + 'tab=about&action=scrollToComments' + (n.target_id ? '&targetId=' + n.target_id : '');
              redirectUrl += '&read_notif=' + n.id;
            } else {
              redirectUrl += sep + 'read_notif=' + n.id;
            }

            let icon = '&#x1F514;';
            let iconBg = 'bg-brand-light';
            if (n.type === 'comment') { icon = '&#x1F4AC;'; iconBg = 'bg-blue-100'; }
            else if (n.type === 'like' || n.type === 'comment_reaction') { icon = '&#x2764;&#xFE0F;'; iconBg = 'bg-pink-100'; }
            else if (n.type === 'ending_soon') { icon = '&#x26A0;&#xFE0F;'; iconBg = 'bg-yellow-100'; }

            return '<a href="' + redirectUrl + '" data-notif-id="' + n.id + '" class="flex items-start gap-3 p-4 hover:bg-slate-50 transition-colors ' + (!n.is_read ? 'bg-brand/5' : '') + '">'
              + '<div class="w-8 h-8 rounded-full ' + iconBg + ' flex items-center justify-center text-sm shrink-0">' + icon + '</div>'
              + '<div class="flex-1 min-w-0">'
              + '<p class="text-[12px] font-medium text-slate-800 leading-snug">' + n.message + '</p>'
              + '<div class="flex items-center gap-2 mt-1">'
              + '<span class="text-[10px] text-slate-400">' + date + ' &bull; ' + time + '</span>'
              + (!n.is_read ? '<span class="w-1.5 h-1.5 rounded-full bg-brand unread-dot"></span>' : '')
              + '</div></div></a>';
          }).join('');

          // Attach async click handlers so the fetch completes before navigation
          document.querySelectorAll('#notif-list a[data-notif-id]').forEach(link => {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              const notifId = this.getAttribute('data-notif-id');
              const href = this.href;
              window.markAsRead(notifId, href);
            });
          });

        } else {
          list.innerHTML = '<div class="p-8 text-center text-slate-400"><p class="text-xs">No notifications yet.</p></div>';
        }
      } catch (error) {
        console.error('Error loading notifications:', error);
        list.innerHTML = '<p class="p-4 text-center text-xs text-red-500">Failed to load notifications.</p>';
      }
    }

    // Lightweight badge-only refresh (used for polling)
    async function fetchUnreadCount() {
      try {
        const response = await fetch('/organizer/api/notifications');
        const data = await response.json();
        updateBadge(data.unreadCount);
      } catch (err) { /* silent fail */ }
    }

    // markAsRead: awaits the server call BEFORE navigating to ensure count is saved
    window.markAsRead = async function(id, navigateTo) {
      // Optimistic UI update
      const currentCount = parseInt(badge.textContent || '0');
      if (!badge.classList.contains('hidden') && currentCount > 0) {
        updateBadge(currentCount - 1);
      }
      const clickedLink = document.querySelector('#notif-list a[data-notif-id="' + id + '"]');
      if (clickedLink) {
        clickedLink.classList.remove('bg-brand/5');
        const dot = clickedLink.querySelector('.unread-dot');
        if (dot) dot.remove();
      }

      // Wait for server confirmation before navigating
      try {
        await fetch('/organizer/notifications/' + id + '/read', { method: 'POST', keepalive: true });
      } catch (err) {
        console.error('Error marking as read:', err);
      }

      if (navigateTo) window.location.href = navigateTo;
    };

    // Auto-process read_notif param when arriving from a notification link
    const urlParams = new URLSearchParams(window.location.search);
    const readNotifId = urlParams.get('read_notif');
    if (readNotifId) {
        fetch('/organizer/notifications/' + readNotifId + '/read', { method: 'POST' })
            .catch(err => console.error('Error in auto markAsRead:', err));
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.delete('read_notif');
        window.history.replaceState({}, document.title, newUrl.toString());
    }

    // Load badge immediately on every organizer page
    fetchUnreadCount();

    // Keep badge real-time with 30-second polling
    setInterval(fetchUnreadCount, 30000);
  });
</script>
