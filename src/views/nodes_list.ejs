<%- include('partials/header', { title: 'Nodes - Campus Navigation' }) %>

<div class="page-header">
    <h1>📍 Nodes</h1>
    <a href="/nodes/create" class="btn-primary">+ Add Node</a>
</div>

<!-- Search Bar -->
<div class="search-bar-wrapper">
    <span class="search-icon">🔍</span>
    <input type="text" id="nodeSearch" class="search-bar-input"
        placeholder="Search by name, building, node code, or type..."
        oninput="filterNodes(this.value)">
    <button class="search-clear" id="searchClearBtn" onclick="clearSearch()" title="Clear search">✕</button>
</div>

<!-- Sort Controls -->
<div class="sort-controls">
    <span class="sort-label">Sort by:</span>
    <button class="sort-btn active" id="sort-name" onclick="sortTable('name', this)">Name</button>
    <button class="sort-btn" id="sort-building" onclick="sortTable('building', this)">Building</button>
    <button class="sort-btn" id="sort-floor" onclick="sortTable('floor', this)">Floor</button>
    <button class="sort-btn sort-dir-btn" id="sort-dir" onclick="toggleSortDir(this)">↑ Asc</button>
</div>

<div id="node-count" class="record-count"></div>

<% if (nodes.length === 0) { %>
    <div class="empty-state">
        <p>No nodes found. Create your first node to get started.</p>
        <a href="/nodes/create" class="btn-primary">Create Node</a>
    </div>
<% } else { %>
    <div class="table-responsive">
        <table class="data-table" id="nodesTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Node Code</th>
                    <th data-col="name">Name</th>
                    <th data-col="building">Building</th>
                    <th data-col="floor">Floor</th>
                    <th>Type</th>
                    <th>360° Image</th>
                    <th>QR Code</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="nodesTableBody">
                <% nodes.forEach(function(node) { %>
                    <tr class="node-row"
                        data-name="<%= (node.name || '').toLowerCase() %>"
                        data-building="<%= (node.building || '').toLowerCase() %>"
                        data-code="<%= (node.node_code || '').toLowerCase() %>"
                        data-type="<%= (node.type_of_node || '').toLowerCase() %>"
                        data-floor="<%= node.floor_level || 0 %>">
                        <td><%= node.node_id %></td>
                        <td><code><%= node.node_code %></code></td>
                        <td><strong><%= node.name %></strong></td>
                        <td><%= node.building || '-' %></td>
                        <td><%= node.floor_level || '-' %></td>
                        <td>
                            <span class="badge badge-<%= node.type_of_node %>">
                                <%= node.type_of_node %>
                            </span>
                        </td>
                        <td>
                            <% if (node.image360) { %>
                                <span class="status-yes">✓ Yes</span>
                            <% } else { %>
                                <span class="status-no">✗ No</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (node.qrcode) { %>
                                <a href="<%= node.qrcode %>" target="_blank" class="btn-link">View QR</a>
                            <% } else { %>
                                <span class="status-no">Not generated</span>
                            <% } %>
                        </td>
                        <td class="actions">
                            <a href="/nodes/<%= node.node_id %>/edit" class="btn-sm btn-edit">Edit</a>
                            <a href="/nodes/<%= node.node_id %>/delete" class="btn-sm btn-delete">Delete</a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <div id="no-results" class="empty-state" style="display:none;">
        <p>No nodes match your search. <a href="#" onclick="clearSearch();return false;">Clear search</a></p>
    </div>
<% } %>

<script>
var currentSort = 'name';
var sortDir = 'asc';

function filterNodes(query) {
    var q = query.toLowerCase().trim();
    var rows = document.querySelectorAll('.node-row');
    var visible = 0;
    rows.forEach(function(row) {
        var match = !q ||
            row.dataset.name.includes(q) ||
            row.dataset.building.includes(q) ||
            row.dataset.code.includes(q) ||
            row.dataset.type.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
    document.getElementById('searchClearBtn').style.display = q ? 'flex' : 'none';
    updateCount(visible, rows.length);
}

function clearSearch() {
    document.getElementById('nodeSearch').value = '';
    filterNodes('');
}

function updateCount(visible, total) {
    var el = document.getElementById('node-count');
    if (!el) return;
    el.textContent = visible === total
        ? 'Showing all ' + total + ' nodes'
        : 'Showing ' + visible + ' of ' + total + ' nodes';
}

function sortTable(col, btn) {
    currentSort = col;
    document.querySelectorAll('.sort-btn:not(.sort-dir-btn)').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    applySort();
}

function toggleSortDir(btn) {
    sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    btn.textContent = sortDir === 'asc' ? '↑ Asc' : '↓ Desc';
    applySort();
}

function applySort() {
    var tbody = document.getElementById('nodesTableBody');
    if (!tbody) return;
    var rows = Array.from(tbody.querySelectorAll('.node-row'));
    rows.sort(function(a, b) {
        var valA, valB;
        if (currentSort === 'name') { valA = a.dataset.name; valB = b.dataset.name; }
        else if (currentSort === 'building') { valA = a.dataset.building; valB = b.dataset.building; }
        else if (currentSort === 'floor') { valA = parseFloat(a.dataset.floor) || 0; valB = parseFloat(b.dataset.floor) || 0; }
        if (valA < valB) return sortDir === 'asc' ? -1 : 1;
        if (valA > valB) return sortDir === 'asc' ? 1 : -1;
        return 0;
    });
    rows.forEach(function(row) { tbody.appendChild(row); });
}

// Init
(function() {
    var total = document.querySelectorAll('.node-row').length;
    updateCount(total, total);
    document.getElementById('searchClearBtn').style.display = 'none';
})();
</script>

<%- include('partials/footer') %>
