<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Events - Organizer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#e8f5fd', DEFAULT: '#1DA1F2', dark: '#1a8fd8' },
            bgWhite: '#FFFFFF',
            bgLight: '#f4f8fd',
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(29, 161, 242, 0.3)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; -webkit-tap-highlight-color: transparent; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="text-textMain pb-20 overflow-x-hidden bg-[#f4f8fd]">

  <!-- Main Content Wrapper -->
  <main class="max-w-2xl mx-auto p-4 sm:p-6 md:py-10">
    <!-- Top Bar -->
    <header class="flex flex-col sm:flex-row justify-between sm:items-center gap-4 mb-6 sm:mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-textMain tracking-tight">My Events</h1>
        <p class="text-xs sm:text-sm font-medium text-textMuted mt-1">Manage your ongoing and scheduled activities.</p>
      </div>
      <div class="flex w-full sm:w-64 relative">
        <svg class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input type="text" id="searchInput" placeholder="Search events..." class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand shadow-sm transition">
      </div>
      <a href="/organizer/events/add" class="w-full sm:w-auto text-center bg-brand hover:bg-brand-dark text-white px-5 py-2.5 rounded-xl font-bold shadow-float transition cursor-pointer">
        Create Event
      </a>
    </header>

    <style>
      .glass-panel {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 1);
        box-shadow: 0 10px 40px -10px rgba(29, 161, 242, 0.1);
      }
    </style>
    <div id="organizerEventCards" class="space-y-4 relative z-10">
      <% events.forEach(evt => { %>
        <div onclick="window.location.href='/organizer/events/<%= evt.id %>'" data-title="<%= (evt.title || evt.name || '').toLowerCase() %>" data-venue="<%= (evt.venue || '').toLowerCase() %>" class="event-card cursor-pointer glass-panel p-4 rounded-3xl flex flex-col gap-2 shrink-0 relative overflow-hidden group hover:scale-[1.01] transition-transform">
          <div class="absolute right-0 top-0 w-32 h-32 bg-brand/10 rounded-full blur-[40px] pointer-events-none group-hover:bg-brand/20 transition-colors"></div>
          <div class="flex justify-between items-start relative z-10">
            <span class="text-[10px] font-bold <%= evt.is_ongoing ? 'text-emerald-600 bg-emerald-50' : 'text-brand bg-brand-light' %> uppercase tracking-widest flex items-center gap-1.5 px-2 py-1 rounded-md">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <%= evt.status %>
            </span>
            <span class="text-[10px] font-mono bg-slate-100 px-2 py-1 rounded text-textMuted border border-slate-200">
              <%= evt.event_date %>
            </span>
          </div>
          <h2 class="text-xl font-extrabold text-textMain leading-tight mt-1 relative z-10 truncate"><%= evt.title || evt.name %></h2>
          
          <div class="flex items-center text-xs font-medium text-textMuted mb-1 relative z-10">
            <svg class="w-3.5 h-3.5 mr-1 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="truncate"><%= evt.venue %></span>
          </div>

          <div class="mt-1 bg-slate-50/80 rounded-2xl p-3 flex justify-between items-center border border-slate-200 relative z-10 shadow-sm">
            <div class="flex flex-col">
              <span class="text-[10px] text-textMuted uppercase tracking-wider font-bold">Schedule</span>
              <span class="text-sm text-slate-700 font-semibold mt-0.5"><%= evt.start_time || 'TBD' %> - <%= evt.end_time || 'TBD' %></span>
            </div>
            <% if(evt.capacity) { %>
            <div class="flex flex-col items-end">
              <span class="text-[10px] text-textMuted uppercase tracking-wider font-bold">Capacity</span>
              <span class="text-sm text-slate-700 font-semibold mt-0.5"><%= evt.capacity %> max</span>
            </div>
            <% } %>
          </div>
        </div>
      <% }); %>

      <% if (events.length === 0) { %>
        <div class="py-10 flex flex-col items-center justify-center text-textMuted bg-white rounded-3xl border border-gray-50 shadow-sm p-4">
          <svg class="w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <span class="text-sm font-medium">No events found.</span>
        </div>
      <% } %>
    </div>
  </main>

  <!-- 5. Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-brand transition-colors group">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Scanner</span>
      </a>
      
      <a href="#" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
          <span class="absolute top-1.5 right-2 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white"></span>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Alerts</span>
      </a>
    </nav>
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');

    if (searchInput) {
      searchInput.addEventListener('input', function () {
        const query = searchInput.value.trim().toLowerCase();
        const cards = document.querySelectorAll('.event-card');

        cards.forEach(card => {
          const title = card.dataset.title || '';
          const venue = card.dataset.venue || '';
          const isMatch = !query || title.includes(query) || venue.includes(query);
          card.style.display = isMatch ? '' : 'none';
        });
      });
    }
  </script>
</body>
</html>