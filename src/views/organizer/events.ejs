<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Events - Organizer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#e8f5fd', DEFAULT: '#1DA1F2', dark: '#1a8fd8' },
            bgWhite: '#FFFFFF',
            bgLight: '#f4f8fd',
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(29, 161, 242, 0.3)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; -webkit-tap-highlight-color: transparent; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="text-textMain pb-20 overflow-x-hidden bg-[#f4f8fd]">

  <!-- Main Content Wrapper -->
  <main class="max-w-md mx-auto p-4 sm:p-6 md:py-10">
    <!-- Top Bar -->
    <%- include('../partials/organizer_header', { headerTitle: 'My Events', headerSubtitle: 'Manage Activities' }) %>

    <!-- Success Message -->

    <style>
      .glass-panel {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 1);
        box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
      }
    </style>
    <!-- Search and Filter Bar -->
    <div class="mb-6 space-y-3">
      <div class="relative group">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-textMuted group-focus-within:text-brand transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text" id="searchInput" placeholder="Search event title or venue..." 
          class="block w-full pl-11 pr-4 py-3.5 bg-white border border-slate-200 rounded-2xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand shadow-sm transition-all">
      </div>
      
      <div class="flex items-center gap-3">
        <div class="relative flex-1">
          <select id="sortFilter" class="appearance-none block w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-[13px] font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand shadow-sm transition-all cursor-pointer">
            <option value="newest">Newest First</option>
            <option value="oldest">Oldest First</option>
            <option value="az">A - Z Title</option>
            <option value="za">Z - A Title</option>
          </select>
          <div class="absolute inset-y-0 right-0 flex items-center px-3 pointer-events-none text-slate-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </div>
        </div>
        <div id="resultsCount" class="text-[11px] font-bold text-brand bg-brand-light px-3 py-2.5 rounded-xl border border-brand/10">
          <%= events.length %> Events
        </div>
      </div>
    </div>

    <div id="organizerEventCards" class="space-y-4 relative z-10 min-h-[200px]">
      <% events.forEach(evt => { %>
        <div onclick="window.location.href='/organizer/events/<%= evt.id %>'" 
          data-title="<%= (evt.title || evt.name || '').toLowerCase() %>" 
          data-venue="<%= (evt.venue || '').toLowerCase() %>" 
          data-date="<%= evt.event_date %>"
          class="event-card cursor-pointer bg-white border border-gray-50 rounded-3xl p-4 shadow-sm hover:shadow-md transition-all relative overflow-hidden group">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-2xl bg-[#F0F2FF] overflow-hidden flex items-center justify-center flex-shrink-0 border border-white shadow-sm">
              <% if(evt.image_url) { %>
                <img src="<%= evt.image_url %>" class="w-full h-full object-cover">
              <% } else { %>
                <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-extrabold text-textMain text-sm leading-tight line-clamp-2 mb-1 title-text"><%= evt.title || evt.name %></p>
              <div class="flex items-center text-xs font-medium text-textMuted mb-1">
                <svg class="w-3 h-3 mr-1 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="truncate"><%= evt.venue %></span>
              </div>
              <div class="flex items-center text-xs font-medium text-textMuted">
                <span class="text-[10px] font-bold <%= evt.is_ongoing ? 'text-emerald-600 bg-emerald-50' : 'text-brand bg-brand-light' %> uppercase tracking-widest flex items-center gap-1.5 px-2 py-0.5 rounded-md">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                  <%= evt.status %>
                </span>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 border border-gray-100 rounded-xl px-3 py-2.5 mb-4 flex justify-between items-center">
            <div class="flex items-center">
              <svg class="w-3.5 h-3.5 mr-1.5 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <span class="text-[13px] font-bold text-textMain date-text"><%= evt.event_date %></span>
            </div>
            <span class="text-xs font-medium text-textMuted bg-white border border-gray-200 px-2 py-0.5 rounded-md"><%= evt.start_time %> - <%= evt.end_time %></span>
          </div>
          
          <div class="pt-3 border-t border-gray-50 flex justify-end">
            <button onclick="event.stopPropagation(); window.location.href='/organizer/events/<%= evt.id %>'" class="text-xs font-bold text-brand bg-brand-light hover:bg-brand hover:text-white transition-all px-4 py-2 rounded-xl active:scale-95 flex items-center justify-center gap-1.5 w-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              View Details
            </button>
          </div>
        </div>
      <% }); %>

      <% if (events.length === 0) { %>
        <div id="noEventsMessage" class="py-10 flex flex-col items-center justify-center text-textMuted bg-white rounded-3xl border border-gray-50 shadow-sm p-4">
          <svg class="w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <span class="text-sm font-medium">No events found.</span>
        </div>
      <% } else { %>
        <div id="noResultsMessage" class="hidden py-10 flex flex-col items-center justify-center text-textMuted bg-white rounded-3xl border border-gray-50 shadow-sm p-4">
          <svg class="w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <span class="text-sm font-medium">No matches for your search.</span>
        </div>
      <% } %>
    </div>

    <!-- Pagination Controls -->
    <div id="paginationContainer" class="mt-8 flex justify-center items-center gap-2 relative z-10">
      <!-- Generated by JS -->
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const searchInput = document.getElementById('searchInput');
      const sortFilter = document.getElementById('sortFilter');
      const container = document.getElementById('organizerEventCards');
      const resultsCountText = document.getElementById('resultsCount');
      const paginationContainer = document.getElementById('paginationContainer');
      const noResultsMessage = document.getElementById('noResultsMessage');
      
      const ITEMS_PER_PAGE = 10;
      let currentPage = 1;
      let allCards = Array.from(document.querySelectorAll('.event-card'));
      let filteredCards = [...allCards];

      function updateUI() {
        const query = searchInput.value.trim().toLowerCase();
        const sortValue = sortFilter.value;

        // 1. Filter
        filteredCards = allCards.filter(card => {
          const title = card.dataset.title || '';
          const venue = card.dataset.venue || '';
          return !query || title.includes(query) || venue.includes(query);
        });

        // 2. Sort
        filteredCards.sort((a, b) => {
          if (sortValue === 'newest') return new Date(b.dataset.date) - new Date(a.dataset.date);
          if (sortValue === 'oldest') return new Date(a.dataset.date) - new Date(b.dataset.date);
          if (sortValue === 'az') return a.dataset.title.localeCompare(b.dataset.title);
          if (sortValue === 'za') return b.dataset.title.localeCompare(a.dataset.title);
          return 0;
        });

        // 3. Update Results Count
        resultsCountText.textContent = `${filteredCards.length} ${filteredCards.length === 1 ? 'Event' : 'Events'}`;
        
        // 4. Handle No Results
        if (filteredCards.length === 0) {
          if (noResultsMessage) noResultsMessage.classList.remove('hidden');
          paginationContainer.innerHTML = '';
          allCards.forEach(c => c.remove()); // Remove all from DOM
        } else {
          if (noResultsMessage) noResultsMessage.classList.add('hidden');
          renderPage();
          renderPagination();
        }
      }

      function renderPage() {
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const pageCards = filteredCards.slice(start, end);

        // Clear container except for messages
        allCards.forEach(c => c.remove());
        
        // Append cards for current page
        pageCards.forEach(card => {
          container.insertBefore(card, noResultsMessage || null);
        });
      }

      function renderPagination() {
        const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
        if (totalPages <= 1) {
          paginationContainer.innerHTML = '';
          return;
        }

        let html = '';
        
        // Previous Button
        html += `
          <button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} 
            class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed hover:bg-brand-light hover:text-brand transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
        `;

        // Page Numbers
        for (let i = 1; i <= totalPages; i++) {
          const isActive = i === currentPage;
          html += `
            <button onclick="changePage(${i})" 
              class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all
              ${isActive ? 'bg-brand text-white shadow-float shadow-brand/40 scale-110' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50'}">
              ${i}
            </button>
          `;
        }

        // Next Button
        html += `
          <button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} 
            class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 disabled:opacity-30 disabled:cursor-not-allowed hover:bg-brand-light hover:text-brand transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        `;

        paginationContainer.innerHTML = html;
      }

      window.changePage = function(page) {
        const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderPage();
        renderPagination();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      searchInput.addEventListener('input', () => {
        currentPage = 1;
        updateUI();
      });

      sortFilter.addEventListener('change', () => {
        currentPage = 1;
        updateUI();
      });

      // Initial Run
      updateUI();
    });

    // Show success message if event was deleted
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('deleted') === 'true') {
      const alert = document.getElementById('success-alert');
      if (alert) {
        alert.classList.remove('hidden');
        alert.classList.add('flex');
        setTimeout(() => {
          if (alert.parentElement) {
            alert.classList.add('opacity-0', 'translate-y-[-20px]', 'transition-all', 'duration-500');
            setTimeout(() => alert.remove(), 500);
          }
        }, 5000);
      }
    }
  </script>
<!-- 5. Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-bold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform ">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-brand group transition-colors">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors">
          <svg class="w-6 h-6" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative overflow-hidden">
          <% if (sessionAuth && sessionAuth.avatarUrl) { %>
            <img src="<%= sessionAuth.avatarUrl %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>
</body>
</html>