<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { DEFAULT: '#1DA1F2', light: '#e8f5fd', dark: '#0c85d0' },
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        } 
      }
    }
  </script>
  <style>
    body { 
      font-family: 'Inter', sans-serif; 
      background-color: #f4f8fd;
      -webkit-tap-highlight-color: transparent;
      overscroll-behavior-y: none;
    }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glass-panel:hover {
      background: rgba(255, 255, 255, 0.95);
      transform: translateY(-2px);
      box-shadow: 0 8px 25px -5px rgba(29, 161, 242, 0.15);
    }
  </style>
</head>
<body class="min-h-screen w-full overflow-x-hidden pb-20 text-textMain relative flex flex-col selection:bg-brand selection:text-white">
  
  <!-- Ambient Background Glow -->
  <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-brand/10 blur-[100px]"></div>
    <div class="absolute bottom-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-blue-300/10 blur-[100px]"></div>
    <div class="absolute top-[40%] right-[10%] w-[40%] h-[40%] rounded-full bg-emerald-300/10 blur-[100px]"></div>
  </div>

  <main class="relative z-10 flex flex-col h-full w-full p-4 gap-4 pb-24 max-w-lg mx-auto">
    
    <!-- 1. Header -->
    <%- include('../partials/organizer_header', { headerTitle: 'Intelligence Hub', headerSubtitle: 'Metrics & Analytics', showPulse: false }) %>

    <!-- Executive Summary Card -->
    <div class="glass-panel p-5 rounded-3xl flex justify-around items-center relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-brand/5 rounded-full blur-[30px]"></div>
      <div class="flex flex-col items-center">
        <span class="text-[10px] font-bold text-textMuted uppercase tracking-wider">Active</span>
        <span class="text-2xl font-extrabold text-emerald-500 mt-1"><%= activeEvents %></span>
      </div>
      <div class="w-px h-8 bg-slate-200"></div>
      <div class="flex flex-col items-center">
        <span class="text-[10px] font-bold text-textMuted uppercase tracking-wider">Finished</span>
        <span class="text-2xl font-extrabold text-indigo-500 mt-1"><%= finishedEvents %></span>
      </div>
      <div class="w-px h-8 bg-slate-200"></div>
      <div class="flex flex-col items-center">
        <span class="text-[10px] font-bold text-textMuted uppercase tracking-wider">Total</span>
        <span class="text-2xl font-extrabold text-slate-800 mt-1"><%= totalEvents %></span>
      </div>
    </div>

    <!-- DB-Driven Data Insights Module -->
    <div class="glass-panel p-5 rounded-3xl flex flex-col gap-3 relative overflow-hidden bg-gradient-to-br from-white via-white to-brand/5">
      <div class="absolute -right-4 -top-4 w-16 h-16 bg-brand/10 rounded-full blur-[20px]"></div>
      <div class="flex items-center gap-2 relative z-10">
        <div class="w-7 h-7 rounded-full bg-brand-light flex items-center justify-center text-brand">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-sm font-bold text-textMain tracking-tight">Data Insights</h3>
      </div>
      <p class="text-[13px] text-slate-600 leading-relaxed font-medium relative z-10">
        <% if(metrics.totalViews > 0) { %>
          <%
            let perfLevel = '';
            let actionItem = '';
            
            if (metrics.conversionRate >= 25 && metrics.avgRating >= 4.0) {
              perfLevel = "exceptional";
              actionItem = "Your events are highly engaging and well-received. Keep leveraging your current promotional strategies.";
            } else if (metrics.conversionRate >= 20) {
              perfLevel = "strong";
              actionItem = "Event discovery is performing well, but consider gathering attendee feedback to boost your reputation score.";
            } else if (metrics.conversionRate < 10) {
              perfLevel = "developing";
              actionItem = "Conversion is on the lower side. Enhance event descriptions and highlight key attractions to turn more views into check-ins.";
            } else {
              perfLevel = "steady";
              actionItem = "You have consistent engagement. Try experimenting with different event categories or promotional channels to increase overall reach.";
            }
          %>
          Across <%= totalEvents %> events, you have accumulated <span class="font-bold text-brand"><%= metrics.totalViews %> views</span> and <span class="font-bold text-slate-800"><%= metrics.totalAttendees %> check-ins</span>. 
          With a conversion rate of <span class="font-bold text-emerald-500"><%= metrics.conversionRate %>%</span>, your overall performance is <strong><%= perfLevel %></strong>. 
          <%= actionItem %>
        <% } else { %>
          There isn't enough interaction data to generate conversion insights yet. Create more events to gather analytics.
        <% } %>
      </p>
      
      <div class="flex items-center gap-3 mt-1 relative z-10 bg-slate-50/80 p-2.5 rounded-xl border border-slate-100">
        <div class="w-1.5 h-1.5 bg-brand rounded-full animate-pulse"></div>
        <span class="text-[10px] font-bold text-textMuted uppercase tracking-wider flex-1">Reputation Score</span>
        <div class="flex items-center gap-1.5 bg-white px-2 py-1 rounded shadow-sm border border-slate-100">
          <span class="text-xs font-extrabold <%= Number(metrics.avgRating) >= 4 ? 'text-emerald-500' : 'text-amber-500' %>"><%= metrics.avgRating %></span>
          <span class="text-[10px] font-semibold text-slate-400">/ 5.0</span>
        </div>
      </div>
    </div>

    <!-- Metric Grid -->
    <div class="grid grid-cols-2 gap-3 flex-1 min-h-0">
      
      <!-- Conversion Rate Card -->
      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between overflow-hidden relative group">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-emerald-500/10 rounded-full blur-[20px] transition-all group-hover:scale-150"></div>
        <div class="flex items-center justify-between relative z-10">
          <span class="text-[11px] font-bold text-textMuted uppercase tracking-wide">Conversion</span>
          <div class="w-5 h-5 rounded-full bg-emerald-50 flex items-center justify-center">
            <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
        </div>
        <div class="text-4xl font-extrabold text-brand mt-1 relative z-10 tracking-tighter"><%= metrics.conversionRate %><span class="text-xl text-brand/70">%</span></div>
        
        <div class="mt-4 flex flex-col gap-1.5 w-full relative z-10">
          <div class="flex justify-between items-end border-b border-slate-100 pb-1.5">
             <span class="text-xs font-bold text-slate-700 flex items-center gap-1"><%= metrics.totalAttendees %> <span class="text-[9px] text-textMuted font-medium uppercase">Attendees</span></span>
             <span class="text-[10px] font-bold text-textMuted uppercase"><%= metrics.totalViews %> Views</span>
          </div>
          <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden mt-0.5">
            <div class="bg-brand h-full rounded-full transition-all duration-1000" style="width: <%= Math.min(100, Math.max(5, metrics.conversionRate)) %>%"></div>
          </div>
        </div>
      </div>

      <!-- Social Engagement Card -->
      <div class="glass-panel p-4 rounded-3xl flex flex-col overflow-hidden relative justify-between">
        <div class="absolute -right-4 -top-4 w-16 h-16 bg-indigo-500/10 rounded-full blur-[20px]"></div>
        <div class="flex items-center justify-between relative z-10 mb-2">
          <span class="text-[11px] font-bold text-textMuted uppercase tracking-wide">Social Matrix</span>
        </div>
        <div class="grid grid-cols-2 gap-y-3 gap-x-2 mt-auto relative z-10 bg-slate-50/50 p-2.5 rounded-2xl border border-slate-100/50">
          <div class="flex flex-col border-r border-slate-200">
            <span class="text-[10px] text-textMuted font-bold uppercase tracking-wide mb-0.5">Likes</span>
            <span class="text-xl font-black text-indigo-500 tracking-tight"><%= metrics.totalLikes %></span>
          </div>
          <div class="flex flex-col pl-2">
            <span class="text-[10px] text-textMuted font-bold uppercase tracking-wide mb-0.5">Saves</span>
            <span class="text-xl font-black text-emerald-500 tracking-tight"><%= metrics.totalBookmarks %></span>
          </div>
          <div class="flex flex-col border-r border-t border-r-slate-200 border-t-slate-200 pt-1.5">
            <span class="text-[10px] text-textMuted font-bold uppercase tracking-wide mb-0.5">Comments</span>
            <span class="text-xl font-black text-rose-500 tracking-tight"><%= metrics.totalComments %></span>
          </div>
          <div class="flex flex-col border-t border-t-slate-200 pt-1.5 pl-2">
            <span class="text-[10px] text-textMuted font-bold uppercase tracking-wide mb-0.5">Navs</span>
            <span class="text-xl font-black text-brand tracking-tight"><%= metrics.totalNavigations %></span>
          </div>
        </div>
      </div>

    </div>

    <!-- Performance Leaderboard Chart -->
    <div class="glass-panel p-5 rounded-3xl flex flex-col gap-3 relative overflow-hidden">
      <div class="absolute -left-10 -bottom-10 w-32 h-32 bg-blue-500/5 rounded-full blur-[30px]"></div>
      <div class="flex justify-between items-start relative z-10">
        <div class="flex flex-col gap-0.5">
          <h3 class="text-sm font-bold text-textMain tracking-tight">Performance Velocity</h3>
          <p class="text-[10px] text-textMuted font-medium italic">Check-ins (Bars) vs Views (Line) on top events</p>
        </div>
        <div class="bg-brand-light text-brand p-1.5 rounded-lg border border-brand/20 shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
      </div>
      <div class="relative w-full mt-1 z-10" style="height: 200px;">
        <canvas id="performanceChart"></canvas>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <!-- Segment Analysis -->
      <div class="glass-panel p-4 rounded-3xl flex flex-col items-center gap-2 relative overflow-hidden">
        <div class="w-full flex items-center justify-between z-10">
          <span class="text-[11px] font-bold text-textMuted uppercase tracking-wide">Category Mix</span>
        </div>
        <div class="relative w-full mt-1 z-10" style="height: 140px;">
          <canvas id="categoryDoughnut"></canvas>
        </div>
      </div>

      <!-- Sentiment Breakdown -->
      <div class="glass-panel p-4 rounded-3xl flex flex-col items-center gap-2 relative overflow-hidden">
        <div class="w-full flex items-center justify-between z-10">
          <span class="text-[11px] font-bold text-textMuted uppercase tracking-wide">Rating Dist</span>
        </div>
        <div class="relative w-full mt-1 z-10" style="height: 140px;">
          <canvas id="sentimentRadar"></canvas>
        </div>
      </div>
    </div>

  </main>

  <!-- Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-brand group transition-colors">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-bold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative overflow-hidden">
          <% if (sessionAuth && sessionAuth.avatarUrl) { %>
            <img src="<%= sessionAuth.avatarUrl %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      Chart.defaults.font.family = 'Inter';
      Chart.defaults.color = '#64748b';

      const chartsData = {
        topEvents: <%- charts.topEventsLabels %>,
        views: <%- charts.topEventsViews %>,
        checkins: <%- charts.topEventsCheckins %>,
        categories: <%- charts.categoryLabels %>,
        categoryVals: <%- charts.categoryValues %>,
        ratings: <%- charts.ratingDistribution %>
      };

      // 1. Performance Leaderboard (Multi-type Chart)
      const perfCtx = document.getElementById('performanceChart');
      if (perfCtx && chartsData.topEvents.length > 0) {
        new Chart(perfCtx, {
          type: 'bar',
          data: {
            labels: chartsData.topEvents.map(l => l.length > 15 ? l.substring(0,12)+'...' : l),
            datasets: [
              {
                label: 'Check-ins',
                data: chartsData.checkins,
                backgroundColor: '#1DA1F2',
                borderRadius: 8,
                barThickness: 12
              },
              {
                label: 'Views',
                data: chartsData.views,
                type: 'line',
                borderColor: '#10b981',
                backgroundColor: '#10b981',
                borderWidth: 2,
                pointRadius: 4,
                pointBackgroundColor: '#fff',
                pointBorderWidth: 2,
                tension: 0.4,
                fill: false
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { display: false }, ticks: { font: { size: 9, weight: '600' } } },
              y: { grid: { borderDash: [4, 4], color: '#f1f5f9' }, ticks: { font: { size: 9 } }, beginAtZero: true }
            }
          }
        });
      }

      // 2. Event Mix (Minimal Doughnut)
      const catCtx = document.getElementById('categoryDoughnut');
      if (catCtx && chartsData.categories.length > 0) {
        new Chart(catCtx, {
          type: 'doughnut',
          data: {
            labels: chartsData.categories,
            datasets: [{
              data: chartsData.categoryVals,
              backgroundColor: ['#1DA1F2', '#6366f1', '#10b981', '#f59e0b', '#f43f5e'],
              borderWidth: 0,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '75%',
            plugins: { 
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return ' ' + context.label + ': ' + context.parsed + ' events';
                  }
                }
              }
            }
          }
        });
      }

      // 3. Sentiment Radar (Custom Radar)
      const radarCtx = document.getElementById('sentimentRadar');
      if (radarCtx && chartsData.ratings.some(r => r > 0)) {
        new Chart(radarCtx, {
          type: 'radar',
          data: {
            labels: ['1★', '2★', '3★', '4★', '5★'],
            datasets: [{
              label: 'Ratings',
              data: chartsData.ratings,
              backgroundColor: 'rgba(29, 161, 242, 0.15)',
              borderColor: '#1DA1F2',
              borderWidth: 2,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#1DA1F2',
              pointBorderWidth: 2,
              pointRadius: 3
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              r: {
                grid: { color: '#f1f5f9', circular: true },
                angleLines: { color: '#f1f5f9' },
                ticks: { display: false, beginAtZero: true },
                pointLabels: { font: { size: 10, weight: '700' }, color: '#64748b' }
              }
            }
          }
        });
      }
    });
  </script>
</body>
</html>
