<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { DEFAULT: '#1DA1F2', light: '#e8f5fd' },
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="min-h-[100dvh] w-full overflow-x-hidden text-textMain relative flex flex-col selection:bg-brand selection:text-white">
  
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0 fixed">
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-brand/10 blur-[100px]"></div>
    <div class="absolute bottom-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-emerald-300/10 blur-[100px]"></div>
  </div>

  <main class="relative z-10 flex flex-col w-full p-4 gap-4 pb-24 max-w-lg mx-auto">
    
    <header class="flex items-center gap-4 pt-2 mb-2">
      <a href="/organizer/dashboard" class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-textMain shadow-sm border border-slate-200">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </a>
      <div>
        <h1 class="text-xl font-bold tracking-tight text-textMain">Analytics</h1>
        <p class="text-xs text-textMuted mt-0.5">Overview of your events' performance</p>
      </div>
    </header>

    <div class="grid grid-cols-2 gap-3 flex-1">
      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative overflow-hidden">
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase relative z-10">Total Events</span>
        <div class="text-4xl font-extrabold text-textMain my-auto tracking-tighter relative z-10">
          <%= totalEvents %>
        </div>
      </div>

      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative overflow-hidden">
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase relative z-10">Active Events</span>
        <div class="text-4xl font-extrabold text-emerald-500 my-auto tracking-tighter relative z-10 border-l-2 border-emerald-500/50 pl-2">
          <%= activeEvents %>
        </div>
      </div>

      <div class="glass-panel p-4 rounded-3xl col-span-2 flex flex-col justify-between relative overflow-hidden">
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase relative z-10">Total Finished Events</span>
        <div class="text-4xl font-extrabold text-blue-500 my-auto tracking-tighter relative z-10 border-l-2 border-blue-500/50 pl-2">
          <%= finishedEvents %>
        </div>
      </div>
      
      <div class="glass-panel p-4 rounded-3xl col-span-2 flex flex-col justify-between relative overflow-hidden min-h-[160px]">
        <div class="absolute -right-4 -bottom-4 w-32 h-32 bg-brand/10 rounded-full blur-[20px]"></div>
        <div class="flex justify-between items-center relative z-10 w-full">
          <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase">Engagement Overview</span>
          <select class="text-xs bg-white text-textMain border-slate-200 border rounded px-2 py-1 outline-none">
            <option>This Month</option>
            <option>Last Month</option>
            <option>All Time</option>
          </select>
        </div>
        
        <div class="relative w-full mt-4" style="height: 200px;">
          <canvas id="engagementChart"></canvas>
        </div>
      </div>

      <div class="glass-panel p-4 rounded-3xl col-span-2 flex flex-col justify-between relative overflow-hidden">
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase mb-3 relative z-10">Popular Tags Overview</span>
        <div class="relative w-full flex justify-center" style="height: 180px;">
          <canvas id="categoryChart"></canvas>
        </div>
      </div>
    </div>

  </main>

  

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      // Engagement Line Chart
      const ctx1 = document.getElementById('engagementChart').getContext('2d');
      new Chart(ctx1, {
        type: 'line',
        data: {
          labels: ['1st', '2nd', '3rd', '4th'],
          datasets: [{
            label: 'Attendees',
            data: [12, 19, 15, 25],
            borderColor: '#1DA1F2',
            backgroundColor: 'rgba(29, 161, 242, 0.2)',
            tension: 0.4,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false } },
            y: { grid: { borderDash: [4, 4] }, beginAtZero: true }
          }
        }
      });

      // Category Doughnut Chart (Spiral)
      const tagLabels = <%- tagLabels %>;
      const tagData = <%- tagData %>;
      
      const ctx2 = document.getElementById('categoryChart').getContext('2d');
      new Chart(ctx2, {
        type: 'doughnut',
        data: {
          labels: tagLabels.length ? tagLabels : ['No Tags'],
          datasets: [{
            data: tagData.length ? tagData : [100],
            backgroundColor: tagLabels.length ? [
              '#1DA1F2', '#34d399', '#fbbf24', '#f87171', '#818cf8', 
              '#a78bfa', '#f472b6', '#2dd4bf', '#fb923c', '#60a5fa'
            ] : ['#e2e8f0'],
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '70%',
          plugins: {
            legend: { position: 'right', labels: { boxWidth: 10, font: { size: 10 } } }
          }
        }
      });
    });
  </script>
<!-- 5. Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-bold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-brand group transition-colors">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform ">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative overflow-hidden">
          <% if (sessionAuth && sessionAuth.avatarUrl) { %>
            <img src="<%= sessionAuth.avatarUrl %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>
</body>
</html>
