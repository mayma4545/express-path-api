<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Notifications - Organizer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#e8f5fd', DEFAULT: '#1DA1F2', dark: '#1a8fd8' },
            bgWhite: '#FFFFFF',
            bgLight: '#f4f8fd',
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] },
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; -webkit-tap-highlight-color: transparent; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="text-textMain pb-20 overflow-x-hidden bg-[#f4f8fd]">

  <!-- Top Nav -->
  <div class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-gray-100 flex items-center px-4 h-14">
    <a href="/organizer/profile" class="p-2 -ml-2 text-gray-500 hover:text-brand transition-colors rounded-full hover:bg-gray-50">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
    <h1 class="mx-auto text-[15px] font-bold text-gray-900 pr-5">Notifications</h1>
  </div>

  <main class="max-w-md mx-auto p-4 sm:p-6 pb-24">
    <div class="glass-panel p-6 rounded-3xl">
      <h2 class="text-xl font-extrabold mb-1">Preferences</h2>
      <p class="text-xs text-textMuted mb-6">Manage how you receive alerts and updates.</p>

      <form action="/organizer/notifications/update" method="POST" class="space-y-4">
        
        <!-- Email Notifications -->
        <label class="flex items-center justify-between p-4 bg-gray-50 border border-gray-200 rounded-xl cursor-pointer hover:bg-white transition-colors">
          <div>
            <p class="text-sm font-semibold text-gray-900">Email Notifications</p>
            <p class="text-[11px] text-gray-500 mt-0.5">Receive an email when attendees RSVP.</p>
          </div>
          <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
            <input type="checkbox" name="email_notif" id="email_notif" checked class="peer sr-only"/>
            <div class="block bg-gray-300 w-10 h-6 rounded-full peer-checked:bg-brand transition-all"></div>
            <div class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform peer-checked:translate-x-4 shadow-sm"></div>
          </div>
        </label>

        <!-- Push Notifications -->
        <label class="flex items-center justify-between p-4 bg-gray-50 border border-gray-200 rounded-xl cursor-pointer hover:bg-white transition-colors">
          <div>
            <p class="text-sm font-semibold text-gray-900">Push Notifications</p>
            <p class="text-[11px] text-gray-500 mt-0.5">Get notified for messages and updates.</p>
          </div>
          <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
            <input type="checkbox" name="push_notif" id="push_notif" class="peer sr-only"/>
            <div class="block bg-gray-300 w-10 h-6 rounded-full peer-checked:bg-brand transition-all"></div>
            <div class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform peer-checked:translate-x-4 shadow-sm"></div>
          </div>
        </label>

        <!-- Submit Button -->
        <button type="submit" class="w-full mt-6 py-3 bg-brand text-white font-bold text-sm rounded-xl shadow-lg shadow-brand/30 hover:bg-brand-dark transition-all transform active:scale-[0.98]">
          Save Preferences
        </button>

      </form>
    </div>
  </main>
  
  <!-- Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain group transition-colors">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted group transition-colors">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-brand transition-colors relative group">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors relative overflow-hidden">
          <% if (sessionAuth && sessionAuth.avatarUrl) { %>
            <img src="<%= sessionAuth.avatarUrl %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>
</body>
</html>