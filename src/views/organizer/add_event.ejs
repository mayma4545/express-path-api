<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { DEFAULT: '#1DA1F2', light: '#e8f5fd' },
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="min-h-[100dvh] w-full overflow-x-hidden text-textMain relative flex flex-col selection:bg-brand selection:text-white">
  
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0 fixed">
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-brand/10 blur-[100px]"></div>
    <div class="absolute bottom-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-blue-300/10 blur-[100px]"></div>
  </div>

  <main class="relative z-10 flex flex-col w-full p-4 gap-4 pb-24 max-w-lg mx-auto">
    
    <%- include('../partials/organizer_header', { 
      headerTitle: typeof event !== 'undefined' && event ? 'Edit Event' : 'Create Event', 
      headerSubtitle: 'Fill in the event details',
      backUrl: typeof event !== 'undefined' && event ? '/organizer/events/' + event.id : '/organizer/dashboard',
      showPulse: false
    }) %>

    <div class="glass-panel p-5 rounded-3xl flex flex-col gap-4">
      <form action="<%= typeof event !== 'undefined' && event ? '/organizer/events/' + event.id + '/update' : '/organizer/events/add' %>" method="POST" enctype="multipart/form-data" class="flex flex-col gap-4">
        
        <div>
          <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Event Name</label>
          <input type="text" name="title" required value="<%= typeof event !== 'undefined' && event ? event.title : '' %>" placeholder="e.g. Annual Tech Symposium" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm placeholder:text-slate-400">
        </div>

        <div>
          <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Description</label>
          <textarea name="description" rows="3" placeholder="What's this event about?" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm placeholder:text-slate-400 resize-none"><%= typeof event !== 'undefined' && event ? event.description : '' %></textarea>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Recurrence Pattern</label>
            <select name="recurrence_type" id="recurrence-type" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm cursor-pointer">
              <option value="none">Once Only</option>
              <option value="once">Once Only</option>
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly</option>
            </select>
          </div>
          <div id="recurrence-end-container" style="display: none;">
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Repeat Until <span class="text-[10px] text-textMuted">(end date)</span></label>
            <input type="date" name="recurrence_end_date" id="recurrence-end-date" value="<%= typeof event !== 'undefined' && event ? event.recurrence_end_date : '' %>" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
            <p class="text-[10px] text-textMuted mt-1">When this recurring event should stop</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3" id="date-inputs-container">
          <div id="start-date-container">
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5" id="start-date-label">Start Date</label>
            <input type="date" name="event_date" id="event-start-date" value="<%= typeof event !== 'undefined' && event && event.event_date ? event.event_date : '' %>" required class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
            
            <select name="day_of_week" id="day-of-week-select" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm hidden">
              <option value="1">Monday</option>
              <option value="2">Tuesday</option>
              <option value="3">Wednesday</option>
              <option value="4">Thursday</option>
              <option value="5">Friday</option>
              <option value="6">Saturday</option>
              <option value="0">Sunday</option>
            </select>
            
            <input type="number" name="day_of_month" id="day-of-month-input" min="1" max="31" placeholder="Day (1-31)" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm hidden">
          </div>
          <div id="event-end-date-container">
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">End Date <span class="text-[10px] text-textMuted">(if multi-day)</span></label>
            <input type="date" name="end_date" id="event-end-date" value="<%= typeof event !== 'undefined' && event && event.end_date ? event.end_date : '' %>" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
            <p class="text-[10px] text-textMuted mt-1">Leave blank for single-day event</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Start Time</label>
            <input type="time" name="start_time" value="<%= typeof event !== 'undefined' && event ? event.start_time : '' %>" required class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
          </div>
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">End Time</label>
            <input type="time" name="end_time" value="<%= typeof event !== 'undefined' && event ? event.end_time : '' %>" required class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Category</label>
            <select name="category_id" id="category-id" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
              <option value="">Select Category</option>
              <% categories.forEach(function(category) { %>
                <option value="<%= category.id %>"><%= category.name %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div class="w-full">
          <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-2">Tags (Select multiple)</label>
          <div class="grid grid-cols-3 sm:grid-cols-4 gap-2">
            <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Sports" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Sports</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Music" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Music</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Technology" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Tech</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Academic" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Academic</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Arts" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Arts</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Food" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Food</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Workshop" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Workshop</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Social" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Social</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Career" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Career</span>
              </label>
              <label class="flex items-center justify-center bg-white border border-slate-200 rounded-lg px-2 py-2 cursor-pointer hover:border-brand transition group">
                <input type="checkbox" name="tags" value="Health" class="peer hidden">
                <span class="text-xs font-semibold text-slate-500 peer-checked:text-brand peer-checked:bg-brand/10 w-full h-full text-center rounded">Health</span>
              </label>
            </div>
          </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Capacity</label>
            <input type="number" name="capacity" value="<%= typeof event !== 'undefined' && event ? event.capacity : '' %>" placeholder="e.g. 100" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
          </div>
          <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Event Poster</label>
            <input type="file" name="image" accept="image/*" class="w-full px-4 py-[9px] bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm">
          </div>
        </div>

        <div>
            <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Venue / Address</label>
            <div class="relative relative-venue-container mb-3">
              <input type="text" id="venue-input" name="venue" required value="<%= typeof event !== 'undefined' && event ? event.venue : '' %>" placeholder="Type an address to search..." autocomplete="off" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand/50 text-sm placeholder:text-slate-400">
              <div id="address-suggestions" class="absolute left-0 right-0 top-full mt-1 bg-white border border-slate-200 shadow-xl rounded-xl z-[2000] hidden overflow-hidden max-h-60 overflow-y-auto"></div>
            </div>

          <label class="block text-xs font-bold text-textMuted uppercase tracking-wider mb-1.5">Pin Location on Map</label>
          <div id="map-container" class="relative w-full h-48 rounded-xl border border-slate-200 z-10 overflow-hidden transition-all duration-300">
            <div id="map" class="w-full h-full"></div>
            <button type="button" id="fullscreen-toggle" class="absolute top-2 right-2 bg-white text-gray-700 p-1.5 rounded shadow z-[2000] hover:bg-gray-100 cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
            </button>
            <button type="button" id="close-fullscreen" class="hidden absolute top-4 left-4 bg-brand text-white px-4 py-2 rounded-xl font-bold shadow z-[2000]">
              Done
            </button>
          </div>
          <p class="text-[10px] text-textMuted mt-1">Tap/click on the map to pin the event location. Click the expand icon to view larger.</p>
          <input type="hidden" name="latitude" id="latitude" value="<%= typeof event !== 'undefined' && event ? event.latitude : '' %>">
          <input type="hidden" name="longitude" id="longitude" value="<%= typeof event !== 'undefined' && event ? event.longitude : '' %>">
        </div>

        <button type="submit" class="w-full mt-2 bg-brand text-white font-bold py-3.5 rounded-xl shadow-[0_8px_20px_rgba(29,161,242,0.3)] hover:bg-blue-500 active:scale-[0.98] transition-all">
          <%= typeof event !== 'undefined' && event ? 'Update Event' : 'Create Event' %>
        </button>
      </form>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Recurrence UI Logic
      const recurrenceTypeSelect = document.getElementById('recurrence-type');
      const recurrenceEndContainer = document.getElementById('recurrence-end-container');
      const recurrenceEndDate = document.getElementById('recurrence-end-date');
      
      const dateInputsContainer = document.getElementById('date-inputs-container');
      const startDateContainer = document.getElementById('start-date-container');
      const startDateLabel = document.getElementById('start-date-label');
      const eventStartDate = document.getElementById('event-start-date');
      const eventEndDateContainer = document.getElementById('event-end-date-container');
      const dayOfWeekSelect = document.getElementById('day-of-week-select');
      const dayOfMonthInput = document.getElementById('day-of-month-input');
      
      function updateRecurrenceVisibility() {
        const type = recurrenceTypeSelect.value;
        
        // Reset visibility
        eventStartDate.classList.remove('hidden');
        dayOfWeekSelect.classList.add('hidden');
        dayOfMonthInput.classList.add('hidden');
        eventEndDateContainer.style.display = 'block';
        startDateContainer.style.display = 'block';
        
        // Reset required
        eventStartDate.removeAttribute('required');
        dayOfWeekSelect.removeAttribute('required');
        dayOfMonthInput.removeAttribute('required');

        if (type === 'once' || type === 'none') {
          recurrenceEndContainer.style.display = 'none';
          recurrenceEndDate.removeAttribute('required');
          
          startDateLabel.textContent = 'Start Date';
          eventStartDate.setAttribute('required', 'required');
        } else {
          recurrenceEndContainer.style.display = 'block';
          recurrenceEndDate.setAttribute('required', 'required');
          
          // Hide end date for recurring
          eventEndDateContainer.style.display = 'none';
          
          if (type === 'daily') {
            startDateContainer.style.display = 'none';
          } else if (type === 'weekly') {
            startDateLabel.textContent = 'Day of Week';
            eventStartDate.classList.add('hidden');
            dayOfWeekSelect.classList.remove('hidden');
            dayOfWeekSelect.setAttribute('required', 'required');
          } else if (type === 'monthly') {
            startDateLabel.textContent = 'Day of Month';
            eventStartDate.classList.add('hidden');
            dayOfMonthInput.classList.remove('hidden');
            dayOfMonthInput.setAttribute('required', 'required');
          }
        }
      }
      
      recurrenceTypeSelect.addEventListener('change', updateRecurrenceVisibility);

      // 2. Data Population (if editing)
      <% if (typeof event !== 'undefined' && event) { %>
        const categoryId = "<%= event.category_id %>";
        if (categoryId) document.getElementById('category-id').value = categoryId;

        const recType = "<%= event.recurrence_type %>";
        if (recType) recurrenceTypeSelect.value = recType;

        const tagsStr = "<%= event.tags || '' %>";
        if (tagsStr) {
          const eventTags = tagsStr.split(',').map(t => t.trim());
          document.querySelectorAll('input[name="tags"]').forEach(input => {
            if (eventTags.includes(input.value)) input.checked = true;
          });
        }
      <% } %>

      // Initialize Recurrence UI
      updateRecurrenceVisibility();

      // 3. Map Initialization
      const savedLat = document.getElementById('latitude').value;
      const savedLng = document.getElementById('longitude').value;
      
      const defaultLat = savedLat ? parseFloat(savedLat) : 12.3700;
      const defaultLng = savedLng ? parseFloat(savedLng) : 123.6300;

      const map = L.map('map', { zoomControl: false, attributionControl: false }).setView([defaultLat, defaultLng], savedLat ? 17 : 14);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { maxZoom: 19 }).addTo(map);
      L.control.zoom({ position: 'bottomright' }).addTo(map);

      const evIcon = L.divIcon({
        className: '',
        html: `<div style="display:flex;flex-direction:column;align-items:center;gap:0;">
          <div style="width:28px;height:28px;background:#1DA1F2;border:3px solid white;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 6px 16px rgba(29,161,242,0.5);"></div>
          <div style="width:4px;height:8px;background:#1DA1F2;border-radius:2px;margin-top:-2px;"></div>
        </div>`,
        iconSize: [28, 38],
        iconAnchor: [14, 38],
      });

      let marker = null;
      if (savedLat && savedLng) {
        marker = L.marker([defaultLat, defaultLng], { icon: evIcon }).addTo(map);
      }

      map.on('click', (e) => {
        const { lat, lng } = e.latlng;
        if (marker) marker.setLatLng(e.latlng);
        else marker = L.marker(e.latlng, { icon: evIcon }).addTo(map);

        document.getElementById('latitude').value = lat;
        document.getElementById('longitude').value = lng;

        fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1`)
          .then(res => res.json())
          .then(data => { if (data && data.display_name) document.getElementById('venue-input').value = data.display_name; })
          .catch(console.error);
      });

      // 4. Map UI (Fullscreen & Autocomplete)
      const mapContainer = document.getElementById('map-container');
      const fullscreenBtn = document.getElementById('fullscreen-toggle');
      const closeFullscreenBtn = document.getElementById('close-fullscreen');
      const bottomNav = document.querySelector('div.fixed.bottom-0');

      function toggleFullscreen(e) {
        if(e) { e.preventDefault(); e.stopPropagation(); }
        const isFullscreen = mapContainer.classList.contains('fixed');
        if (!isFullscreen) {
          mapContainer.classList.remove('relative', 'h-48', 'rounded-xl');
          mapContainer.classList.add('fixed', 'inset-0', 'h-[100dvh]', 'w-full', 'z-[1000]', 'rounded-none');
          fullscreenBtn.classList.add('hidden');
          closeFullscreenBtn.classList.remove('hidden');
          if (bottomNav) bottomNav.classList.add('hidden');
        } else {
          mapContainer.classList.remove('fixed', 'inset-0', 'h-[100dvh]', 'w-full', 'z-[1000]', 'rounded-none');
          mapContainer.classList.add('relative', 'h-48', 'rounded-xl');
          fullscreenBtn.classList.remove('hidden');
          closeFullscreenBtn.classList.add('hidden');
          if (bottomNav) bottomNav.classList.remove('hidden');
        }
        setTimeout(() => map.invalidateSize(), 100);
      }
      fullscreenBtn.addEventListener('click', toggleFullscreen);
      closeFullscreenBtn.addEventListener('click', toggleFullscreen);

      const venueInput = document.getElementById('venue-input');
      const suggestionsBox = document.getElementById('address-suggestions');
      let debounceTimeout;

      venueInput.addEventListener('input', function() {
        clearTimeout(debounceTimeout);
        const query = this.value.trim();
        if (query.length < 3) return suggestionsBox.classList.add('hidden');
        
        debounceTimeout = setTimeout(() => {
          fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&addressdetails=1&limit=5&countrycodes=ph`, {
            headers: { 'Accept-Language': 'en', 'User-Agent': 'ExpressPathAPI/1.0' }
          })
          .then(res => res.json())
          .then(data => {
            suggestionsBox.innerHTML = '';
            if (data.length > 0) {
              data.forEach(place => {
                const item = document.createElement('div');
                item.className = 'px-4 py-3 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0 transition-colors text-sm';
                item.innerHTML = `<div class="font-semibold text-textMain truncate">${place.display_name.split(',')[0]}</div><div class="text-[10px] text-textMuted mt-0.5 truncate">${place.display_name}</div>`;
                item.addEventListener('click', () => {
                  venueInput.value = place.display_name;
                  document.getElementById('latitude').value = place.lat;
                  document.getElementById('longitude').value = place.lon;
                  const newLatLng = [place.lat, place.lon];
                  map.setView(newLatLng, 17);
                  if (marker) marker.setLatLng(newLatLng);
                  else marker = L.marker(newLatLng, { icon: evIcon }).addTo(map);
                  suggestionsBox.classList.add('hidden');
                });
                suggestionsBox.appendChild(item);
              });
              suggestionsBox.classList.remove('hidden');
            } else suggestionsBox.classList.add('hidden');
          })
          .catch(console.error);
        }, 500);
      });

      document.addEventListener('click', (e) => {
        if (!venueInput.contains(e.target) && !suggestionsBox.contains(e.target)) suggestionsBox.classList.add('hidden');
      });
    });
  </script>
<!-- 5. Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
