<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { light: '#E9E4FF', DEFAULT: '#7C43FE', dark: '#5A26ED' },
            textMain: '#111827',
            textMuted: '#6B7280'
          },
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          boxShadow: {
            soft: '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            float: '0 8px 16px -4px rgba(124, 67, 254, 0.35)'
          }
        }
      }
    }
  </script>
</head>
<body class="min-h-screen bg-[#F8F9FE] text-textMain font-sans flex items-center justify-center p-6">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-soft border border-gray-100 p-7">
      <div class="mb-6 text-center">
        <div class="mx-auto mb-3 w-12 h-12 rounded-2xl bg-brand text-white text-xl font-bold flex items-center justify-center shadow-float">O</div>
        <h1 class="text-2xl font-extrabold tracking-tight">Organizer Portal</h1>
        <p class="text-sm text-textMuted mt-1">Sign in with your organizer account.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-2xl flex items-center gap-3 animate-bounce">
          <div class="w-8 h-8 bg-red-100 text-red-500 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <p class="text-xs font-bold text-red-600"><%= error %></p>
        </div>
      <% } %>

      <form action="/organizer/login" method="POST" class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-bold mb-1.5">Email or Username</label>
          <input id="email" name="email" type="text" required class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand" placeholder="email@example.com or admin4545">
        </div>

        <div>
          <label for="password" class="block text-sm font-bold mb-1.5">Password</label>
          <input id="password" name="password" type="password" required class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand" placeholder="Enter password">
        </div>

        <button type="submit" class="w-full rounded-xl bg-brand text-white px-4 py-3 text-sm font-bold shadow-float hover:bg-brand-dark active:scale-[0.99] transition">
          Login
        </button>
      </form>

      <div class="mt-8 text-center pt-4 border-t border-gray-50">
        <p class="text-sm text-textMuted">Don't have an account?</p>
        <a href="/organizer/signup" class="text-sm font-bold text-brand hover:underline mt-1 inline-block">Join as Organizer</a>
      </div>
    </div>
  </div>
</body>
</html>
