<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Organizer Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#e8f5fd', DEFAULT: '#1DA1F2', dark: '#1a8fd8' },
            bgWhite: '#FFFFFF',
            bgLight: '#f4f8fd',
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] },
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f4f8fd; -webkit-tap-highlight-color: transparent; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="text-textMain pb-20 overflow-x-hidden bg-[#f4f8fd]">

  <!-- Main Content Wrapper -->
  <main class="max-w-md mx-auto p-4 sm:p-6 md:py-10">
    <!-- Top Bar -->
    <%- include('../partials/organizer_header', { headerTitle: 'Profile', headerSubtitle: 'Account Settings', backUrl: '/organizer/dashboard', showPulse: false }) %>

    <!-- Profile Header -->
    <div class="glass-panel rounded-3xl p-6 mb-6 flex flex-col items-center">
      <div class="relative group cursor-pointer" onclick="document.getElementById('avatarInput').click()">
        <div class="w-24 h-24 rounded-full bg-brand-light flex items-center justify-center text-brand mb-4 border-4 border-white shadow-sm overflow-hidden relative" id="avatarContainer">
          <% if (organizer.avatar_url) { %>
            <img src="<%= organizer.avatar_url %>" alt="Profile" class="w-full h-full object-cover" id="avatarImg">
          <% } else { %>
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="avatarPlaceholder">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
          <!-- Loading Overlay -->
          <div id="uploadLoading" class="absolute inset-0 bg-black/40 hidden items-center justify-center">
            <div class="w-6 h-6 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
          </div>
        </div>
        <button class="absolute bottom-4 right-0 p-1.5 bg-brand text-white rounded-full border-2 border-white shadow-sm group-hover:scale-110 transition-transform">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
        </button>
      </div>
      <input type="file" id="avatarInput" class="hidden" accept="image/*" onchange="handleAvatarUpload(this)">
      
      <h2 class="text-lg font-bold text-textMain" id="profileName"><%= organizer.name %></h2>
      <p class="text-sm text-textMuted" id="profileEmail"><%= organizer.account.email %></p>
      <span class="mt-2 text-[10px] font-bold text-brand bg-brand-light px-2.5 py-1 rounded-md uppercase tracking-wide">Verified Organizer</span>
    </div>

    <!-- Settings List -->
    <div class="glass-panel rounded-3xl overflow-hidden mb-6">
      
      <!-- Account Details -->
      <a href="/organizer/account" class="flex items-center justify-between p-4 border-b border-gray-100 hover:bg-gray-50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-textMuted">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-textMain">Account Details</p>
            <p class="text-[11px] text-textMuted">Manage your personal info</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>

      <!-- Notifications -->
      <a href="/organizer/notifications" class="flex items-center justify-between p-4 border-b border-gray-100 hover:bg-gray-50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-textMuted">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-textMain">Notifications</p>
            <p class="text-[11px] text-textMuted">Alert preferences</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>

      <!-- Security -->
      <a href="/organizer/security" class="flex items-center justify-between p-4 hover:bg-gray-50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-textMuted">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-textMain">Security</p>
            <p class="text-[11px] text-textMuted">Password and authentication</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>

    </div>

    <!-- Logout -->
    <form action="/organizer/logout" method="POST" class="w-full">
      <button type="submit" class="block w-full py-3.5 bg-white border border-red-100 text-red-500 font-bold text-sm text-center rounded-2xl shadow-sm hover:bg-red-50 hover:text-red-600 transition-colors cursor-pointer">
        Log Out
      </button>
    </form>
  </main>

  <!-- Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain group transition-colors">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform ">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted group transition-colors">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-brand transition-colors relative group">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors relative">
          <svg class="w-6 h-6" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>
  
  <script>
    async function handleAvatarUpload(input) {
      const file = input.files[0];
      if (!file) return;

      // Show loading
      const loading = document.getElementById('uploadLoading');
      loading.classList.remove('hidden');
      loading.classList.add('flex');

      const formData = new FormData();
      formData.append('avatar', file);

      try {
        const response = await fetch('/organizer/avatar/update', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();
        if (result.success) {
          // Update the image on the page
          const container = document.getElementById('avatarContainer');
          let img = document.getElementById('avatarImg');
          
          if (!img) {
            // Replace placeholder SVG with img
            const placeholder = document.getElementById('avatarPlaceholder');
            if (placeholder) placeholder.remove();
            
            img = document.createElement('img');
            img.id = 'avatarImg';
            img.alt = 'Profile';
            img.className = 'w-full h-full object-cover';
            container.appendChild(img);
          }
          
          img.src = result.avatar_url;
        } else {
          alert('Failed to upload: ' + result.message);
        }
      } catch (err) {
        console.error('Upload error:', err);
        alert('An error occurred during upload.');
      } finally {
        loading.classList.add('hidden');
        loading.classList.remove('flex');
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('updated') === 'true') {
        // Optional: show a toast or alert
      }
    });
  </script>
</body>
</html>