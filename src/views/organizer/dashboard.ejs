<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Event Command Center</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { DEFAULT: '#1DA1F2', light: '#e8f5fd' },
            textMain: '#0f172a',
            textMuted: '#64748b'
          }, 
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        } 
      }
    }
  </script>
  <style>
    body { 
      font-family: 'Inter', sans-serif; 
      background-color: #f4f8fd;
      -webkit-tap-highlight-color: transparent;
      overscroll-behavior-y: none;
    }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .glass-panel {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 1);
      box-shadow: 0 4px 15px -5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="min-h-screen w-full overflow-x-hidden pb-20 text-textMain relative flex flex-col selection:bg-brand selection:text-white">
  
  <!-- Ambient Background Glow -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-brand/10 blur-[100px]"></div>
    <div class="absolute bottom-[20%] -right-[10%] w-[60%] h-[60%] rounded-full bg-blue-300/10 blur-[100px]"></div>
  </div>

  <main class="relative z-10 flex flex-col h-full w-full p-4 gap-4 pb-24 max-w-lg mx-auto">
    
    <!-- 1. Header -->
    <%- include('../partials/organizer_header', { headerTitle: 'Command Center', headerSubtitle: 'Ongoing View' }) %>

    <!-- 2. Ongoing Events Zone -->
    <% if (activeEventsList && activeEventsList.length > 0) { %>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-4 no-scrollbar pb-2">
        <% activeEventsList.forEach(function(event, index) { %>
          <div class="glass-panel p-4 rounded-3xl flex flex-col gap-2 w-full shrink-0 snap-center relative overflow-hidden" style="min-width: 100%;">
            <div class="absolute right-0 top-0 w-32 h-32 bg-brand/10 rounded-full blur-[40px] pointer-events-none"></div>
            <div class="flex justify-between items-start relative z-10">
              <span class="text-[10px] font-bold text-brand uppercase tracking-widest flex items-center gap-1.5 px-2 py-1 bg-brand-light rounded-md">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                Ongoing Event
              </span>
              <span class="text-[10px] font-mono bg-slate-100 px-2 py-1 rounded text-textMuted border border-slate-200">EVT-<%= String(event.id).padStart(3, '0') %></span>
            </div>
            <h2 class="text-2xl font-extrabold text-textMain leading-tight mt-1 relative z-10 truncate"><%= event.title %></h2>
            <div class="mt-2 bg-slate-50/80 rounded-2xl p-3 flex justify-between items-center border border-slate-200 relative z-10 shadow-sm">
              <div class="flex flex-col">
                <span class="text-[10px] text-textMuted uppercase tracking-wider font-bold">Location</span>
                <span class="text-sm text-slate-700 font-semibold mt-0.5 truncate max-w-[150px]"><%= event.venue %></span>
              </div>
              <span class="text-lg font-mono font-bold text-brand tracking-tight">Active</span>
            </div>
          </div>
        <% }) %>
      </div>
      
      <% if (activeEventsList.length > 1) { %>
        <div class="flex justify-center gap-1.5 mt-[-8px] z-10">
          <% activeEventsList.forEach(function(_, i) { %>
            <div class="w-1.5 h-1.5 rounded-full <%= i === 0 ? 'bg-brand' : 'bg-slate-300' %>"></div>
          <% }) %>
        </div>
      <% } %>
    <% } else { %>
      <div class="glass-panel p-4 rounded-3xl flex flex-col gap-2 shrink-0 relative overflow-hidden items-center justify-center min-h-[140px]">
        <span class="text-textMuted text-sm font-medium">No ongoing events currently running.</span>
      </div>
    <% } %>

    <!-- Activity Feed -->
    <div class="glass-panel p-4 rounded-3xl shrink-0 flex flex-col gap-3 mt-2 relative overflow-hidden">
      <div class="flex justify-between items-center relative z-10">
        <span class="text-[11px] font-bold text-textMuted uppercase tracking-wider">Recent Activity Feed</span>
        <span class="flex items-center gap-1 text-[10px] text-brand font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
          Syncing
        </span>
      </div>
      <div class="flex flex-col gap-2.5 relative z-10">
        <% if (activityFeed && activityFeed.length > 0) { %>
          <% activityFeed.forEach(function(activity) { %>
            <% 
              let redirectUrl = '#';
              if (activity.eventId) {
                redirectUrl = `/organizer/events/${activity.eventId}`;
                if (activity.type === 'comment' || activity.type === 'reply') {
                  redirectUrl += '?tab=about&action=scrollToComments';
                }
                if (activity.id) {
                    redirectUrl += (redirectUrl.includes('?') ? '&' : '?') + 'read_notif=' + activity.id;
                }
              }
            %>
            <a href="<%= redirectUrl %>" class="flex items-start gap-3 hover:bg-slate-50 p-1.5 -mx-1.5 rounded-xl transition-colors relative z-20" onclick="<% if (activity.id) { %>event.preventDefault(); window.markAsRead('<%= activity.id %>', this.href);<% } %>">
              <div class="w-2 h-2 rounded-full <%= activity.color %> mt-1.5 shrink-0 shadow-[0_0_5px_rgba(16,185,129,0.3)]"></div>
              <div class="flex flex-col flex-1 overflow-hidden">
                <span class="text-sm text-textMain font-semibold truncate"><%= activity.eventName %>: <%= activity.message %></span>
                <span class="text-[10px] text-textMuted font-mono"><%= activity.time %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Metric Grid -->
    <div class="grid grid-cols-2 gap-3 flex-1 min-h-0">
      
      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative group overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-brand/10 rounded-full blur-[20px]"></div>
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase relative z-10">Recent Visits</span>
        <div class="text-3xl font-extrabold text-textMain my-auto tracking-tighter flex items-baseline gap-1 relative z-10">
          <%= dashboardMetrics.entryVelocity || 0 %> <span class="text-sm text-textMuted font-medium">/ 1H</span>
        </div>
        <div class="flex items-center justify-between mt-2 pt-2 border-t border-slate-100 relative z-10">
          <div class="text-[10px] text-brand font-bold tracking-wide"><%= dashboardMetrics.entryVelocity > 20 ? 'High Traffic' : 'Normal Traffic' %></div>
          <div class="text-[10px] text-brand font-medium bg-brand-light px-2 py-0.5 rounded">All Gates</div>
        </div>
      </div>

      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-16 h-16 bg-brand/10 rounded-full blur-[20px]"></div>
        <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase relative z-10">Venue Navigation Hits</span>
        <div class="text-4xl font-extrabold text-brand my-auto tracking-tighter relative z-10 border-l-2 border-brand/50 pl-2"><%= dashboardMetrics.livePathHits || 0 %></div>
        <div class="flex items-center justify-between mt-1 text-[10px] text-textMuted relative z-10 bg-slate-50 p-1.5 rounded-lg border border-slate-100 shadow-sm">
          <span class="truncate pr-1 font-medium">Gate &rarr; Venue</span>
          <span class="text-brand font-bold shrink-0"><%= dashboardMetrics.livePathHits > 100 ? 'Congested' : 'Clear' %></span>
        </div>
      </div>

      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-brand/10 rounded-full blur-[20px]"></div>
        <div class="flex justify-between items-center mb-1 relative z-10">
          <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase">RSVP vs Actual</span>
          <div class="w-1.5 h-1.5 rounded-full bg-brand"></div>
        </div>
        <div class="text-2xl font-extrabold text-textMain my-auto flex items-baseline gap-1.5 relative z-10">
          <span class="text-brand"><%= dashboardMetrics.totalActual || '0' %></span>
          <span class="text-sm font-medium text-textMuted">/<%= dashboardMetrics.totalRSVP || '0' %></span>
        </div>
        <% 
            const percent = dashboardMetrics.totalRSVP > 0 ? Math.min(100, Math.floor((dashboardMetrics.totalActual / dashboardMetrics.totalRSVP) * 100)) : 0;
            const missing = Math.max(0, dashboardMetrics.totalRSVP - dashboardMetrics.totalActual);
        %>
        <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden mt-2 mb-1.5 border border-slate-200 relative z-10">
          <div class="bg-brand h-full rounded-full relative" style="width: <%= percent %>%"></div>
        </div>
        <div class="text-[10px] text-textMuted font-medium relative z-10">Gap: <%= missing %> missing</div>
      </div>

      <div class="glass-panel p-4 rounded-3xl flex flex-col justify-between relative overflow-hidden">
        <div class="absolute -left-4 -bottom-4 w-20 h-20 bg-brand/10 rounded-full blur-[20px]"></div>
        <div class="flex justify-between items-center relative z-10">
          <span class="text-[11px] text-textMuted font-bold tracking-wide uppercase">Unread Notifications</span>
          <span class="flex h-2 w-2 relative">
            <span class="<%= dashboardMetrics.alerts > 0 ? 'animate-ping' : '' %> absolute inline-flex h-full w-full rounded-full bg-brand opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand"></span>
          </span>
        </div>
        <div class="flex items-end gap-2 my-auto relative z-10 pt-1">
            <div class="text-4xl font-extrabold text-brand tracking-tighter drop-shadow-[0_4px_8px_rgba(29,161,242,0.2)]">
                <%= dashboardMetrics.alerts || 0 %>
            </div>
            <div class="text-xs text-brand/80 mb-1.5 font-bold uppercase tracking-wider"><%= dashboardMetrics.alerts === 1 ? 'Alert' : 'Alerts' %></div>
        </div>
        <div class="text-[10px] text-slate-700 font-medium mt-1 relative z-10 border-l-2 border-brand/50 pl-1.5">
          <%= dashboardMetrics.alerts > 0 ? 'Check Activity Feed' : 'All clear' %>
        </div>
      </div>

    </div>

  </main>

  <!-- Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-brand group transition-colors">
        <div class="p-1.5 rounded-full bg-brand-light transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-bold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform ">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative overflow-hidden">
          <% if (organizer.avatar_url) { %>
            <img src="<%= organizer.avatar_url %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>

  <!-- Success Login Popup -->
  <div id="login-success-popup" class="fixed top-6 left-1/2 -translate-x-1/2 z-[1000] pointer-events-none opacity-0 translate-y-[-20px] transition-all duration-500">
    <div class="bg-white/90 backdrop-blur-xl border border-emerald-100 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.15)] rounded-3xl p-4 flex items-center gap-4 min-w-[300px]">
      <div class="w-12 h-12 bg-emerald-500 text-white rounded-2xl flex items-center justify-center shadow-[0_8px_15px_-3px_rgba(16,185,129,0.4)]">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <div>
        <h4 class="text-sm font-extrabold text-slate-900">Welcome Back!</h4>
        <p class="text-[11px] text-slate-500 font-medium">Successfully logged in to your portal.</p>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('loginSuccess') === 'true') {
        const popup = document.getElementById('login-success-popup');
        // Show popup
        setTimeout(() => {
          popup.classList.remove('opacity-0', 'translate-y-[-20px]');
          popup.classList.add('opacity-100', 'translate-y-0');
        }, 300);

        // Hide popup after 4 seconds
        setTimeout(() => {
          popup.classList.remove('opacity-100', 'translate-y-0');
          popup.classList.add('opacity-0', 'translate-y-[-20px]');
        }, 4000);

        // Clean up URL without refreshing
        const newUrl = window.location.pathname;
        window.history.replaceState({}, document.title, newUrl);
      }
    });
  </script>
</body>
</html>
