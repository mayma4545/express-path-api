<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Event Details — Organizer</title>
  <meta name="description" content="View full event details." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { brand: '#1DA1F2', 'brand-dark': '#0d8de0', 'brand-light': '#e8f5fe' },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body { font-family: 'Inter', sans-serif; overscroll-behavior-y: none; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp .4s ease forwards; }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
    .slide-in { animation: slideInRight .35s cubic-bezier(.4, 0, .2, 1) forwards; }
    .btn-ripple { position: relative; overflow: hidden; }
    .btn-ripple::after { content: ''; position: absolute; inset: 0; background: white; opacity: 0; transition: opacity .3s; border-radius: inherit; }
    .btn-ripple:active::after { opacity: .25; }
    .tab-btn { transition: all .2s; }
    .tab-btn.active { color: #1DA1F2; border-bottom: 2px solid #1DA1F2; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
  </style>
</head>
<body class="bg-white min-h-screen mb-[4rem] max-w-md mx-auto overflow-x-hidden relative" style="padding-bottom: 90px;">

  <!-- Floating Nav Bar -->
  <div class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-md z-40 px-4 pt-2 bg-white/80 backdrop-blur-md border-b border-gray-100" style="max-width:448px;">
    <%- include('../partials/organizer_header', { 
      headerTitle: 'Event Details', 
      headerSubtitle: 'Real-time Monitoring',
      backUrl: '/organizer/dashboard',
      showPulse: true,
      customActions: `
        <a href="/organizer/events/${event.id}/edit" class="bg-white/90 border border-slate-200 shadow-sm rounded-full p-2.5 text-brand active:scale-95 transition-all flex items-center justify-center" title="Edit Event">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </a>
        <button onclick="confirmDelete()" class="bg-white/90 border border-slate-200 shadow-sm rounded-full p-2.5 text-red-500 active:scale-95 transition-all flex items-center justify-center" title="Delete Event">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </button>
      `
    }) %>
  </div>

  <!-- Hero Image -->
  <div class="relative" style="height:300px;">
    <img id="detail-img" src="" onerror="this.src='https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800'; this.onerror=null;" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 px-5 pb-5 flex items-end justify-between">
      <div>
        <span id="detail-category" class="text-xs font-bold uppercase tracking-widest text-white/80 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/30 mb-2 inline-block"></span>
        <h1 id="detail-name" class="text-2xl font-extrabold text-white leading-tight mt-1 drop-shadow-lg"></h1>
      </div>
      <div class="flex flex-col items-center bg-white/20 backdrop-blur-sm rounded-2xl px-3 py-2 border border-white/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <p id="detail-visits" class="text-sm font-bold text-white leading-none"></p>
        <p class="text-[10px] text-white/70 font-medium">visits</p>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="fade-up px-5 pt-6 grid grid-cols-2 gap-4">
    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-blue-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
        </div>
        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Navigation</span>
      </div>
      <p id="detail-navs" class="text-2xl font-black text-gray-900">0</p>
      <p class="text-[10px] text-gray-500 font-medium mt-0.5">Used Map View</p>
    </div>
    
    <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
      <div class="flex items-center gap-2 mb-1">
        <div class="w-8 h-8 rounded-full bg-pink-50 flex items-center justify-center text-pink-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
        </div>
        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Bookmarks</span>
      </div>
      <p id="detail-bookmarks" class="text-2xl font-black text-gray-900">0</p>
      <p class="text-[10px] text-gray-500 font-medium mt-0.5">Saved by Users</p>
    </div>
  </div>

  <!-- Meta pills -->
  <div class="fade-up px-5 pt-5 flex flex-wrap gap-2">
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-brand-light text-brand px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span id="detail-date"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
      </svg>
      <span id="detail-time"></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-green-50 text-green-600 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
      </svg>
      <span id="detail-venue"></span>
    </span>
  </div>

  <!-- Tabs -->
  <div class="slide-in mt-5 px-5">
    <div class="flex border-b border-gray-200 mb-4 overflow-x-auto no-scrollbar">
      <button id="tab-about" class="tab-btn active flex-1 py-2.5 text-sm font-semibold text-center whitespace-nowrap px-4" onclick="switchTab('about')">About</button>
      <button id="tab-gallery" class="tab-btn flex-1 py-2.5 text-sm font-semibold text-gray-400 text-center whitespace-nowrap px-4" onclick="switchTab('gallery')">Photos</button>
      <button id="tab-announcements" class="tab-btn flex-1 py-2.5 text-sm font-semibold text-gray-400 text-center whitespace-nowrap px-4" onclick="switchTab('announcements')">Announcements</button>
    </div>

    <!-- About Tab -->
    <div id="tab-about-content" class="tab-content active">
      <p id="detail-desc" class="text-sm text-gray-600 leading-relaxed"></p>
      <div id="detail-tags" class="flex flex-wrap gap-2 mt-4"></div>
      
      <!-- Comments Section -->
      <div id="comments-section" class="mt-8 border-t border-gray-100 pt-6 pb-2">
        <h3 class="text-lg font-bold text-gray-900 mb-4">Comments (<span id="comment-count">0</span>)</h3>
        <div class="space-y-5" id="comments-list">
          <p class="text-sm text-gray-500 text-center py-4">Loading comments...</p>
        </div>
      </div>
    </div>

    <!-- Gallery Tab -->
    <div id="tab-gallery-content" class="tab-content">
      <div class="mb-6 p-4 bg-gray-50 rounded-2xl border border-gray-200">
        <h4 class="text-sm font-bold text-gray-900 mb-2">Upload New Photo</h4>
        <form action="/organizer/events/<%= event.id %>/photos" method="POST" enctype="multipart/form-data" class="flex items-center gap-2">
          <input type="file" name="photos" accept="image/*" multiple required class="block w-full text-sm text-gray-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-white file:text-brand file:border file:border-gray-200 outline-none"/>
          <button type="submit" class="bg-brand text-white px-3 py-1.5 rounded-xl text-xs font-bold hover:bg-brand-dark transition-all shrink-0">Upload</button>
        </form>
      </div>
      <div id="gallery-container" class="grid grid-cols-2 gap-2">
        <p class="text-sm text-gray-500 text-center py-4 col-span-2">Loading photos...</p>
      </div>
    </div>

    <!-- Announcements Tab -->
    <div id="tab-announcements-content" class="tab-content">
      <!-- Add Announcement -->
      <div class="mb-6 p-4 bg-gray-50 rounded-2xl border border-gray-200">
        <h4 class="text-sm font-bold text-gray-900 mb-3">Post Announcement</h4>
        <form action="/organizer/events/<%= event.id %>/announcement" method="POST" class="space-y-3">
          <input type="text" name="title" placeholder="Title" required class="w-full bg-white border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-brand" />
          <textarea name="body" rows="2" placeholder="Message content" required class="w-full bg-white border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-brand resize-none"></textarea>
          <div class="flex justify-end">
            <button type="submit" class="bg-brand text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-brand-dark transition-all">Post</button>
          </div>
        </form>
      </div>
      <div id="detail-announcements-list" class="space-y-4">
        <p class="text-sm text-gray-500 text-center py-4">Loading announcements...</p>
      </div>
    </div>
  </div>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const RAW_EVENT = <%- typeof event !== 'undefined' ? JSON.stringify(event) : 'null' %>;
    let ev = null;
    
    if (RAW_EVENT) {
      const evCat = RAW_EVENT.category ? RAW_EVENT.category.name : (RAW_EVENT.tags ? RAW_EVENT.tags.split(',')[0] : "Other");
      ev = {
        id: RAW_EVENT.id,
        category: evCat,
        name: RAW_EVENT.title || RAW_EVENT.name,
        description: RAW_EVENT.description || "No description",
        venue: RAW_EVENT.venue || "TBA",
        img: RAW_EVENT.image_url || "https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800",
        date: RAW_EVENT.event_date ? new Date(RAW_EVENT.event_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : "TBA",
        start: RAW_EVENT.start_time ? (RAW_EVENT.start_time.length > 5 ? RAW_EVENT.start_time.substring(0, 5) : RAW_EVENT.start_time) : "",
        end: RAW_EVENT.end_time ? (RAW_EVENT.end_time.length > 5 ? RAW_EVENT.end_time.substring(0, 5) : RAW_EVENT.end_time) : "",
        visits: RAW_EVENT.analytics ? (RAW_EVENT.analytics.page_view_count || 0) : 0,
        navs: RAW_EVENT.analytics ? (RAW_EVENT.analytics.navigation_count || 0) : 0,
        bookmarks: RAW_EVENT.bookmarks ? RAW_EVENT.bookmarks.length : 0,
        organizer: RAW_EVENT.organizer ? RAW_EVENT.organizer.name : "Organizer"
      };
    }

    if (ev) {
      document.title = ev.name + " — Organizer";
      document.getElementById('detail-img').src = ev.img;
      document.getElementById('detail-name').textContent = ev.name;
      document.getElementById('detail-category').textContent = ev.category;
      document.getElementById('detail-date').textContent = ev.date;
      document.getElementById('detail-time').textContent = ev.start + " - " + ev.end;
      document.getElementById('detail-venue').textContent = ev.venue;
      document.getElementById('detail-desc').textContent = ev.description;
      document.getElementById('detail-visits').textContent = ev.visits;
      document.getElementById('detail-navs').textContent = ev.navs;
      document.getElementById('detail-bookmarks').textContent = ev.bookmarks;

      // tags
      const parsedTags = [ev.category];
      if (RAW_EVENT && RAW_EVENT.tags) {
         parsedTags.push(...RAW_EVENT.tags.split(',').map(t => t.trim()).filter(Boolean));
      }
      const tagContainer = document.getElementById('detail-tags');
      [...new Set(parsedTags)].forEach(t => {
        if (!t || t.toLowerCase() === 'other') return;
        const el = document.createElement('span');
        el.className = 'text-xs font-medium bg-gray-100 text-gray-500 px-3 py-1 rounded-full';
        el.textContent = t;
        tagContainer.appendChild(el);
      });

      // announcements
      fetch('/api/events/' + ev.id + '/announcements')
        .then(r => r.json())
        .then(data => {
            const list = document.getElementById('detail-announcements-list');
            list.innerHTML = '';
            if (data.announcements && data.announcements.length > 0) {
                data.announcements.forEach(a => {
                    const div = document.createElement('div');
                    div.className = 'bg-white rounded-2xl p-4 border border-gray-100 shadow-sm mb-3';
                    div.innerHTML = '<h5 class="font-bold text-gray-900 text-sm mb-1">'+a.title+'</h5><p class="text-xs text-gray-600 mb-2">'+a.body+'</p><span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-1 rounded inline-block">'+new Date(a.created_at).toLocaleDateString()+'</span>';
                    list.appendChild(div);
                });
            } else {
                list.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">No announcements yet.</p>';
            }
        }).catch(err => {
            document.getElementById('detail-announcements-list').innerHTML = '<p class="text-sm text-red-500 text-center">Error loading announcements.</p>';
        });

      // load photos
      fetch('/api/events/' + ev.id + '/photos')
        .then(r => r.json())
        .then(data => {
            const container = document.getElementById('gallery-container');
            container.innerHTML = '';
            const mainDiv = document.createElement('div');
            mainDiv.id = 'gallery-main';
            mainDiv.className = 'col-span-2 rounded-2xl overflow-hidden';
            mainDiv.style.height = '160px';
            mainDiv.innerHTML = '<img src="' + ev.img + '" class="w-full h-full object-cover" />';
            container.appendChild(mainDiv);

            if (data.photos && data.photos.length > 0) {
                data.photos.forEach(p => {
                  const pDiv = document.createElement('div');
                  pDiv.className = 'rounded-xl overflow-hidden bg-gray-100 relative';
                  pDiv.style.height = '100px';
                  pDiv.innerHTML = '<img src="' + p.image_url + '" onerror="this.src=\'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=800\'; this.onerror=null;" class="w-full h-full object-cover" />';                  container.appendChild(pDiv);
                });
            }
        }).catch(err => console.error(err));

      // load comments
      fetch('/api/events/' + ev.id + '/comments')
        .then(r => r.json())
        .then(data => {
            const list = document.getElementById('comments-list');
            list.innerHTML = '';
            document.getElementById('comment-count').textContent = data.comments && data.comments.length ? data.comments.length : '0';
            
            if (data.comments && data.comments.length > 0) {
                const organizerId = data.organizer_id;
                const topLevel = data.comments.filter(c => !c.parent_comment_id);
                
                const renderComment = (c, isReply = false) => {
                   const userName = (c.user && c.user.first_name) ? c.user.first_name + ' ' + (c.user.last_name || '') : 'Anonymous';
                   const userInit = (c.user && c.user.first_name) ? c.user.first_name.substring(0, 2).toUpperCase() : 'AN';
                   const isOrganizer = c.user && (c.user.id === organizerId);
                   
                   const replies = data.comments.filter(r => r.parent_comment_id === c.id);
                   
                   let html = `
                    <div class="group/comment ${isReply ? 'ml-8 mt-4' : 'mt-6'}">
                      <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full ${isOrganizer ? 'bg-brand text-white' : 'bg-blue-100 text-blue-600'} flex items-center justify-center font-bold text-[10px] flex-shrink-0 ring-2 ring-white shadow-sm">
                          ${userInit}
                        </div>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 mb-0.5">
                            <span class="text-sm font-bold text-gray-900 truncate">${userName}</span>
                            ${isOrganizer ? '<span class="text-[9px] font-black uppercase tracking-tighter bg-brand/10 text-brand px-1.5 py-0.5 rounded-md border border-brand/20">Organizer</span>' : ''}
                            <span class="text-[10px] text-gray-400 ml-auto whitespace-nowrap">${new Date(c.created_at).toLocaleDateString()}</span>
                          </div>
                          <p class="text-sm text-gray-600 leading-relaxed break-words">${c.content}</p>
                          
                          <div class="flex items-center gap-4 mt-2">
                             <button onclick="showReplyForm(${c.id})" class="text-[11px] font-bold text-brand hover:text-brand-dark transition-colors">Reply</button>
                             <span class="text-[10px] text-gray-300">|</span>
                             <span class="text-[10px] text-gray-400 font-medium">${replies.length} replies</span>
                          </div>
                          
                          <div id="reply-form-container-${c.id}" class="hidden mt-3 fade-up">
                             <div class="bg-gray-50 rounded-2xl p-3 border border-gray-100">
                               <textarea id="reply-input-${c.id}" rows="2" class="w-full bg-white border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-brand resize-none" placeholder="Write your reply..."></textarea>
                               <div class="flex justify-end gap-2 mt-2">
                                 <button onclick="hideReplyForm(${c.id})" class="px-3 py-1.5 text-[11px] font-bold text-gray-500 hover:text-gray-700 transition-colors">Cancel</button>
                                 <button onclick="submitReply(${c.id})" class="bg-brand text-white px-3 py-1.5 rounded-lg text-[11px] font-bold hover:bg-brand-dark transition-all">Post Reply</button>
                               </div>
                             </div>
                          </div>
                        </div>
                      </div>
                      <div id="replies-container-${c.id}">
                        ${replies.map(r => renderComment(r, true)).join('')}
                      </div>
                    </div>`;
                   return html;
                };

                topLevel.forEach(c => {
                   list.insertAdjacentHTML('beforeend', renderComment(c));
                });
            } else {
                list.innerHTML = '<div class="py-8 text-center"><div class="w-12 h-12 bg-gray-50 text-gray-300 rounded-full flex items-center justify-center mx-auto mb-3"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg></div><p class="text-sm text-gray-400">No comments yet. Be the first to start the conversation!</p></div>';
            }
            
            if (urlParams.get('action') === 'scrollToComments') {
                const targetId = urlParams.get('targetId');
                setTimeout(() => {
                    const element = targetId ? document.getElementById('comment-' + targetId) : document.getElementById('comments-section');
                    if (element) {
                        element.scrollIntoView({ behavior: 'smooth' });
                        if (targetId) {
                            element.classList.add('bg-brand-light');
                            setTimeout(() => element.classList.remove('bg-brand-light'), 2000);
                        }
                    }
                }, 500);
            }
        }).catch(err => console.error(err));
    }

    function showReplyForm(commentId) {
      document.getElementById('reply-form-container-' + commentId).classList.remove('hidden');
      document.getElementById('reply-input-' + commentId).focus();
    }

    function hideReplyForm(commentId) {
      document.getElementById('reply-form-container-' + commentId).classList.add('hidden');
    }

    async function submitReply(parentId) {
      const input = document.getElementById('reply-input-' + parentId);
      const text = input.value.trim();
      if (!text) return;

      try {
        const response = await fetch(`/api/events/${ev.id}/comment`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text, parent_comment_id: parentId })
        });
        const result = await response.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert('Failed to post reply: ' + result.error);
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred while posting your reply.');
      }
    }

    function switchTab(name) {
      ['about', 'gallery', 'announcements'].forEach(t => {
        document.getElementById('tab-' + t).classList.toggle('active', t === name);
        document.getElementById('tab-' + t + '-content').classList.toggle('active', t === name);
        if (t !== name) {
          document.getElementById('tab-' + t).classList.remove('active');
          document.getElementById('tab-' + t).classList.add('text-gray-400');
        } else {
          document.getElementById('tab-' + t).classList.remove('text-gray-400');
        }
      });
      // Save the active tab to localStorage
      localStorage.setItem('activeEventTab', name);
    }

    // Restore the last active tab on page load
    if (urlParams.get('tab')) {
      switchTab(urlParams.get('tab'));
    }

    function confirmDelete() {
      document.getElementById('delete-modal').classList.remove('hidden');
      document.getElementById('delete-modal').classList.add('flex');
    }

    function closeDeleteModal() {
      document.getElementById('delete-modal').classList.add('hidden');
      document.getElementById('delete-modal').classList.remove('flex');
    }

    async function deleteEvent() {
      closeDeleteModal();
      document.getElementById('loading-overlay').classList.remove('hidden');
      document.getElementById('loading-overlay').classList.add('flex');

      try {
        const response = await fetch(`/organizer/events/${ev.id}/delete`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        const result = await response.json();
        if (result.success) {
          // Stay on loading for a second to feel the process
          setTimeout(() => {
            window.location.href = '/organizer/events?deleted=true';
          }, 1500);
        } else {
          throw new Error(result.message || 'Failed to delete event');
        }
      } catch (err) {
        console.error(err);
        document.getElementById('loading-overlay').classList.add('hidden');
        document.getElementById('loading-overlay').classList.remove('flex');
        alert('Error: ' + err.message);
      }
    }
  </script>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-black/60 backdrop-blur-sm transition-all">
    <div class="bg-white rounded-3xl w-full max-w-sm overflow-hidden shadow-2xl fade-up">
      <div class="p-6 text-center">
        <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Delete Event?</h3>
        <p class="text-sm text-gray-500 mb-6">Are you sure you want to delete <span class="font-bold text-gray-700">"<%= event.title %>"</span>? This action cannot be undone and all event data will be permanently removed.</p>
        <div class="flex flex-col gap-3">
          <button onclick="deleteEvent()" class="w-full bg-red-500 text-white font-bold py-3.5 rounded-2xl hover:bg-red-600 active:scale-[0.98] transition-all shadow-lg shadow-red-200">Yes, Delete Event</button>
          <button onclick="closeDeleteModal()" class="w-full bg-gray-100 text-gray-600 font-bold py-3.5 rounded-2xl hover:bg-gray-200 active:scale-[0.98] transition-all">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Loading Overlay -->
  <div id="loading-overlay" class="fixed inset-0 z-[110] hidden items-center justify-center bg-white/90 backdrop-blur-md transition-all">
    <div class="text-center">
      <div class="relative w-20 h-20 mx-auto mb-4">
        <div class="absolute inset-0 border-4 border-brand/20 rounded-full"></div>
        <div class="absolute inset-0 border-4 border-brand border-t-transparent rounded-full animate-spin"></div>
      </div>
      <p class="text-brand font-bold animate-pulse">Deleting Event...</p>
      <p class="text-xs text-gray-400 mt-2">Please wait while we clean up</p>
    </div>
  </div>

  <!-- Bottom Navigation Tab Bar -->
  <div class="fixed bottom-0 w-full z-50 bg-white/95 backdrop-blur-xl border-t border-slate-200">
    <nav class="flex justify-between items-center px-6 py-3.5 max-w-lg mx-auto">
      <a href="/organizer/dashboard" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>
        <span class="text-[10px] font-bold tracking-wide">Home</span>
      </a>
      
      <a href="/organizer/analytics" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Analytics</span>
      </a>
      
      <a href="/organizer/events/add" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full bg-brand text-white shadow-lg shadow-brand/30 hover:scale-105 transition-transform ">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Add</span>
      </a>
      
      <a href="/organizer/events" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm14 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Event</span>
      </a>
      
      <a href="/organizer/profile" class="flex flex-col items-center justify-center gap-1 w-12 text-textMuted hover:text-textMain transition-colors relative group">
        <div class="p-1.5 rounded-full group-hover:bg-slate-100 transition-colors relative overflow-hidden">
          <% if (typeof sessionAuth !== 'undefined' && sessionAuth && sessionAuth.avatarUrl) { %>
            <img src="<%= sessionAuth.avatarUrl %>" alt="Profile" class="w-6 h-6 rounded-full object-cover">
          <% } else { %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% } %>
        </div>
        <span class="text-[10px] font-semibold tracking-wide">Profile</span>
      </a>
    </nav>
  </div>
</body>
</html>
