<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: '#1DA1F2',
            'brand-dark': '#0d8de0',
            'brand-light': '#e8f5fe',
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
        },
      },
    };
  </script>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body { font-family: 'Inter', sans-serif; overscroll-behavior-y: none; background-color: #f8fafc; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp .4s ease forwards; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
  </style>
</head>

<body class="min-h-screen max-w-md mx-auto pb-10">

  <!-- ── Floating Nav Bar ────────────────────────────── -->
  <div class="sticky top-0 w-full z-40 px-4 pt-5 pb-3 flex items-center justify-between bg-white/80 backdrop-blur-md border-b border-gray-100">
    <a href="javascript:history.back()"
      class="bg-white shadow-sm border border-gray-200 rounded-full p-2 text-gray-700 active:scale-95 transition-all flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
    <div class="px-4 py-1">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest text-center">Organizer Profile</p>
    </div>
    <div class="w-9"></div> <!-- spacer -->
  </div>

  <!-- ── Profile Header (Approved) / Reviewer Header (Pending) ──────────────── -->
  <% if (organizer.status === 'pending') { %>
    <!-- Verification Mode UI -->
    <div class="px-6 pt-8 pb-10 fade-up">
      <div class="bg-white rounded-[2rem] border border-amber-200 shadow-xl shadow-amber-50 overflow-hidden">
        <div class="bg-amber-50 px-6 py-4 border-b border-amber-100 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></div>
            <span class="text-[10px] font-black uppercase tracking-widest text-amber-700">Verification Pending</span>
          </div>
          <span class="text-[10px] font-bold text-amber-600/60">ID: #ORG-<%= organizer.id %></span>
        </div>
        
        <div class="p-8">
          <div class="flex flex-col items-center text-center mb-8">
            <div class="w-24 h-24 rounded-3xl bg-gray-50 flex items-center justify-center mb-4 shadow-inner border-2 border-white overflow-hidden ring-4 ring-gray-50/50">
              <% if (organizer.avatar_url) { %>
                <img src="<%= organizer.avatar_url %>" class="w-full h-full object-cover">
              <% } else { %>
                <span class="text-gray-300 text-4xl font-extrabold"><%= organizer.name[0].toUpperCase() %></span>
              <% } %>
            </div>
            <h1 class="text-2xl font-black text-gray-900 tracking-tight"><%= organizer.name %></h1>
            <p class="text-xs font-medium text-gray-400 mt-1">Application for Organizer Partnership</p>
          </div>

          <div class="space-y-6">
            <div class="relative pl-4 border-l-2 border-gray-100">
              <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Full Name / Organization</label>
              <p class="text-sm font-bold text-gray-800"><%= organizer.name %></p>
            </div>

            <div class="relative pl-4 border-l-2 border-gray-100">
              <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Email Address</label>
              <p class="text-sm font-bold text-brand"><%= (organizer.account && organizer.account.email) ? organizer.account.email : 'N/A' %></p>
            </div>

            <div class="relative pl-4 border-l-2 border-gray-100">
              <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Official Address</label>
              <p class="text-sm font-bold text-gray-800"><%= organizer.address || 'Not specified' %></p>
            </div>

            <div class="relative pl-4 border-l-2 border-gray-100">
              <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Business/Organization Bio</label>
              <p class="text-sm text-gray-600 leading-relaxed font-medium"><%= organizer.description || 'No description provided' %></p>
            </div>
          </div>

          <div class="mt-10 pt-8 border-t border-dashed border-gray-100">
            <div class="flex flex-col gap-3">
              <form action="/admin/organizers/<%= organizer.id %>/approve" method="POST" class="m-0">
                <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-4 rounded-2xl shadow-lg shadow-emerald-100 active:scale-[0.98] transition-all text-sm flex items-center justify-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Approve Application
                </button>
              </form>
              <form action="/admin/organizers/<%= organizer.id %>/reject" method="POST" class="m-0">
                <button type="submit" class="w-full bg-white hover:bg-red-50 text-red-500 font-bold py-4 rounded-2xl active:scale-[0.98] transition-all text-sm border-2 border-red-50">
                  Decline Request
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } else { %>
    <!-- Standard Profile View (Approved/Rejected) -->
    <div class="bg-white border-b border-gray-100 px-6 pt-8 pb-10 fade-up">
      <div class="flex flex-col items-center text-center">
        <div class="w-24 h-24 rounded-3xl bg-brand-light flex items-center justify-center mb-5 shadow-xl shadow-brand/10 border-4 border-white overflow-hidden">
          <% if (organizer.avatar_url) { %>
            <img src="<%= organizer.avatar_url %>" class="w-full h-full object-cover">
          <% } else { %>
            <span class="text-brand text-4xl font-extrabold"><%= organizer.name[0].toUpperCase() %></span>
          <% } %>
        </div>
        
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight"><%= organizer.name %></h1>
        
        <div class="flex items-center gap-2 mt-2">
          <% if(organizer.status === 'approved') { %>
            <span class="text-[10px] font-black uppercase tracking-widest bg-emerald-100 text-emerald-600 px-2.5 py-1 rounded-lg border border-emerald-200">Verified Partner</span>
          <% } else if(organizer.status === 'rejected') { %>
            <span class="text-[10px] font-black uppercase tracking-widest bg-red-100 text-red-600 px-2.5 py-1 rounded-lg border border-red-200">Account Rejected</span>
          <% } %>
        </div>

        <% if (organizer.description) { %>
          <p class="mt-5 text-sm text-gray-500 leading-relaxed max-w-[280px]">
            <%= organizer.description %>
          </p>
        <% } %>

        <div class="grid grid-cols-2 w-full gap-4 mt-8">
          <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Email Address</p>
              <p class="text-xs font-bold text-gray-700 truncate"><%= (organizer.account && organizer.account.email) ? organizer.account.email : 'N/A' %></p>
          </div>
          <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Office Location</p>
              <p class="text-xs font-bold text-gray-700 truncate"><%= organizer.address || 'Not specified' %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Stats Row ──────────────────────────────────── -->
    <div class="px-6 py-6 fade-up" style="animation-delay: 0.1s;">
      <div class="grid grid-cols-3 gap-3">
          <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center">
              <p class="text-lg font-black text-gray-900"><%= stats.totalEvents %></p>
              <p class="text-[9px] font-bold text-gray-400 uppercase tracking-tighter">Total Events</p>
          </div>
          <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center">
              <p class="text-lg font-black text-brand"><%= stats.ongoingEvents %></p>
              <p class="text-[9px] font-bold text-gray-400 uppercase tracking-tighter">Ongoing Events</p>
          </div>
          <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center">
              <p class="text-lg font-black text-emerald-500"><%= stats.averageRating %></p>
              <p class="text-[9px] font-bold text-gray-400 uppercase tracking-tighter">Avg Rating</p>
          </div>
      </div>
    </div>

    <!-- ── Events List ────────────────────────────────── -->
    <div class="px-6 pb-20 fade-up" style="animation-delay: 0.2s;">
      <h3 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-4">Event Portfolio</h3>
      
      <div class="space-y-4">
        <% if (events.length > 0) { %>
          <% events.forEach(evt => { %>
            <a href="/admin/events/<%= evt.id %>" class="block bg-white rounded-2xl p-3 border border-gray-100 shadow-sm flex gap-3 hover:border-brand/30 transition-colors active:scale-[0.98]">
              <div class="w-16 h-16 rounded-xl overflow-hidden shrink-0 bg-gray-100 border border-gray-50">
                  <img src="<%= evt.image_url || 'https://images.unsplash.com/photo-1542204165-65bf26472b9b?auto=format&fit=crop&q=80&w=200' %>" class="w-full h-full object-cover">
              </div>
              <div class="min-w-0 flex-1 flex flex-col justify-center">
                  <div class="flex items-center gap-1.5 mb-0.5">
                      <span class="text-[9px] font-black uppercase text-brand"><%= evt.category ? evt.category.name : 'Other' %></span>
                      <span class="w-1 h-1 rounded-full bg-gray-200"></span>
                      <span class="text-[9px] font-bold text-gray-400"><%= new Date(evt.event_date).toLocaleDateString() %></span>
                  </div>
                  <h4 class="text-sm font-bold text-gray-900 truncate"><%= evt.title %></h4>
                  <div class="flex items-center gap-2 mt-1">
                      <% if(evt.is_ongoing) { %>
                          <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                          <span class="text-[9px] font-bold text-emerald-600">ONGOING</span>
                      <% } else { %>
                          <span class="text-[9px] font-bold text-gray-400 uppercase tracking-tighter"><%= evt.status %></span>
                      <% } %>
                  </div>
              </div>
            </a>
          <% }) %>
        <% } else { %>
          <div class="py-12 bg-gray-50 rounded-3xl border border-dashed border-gray-200 text-center">
              <p class="text-sm font-bold text-gray-400">No events published yet</p>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

</body>
</html>
