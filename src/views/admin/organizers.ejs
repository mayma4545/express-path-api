<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#E9E4FF', DEFAULT: '#1DA1F2', dark: '#5A26ED' },
            bgWhite: '#FFFFFF',
            bgLight: '#F8F9FE',
            textMain: '#111827',
            textMuted: '#6B7280'
          }, 
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(124, 67, 254, 0.4)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8F9FE; -webkit-tap-highlight-color: transparent; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .modal-enter { animation: fadeIn .18s ease-out; }
    .modal-card-enter { animation: slideUp .22s ease-out; }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(10px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
  </style>
</head>
<body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">

  <!-- Desktop Sidebar -->
    <aside
      class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft"
    >
      <div class="flex flex-col gap-8 items-center">
        <nav class="flex flex-col gap-6">
          <a
            href="/admin/dashboard"
            class="p-3 rounded-xl bg-brand-light text-brand"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path
                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/organizers"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/activity"
            class="relative p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              />
            </svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a
            href="/admin/events"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </a>
          <a
            href="/admin/reports"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
          </a>
        </nav>
      </div>
      
    </aside>
    
  <!-- Mobile Bottom Tab Pane -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40">
      <a href="/admin/dashboard" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.293 3.293a1 1 0 011.414 0l7 7A1 1 0 0119 12h-1v7a1 1 0 01-1 1h-3a1 1 0 01-1-1v-3a1 1 0 00-1-1h-2a1 1 0 00-1 1v3a1 1 0 01-1 1H6a1 1 0 01-1-1v-7H4a1 1 0 01-.707-1.707l7-7z"/></svg>
      </a>
      <a href="/admin/organizers" class="flex flex-col items-center gap-1 text-brand">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </a>
      <a href="/admin/activity" class="relative flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-0 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="mobile-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
      <a href="/admin/events" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
      <a href="/admin/reports" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </a>
    </div>

  <!-- Main Content Wrapper -->
  <main class="max-w-2xl mx-auto p-4 sm:p-6 md:py-10">
    
    <!-- Status Alerts -->
    <div id="approved-alert" class="hidden mb-6 bg-emerald-50 border border-emerald-100 rounded-2xl p-4 flex items-center gap-3 fade-up">
        <div class="w-10 h-10 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <h4 class="text-emerald-900 font-bold text-sm">Account Approved</h4>
          <p class="text-emerald-600 text-xs">The organizer has been notified and can now log in.</p>
        </div>
        <button onclick="this.parentElement.remove()" class="ml-auto text-emerald-400 hover:text-emerald-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
    </div>

    <div id="rejected-alert" class="hidden mb-6 bg-red-50 border border-red-100 rounded-2xl p-4 flex items-center gap-3 fade-up">
        <div class="w-10 h-10 bg-red-100 text-red-600 rounded-full flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </div>
        <div>
          <h4 class="text-red-900 font-bold text-sm">Account Rejected</h4>
          <p class="text-red-600 text-xs">The application has been declined.</p>
        </div>
        <button onclick="this.parentElement.remove()" class="ml-auto text-red-400 hover:text-red-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
    </div>
    
    <!-- Top Bar -->
    <header class="flex flex-col sm:flex-row justify-between sm:items-center gap-4 mb-6 sm:mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-textMain tracking-tight">Organizers</h1>
        <p class="text-xs sm:text-sm font-medium text-textMuted mt-1">Review and confirm organizer accounts.</p>
      </div>
      <div class="flex w-full sm:w-64 relative">
        <svg class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input type="text" id="searchInput" placeholder="Search organizers..." class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand shadow-sm transition">
      </div>
    </header>

    <div id="organizerListContainer" class="bg-white rounded-3xl p-2 shadow-sm border border-gray-50 relative z-10">
      <% organizers.forEach((org, index) => { %>
        <div class="organizer-item flex flex-col sm:flex-row sm:items-center justify-between p-4 rounded-2xl hover:bg-gray-50 transition gap-3 sm:gap-4 <%= index > 0 ? 'border-t border-gray-50' : '' %>" data-name="<%= org.name.toLowerCase() %>" data-email="<%= (org.account && org.account.email) ? org.account.email.toLowerCase() : '' %>">
          <div class="flex items-center gap-3 sm:gap-4 min-w-0 flex-1">
            <div class="w-12 h-12 flex-shrink-0 rounded-2xl bg-[#F0F2FF] overflow-hidden flex items-center justify-center font-bold text-brand shadow-sm border border-white">
              <% if(org.avatar_url) { %>
                <img src="<%= org.avatar_url %>" class="w-full h-full object-cover">
              <% } else { %>
                <span class="text-lg"><%= org.name.charAt(0).toUpperCase() %></span>
              <% } %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="font-bold text-textMain text-sm truncate"><%= org.name %></p>
                <% if(org.status === 'pending') { %>
                  <span class="text-[9px] font-black uppercase tracking-tighter bg-amber-100 text-amber-600 px-1.5 py-0.5 rounded-md border border-amber-200">Pending</span>
                <% } else if(org.status === 'approved') { %>
                  <span class="text-[9px] font-black uppercase tracking-tighter bg-emerald-100 text-emerald-600 px-1.5 py-0.5 rounded-md border border-emerald-200">Approved</span>
                <% } else if(org.status === 'rejected') { %>
                  <span class="text-[9px] font-black uppercase tracking-tighter bg-red-100 text-red-600 px-1.5 py-0.5 rounded-md border border-red-200">Rejected</span>
                <% } %>
              </div>
              <p class="text-xs text-textMuted mt-0.5 truncate"><%= org.description || 'No description provided' %></p>
              <p class="text-[11px] font-medium text-brand-dark mt-1 truncate"><%= (org.account && org.account.email) ? org.account.email : 'No linked account yet' %></p>
              <% if(org.address) { %>
                <p class="text-[10px] text-textMuted mt-1 truncate flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  <%= org.address %>
                </p>
              <% } %>
            </div>
          </div>
          <div class="flex gap-2 w-full sm:w-auto mt-2 sm:mt-0 pt-3 sm:pt-0 border-t sm:border-t-0 border-gray-50 justify-end items-center">
            <% if(org.status === 'pending') { %>
              <form action="/admin/organizers/<%= org.id %>/approve" method="POST" class="m-0">
                <button type="submit" class="text-xs font-bold text-white bg-emerald-500 px-4 py-1.5 rounded-xl sm:rounded-lg hover:bg-emerald-600 active:scale-95 transition shadow-sm">Confirm</button>
              </form>
              <form action="/admin/organizers/<%= org.id %>/reject" method="POST" class="m-0">
                <button type="submit" class="text-xs font-bold text-red-500 bg-red-50 px-4 py-1.5 rounded-xl sm:rounded-lg hover:bg-red-100 active:scale-95 transition">Reject</button>
              </form>
            <% } else { %>
              <a href="/admin/organizers/<%= org.id %>" class="flex-1 sm:flex-none text-xs font-bold text-brand bg-brand-light px-4 py-2 sm:py-1.5 rounded-xl sm:rounded-lg hover:bg-[#D7C9FF] active:scale-95 transition text-center">
                Profile
              </a>
              <form action="/admin/organizers/<%= org.id %>/delete" method="POST" class="delete-org-form flex-1 sm:flex-none m-0">
                <button type="submit" class="w-full text-xs font-bold text-red-500 bg-[#FFF0F0] px-4 py-2 sm:py-1.5 rounded-xl sm:rounded-lg hover:bg-red-100 active:scale-95 transition">Revoke</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }); %>
      <% if (organizers.length === 0) { %>
        <div class="py-10 flex flex-col items-center justify-center text-textMuted">
          <svg class="w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          <span class="text-sm font-medium">No organizers found.</span>
        </div>
      <% } %>
    </div>
    
    <!-- Pagination Area -->
    <div id="paginationControls" class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-6 hidden">
      <span id="paginationInfo" class="text-xs font-medium text-textMuted">Showing 1 to 10 of 10</span>
      <div class="flex items-center gap-2">
        <button id="prevPageBtn" class="px-4 py-2 rounded-xl border border-gray-200 bg-white text-sm font-bold text-textMain hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition">Previous</button>
        <div id="pageNumbers" class="flex items-center gap-1 hidden sm:flex text-sm font-medium"></div>
        <button id="nextPageBtn" class="px-4 py-2 rounded-xl border border-gray-200 bg-white text-sm font-bold text-textMain hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition">Next</button>
      </div>
    </div>
  </main>

  <!-- Floating Add Button -->
  <button id="openAddOrganizerModal" type="button" class="fixed bottom-24 md:bottom-10 right-6 md:right-10 w-14 h-14 bg-brand text-white rounded-2xl md:rounded-full shadow-float flex items-center justify-center hover:bg-brand-dark active:scale-95 transition z-40">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
  </button>

  <div id="addOrganizerModal" class="fixed inset-0 z-50 hidden modal-enter">
    <div id="addOrganizerBackdrop" class="absolute inset-0 bg-black/40 backdrop-blur-[2px]"></div>
    <div class="relative min-h-screen flex items-end sm:items-center justify-center p-0 sm:p-4">
      <div class="w-full max-w-xl bg-white rounded-t-3xl sm:rounded-3xl shadow-soft sm:border border-gray-100 modal-card-enter max-h-[90vh] overflow-y-auto no-scrollbar pb-8 sm:pb-0">
        <div class="sticky top-0 bg-white/80 backdrop-blur-md px-6 py-5 border-b border-gray-100 flex items-start justify-between gap-4 z-10">
          <div>
            <h2 class="text-xl font-extrabold text-textMain tracking-tight">Create Organizer</h2>
            <p class="text-sm text-textMuted mt-1">Add organizer details to the database.</p>
          </div>
          <button id="closeAddOrganizerModal" type="button" class="w-9 h-9 rounded-xl border border-gray-100 text-textMuted hover:bg-gray-50 active:scale-95 transition">
            <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>

        <form action="/admin/organizers" method="POST" enctype="multipart/form-data" class="p-6 space-y-5">
          <!-- Modern Avatar Picker (Top) -->
          <div class="flex flex-col items-center justify-center pt-2 pb-4">
            <label for="org-avatar" class="relative cursor-pointer group">
              <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border-2 border-dashed border-gray-300 bg-gray-50 flex flex-col items-center justify-center overflow-hidden group-hover:border-brand transition group-hover:bg-brand-light shadow-sm relative z-10">
                <img id="org-avatar-preview" src="" alt="Avatar preview" class="w-full h-full object-cover hidden absolute inset-0 z-20">
                <div id="org-avatar-placeholder" class="flex flex-col items-center text-brand relative z-10">
                  <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400 group-hover:text-brand transition mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <span class="text-[10px] sm:text-xs font-bold text-gray-500 group-hover:text-brand transition">Upload Logo</span>
                </div>
              </div>
              <div class="absolute bottom-0 right-0 bg-brand text-white p-1.5 sm:p-2 rounded-full border-2 border-white shadow-sm z-30 group-hover:scale-110 transition">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <input id="org-avatar" name="avatar_image" type="file" accept="image/*" class="hidden">
            </label>
          </div>

          <div>
            <label for="org-name" class="block text-sm font-bold text-textMain mb-1.5">Organizer Name</label>
            <input id="org-name" name="name" type="text" required maxlength="255" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="e.g. CS Student Council">
          </div>

          <div>
            <label for="org-email" class="block text-sm font-bold text-textMain mb-1.5">Username (Email)</label>
            <input id="org-email" name="email" type="email" required maxlength="255" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="organizer@email.com">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="org-password" class="block text-sm font-bold text-textMain mb-1.5">Password</label>
              <input id="org-password" name="password" type="password" required minlength="8" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="At least 8 characters">
            </div>
            <div>
              <label for="org-password-confirm" class="block text-sm font-bold text-textMain mb-1.5">Confirm Password</label>
              <input id="org-password-confirm" name="confirm_password" type="password" required minlength="8" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="Confirm password">
            </div>
          </div>

          <div>
            <label for="org-description" class="block text-sm font-bold text-textMain mb-1.5">Description (Optional)</label>
            <textarea id="org-description" name="description" rows="3" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="Tell users about this organizer"></textarea>
          </div>

          <div class="pt-4 pb-2 flex flex-col sm:flex-row items-center justify-end gap-3 sm:gap-2 border-t border-gray-100 mt-6">
            <button id="cancelAddOrganizer" type="button" class="w-full sm:w-auto px-4 py-3 sm:py-2.5 rounded-xl border border-gray-200 bg-white text-sm font-bold text-textMuted hover:bg-gray-50 active:scale-95 transition">Cancel</button>
            <button type="submit" id="submitOrganizerBtn" class="w-full sm:w-auto px-5 py-3 sm:py-2.5 rounded-xl bg-brand text-white text-sm font-bold shadow-float hover:bg-brand-dark active:scale-95 transition">Save Organizer</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Organizer Modal -->
  <div id="editOrganizerModal" class="fixed inset-0 z-50 hidden modal-enter">
    <div id="editOrganizerBackdrop" class="absolute inset-0 bg-black/40 backdrop-blur-[2px]"></div>
    <div class="relative min-h-screen flex items-end sm:items-center justify-center p-0 sm:p-4">
      <div class="w-full max-w-xl bg-white rounded-t-3xl sm:rounded-3xl shadow-soft sm:border border-gray-100 modal-card-enter max-h-[90vh] overflow-y-auto no-scrollbar pb-8 sm:pb-0">
        <div class="sticky top-0 bg-white/80 backdrop-blur-md px-6 py-5 border-b border-gray-100 flex items-start justify-between gap-4 z-10">
          <div>
            <h2 class="text-xl font-extrabold text-textMain tracking-tight">Edit Organizer</h2>
            <p class="text-sm text-textMuted mt-1">Update existing organizer details.</p>
          </div>
          <button id="closeEditOrganizerModal" type="button" class="w-9 h-9 rounded-xl border border-gray-100 text-textMuted hover:bg-gray-50 active:scale-95 transition">
            <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>

        <form id="editOrganizerForm" action="" method="POST" enctype="multipart/form-data" class="p-6 space-y-5">
          <!-- Modern Avatar Picker (Top) -->
          <div class="flex flex-col items-center justify-center pt-2 pb-4">
            <label for="edit-org-avatar" class="relative cursor-pointer group">
              <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border-2 border-dashed border-gray-300 bg-gray-50 flex flex-col items-center justify-center overflow-hidden group-hover:border-brand transition group-hover:bg-brand-light shadow-sm relative z-10">
                <img id="edit-org-avatar-preview" src="" alt="Avatar preview" class="w-full h-full object-cover hidden absolute inset-0 z-20">
                <div id="edit-org-avatar-placeholder" class="flex flex-col items-center text-brand relative z-10">
                  <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400 group-hover:text-brand transition mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <span class="text-[10px] sm:text-xs font-bold text-gray-500 group-hover:text-brand transition">Upload Logo</span>
                </div>
              </div>
              <div class="absolute bottom-0 right-0 bg-brand text-white p-1.5 sm:p-2 rounded-full border-2 border-white shadow-sm z-30 group-hover:scale-110 transition">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <input id="edit-org-avatar" name="avatar_image" type="file" accept="image/*" class="hidden">
            </label>
          </div>

          <div>
            <label for="edit-org-name" class="block text-sm font-bold text-textMain mb-1.5">Organizer Name</label>
            <input id="edit-org-name" name="name" type="text" required maxlength="255" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition">
          </div>

          <div>
            <label for="edit-org-email" class="block text-sm font-bold text-textMain mb-1.5">Username (Email)</label>
            <input id="edit-org-email" name="email" type="email" required maxlength="255" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="edit-org-password" class="block text-sm font-bold text-textMain mb-1.5">New Password (Leave blank to keep)</label>
              <input id="edit-org-password" name="password" type="password" minlength="8" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="New password">
            </div>
            <div>
              <label for="edit-org-password-confirm" class="block text-sm font-bold text-textMain mb-1.5">Confirm New Password</label>
              <input id="edit-org-password-confirm" name="confirm_password" type="password" minlength="8" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition" placeholder="Confirm new password">
            </div>
          </div>

          <div>
            <label for="edit-org-description" class="block text-sm font-bold text-textMain mb-1.5">Description (Optional)</label>
            <textarea id="edit-org-description" name="description" rows="3" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand transition"></textarea>
          </div>

          <div class="pt-4 pb-2 flex flex-col sm:flex-row items-center justify-end gap-3 sm:gap-2 border-t border-gray-100 mt-6">
            <button id="cancelEditOrganizer" type="button" class="w-full sm:w-auto px-4 py-3 sm:py-2.5 rounded-xl border border-gray-200 bg-white text-sm font-bold text-textMuted hover:bg-gray-50 active:scale-95 transition">Cancel</button>
            <button type="submit" class="w-full sm:w-auto px-5 py-3 sm:py-2.5 rounded-xl bg-brand text-white text-sm font-bold shadow-float hover:bg-brand-dark active:scale-95 transition">Update Organizer</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Global Loading Overlay -->
  <div id="globalLoader" class="fixed inset-0 z-[100] hidden items-center justify-center bg-white/70 backdrop-blur-sm transition-opacity duration-300 opacity-0">
    <div class="bg-white p-6 rounded-2xl shadow-float flex flex-col items-center justify-center gap-4 min-w-[200px] border border-gray-100">
      <svg class="animate-spin h-10 w-10 text-brand" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span class="text-sm font-bold text-textMain animate-pulse" id="loaderText">Processing...</span>
    </div>
  </div>

  <script>
    (function () {
      // Show alerts based on URL parameters
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('approved') === 'true') {
        const alert = document.getElementById('approved-alert');
        alert.classList.remove('hidden');
        alert.classList.add('flex');
        setTimeout(() => alert.remove(), 5000);
      } else if (urlParams.get('rejected') === 'true') {
        const alert = document.getElementById('rejected-alert');
        alert.classList.remove('hidden');
        alert.classList.add('flex');
        setTimeout(() => alert.remove(), 5000);
      }

      // --- Global Loader Setup ---
      const globalLoader = document.getElementById('globalLoader');
      const loaderText = document.getElementById('loaderText');

      function showLoader(message = 'Processing...') {
        loaderText.textContent = message;
        globalLoader.classList.remove('hidden');
        globalLoader.classList.add('flex');
        // small timeout to trigger fade transition
        setTimeout(() => globalLoader.classList.remove('opacity-0'), 10);
      }

      function hideLoader() {
        globalLoader.classList.add('opacity-0');
        setTimeout(() => {
          globalLoader.classList.add('hidden');
          globalLoader.classList.remove('flex');
        }, 300);
      }

      // Attach Loader to all Form Submits
      document.querySelectorAll('form').forEach(f => {
        f.addEventListener('submit', function(e) {
          // If it's the delete form, natively confirm first
          if (f.classList.contains('delete-org-form')) {
            if (!confirm('Are you sure you want to permanently revoke this organizer? This action cannot be undone.')) {
              e.preventDefault();
              return;
            }
            showLoader('Deleting Organizer...');
          } else if (f.id === 'editOrganizerForm') {
            showLoader('Saving Changes...');
          } else {
            showLoader('Creating Organizer...');
          }
        });
      });

      // --- Add Organizer Modal Logic ---
      const modal = document.getElementById('addOrganizerModal');
      const openBtn = document.getElementById('openAddOrganizerModal');
      const closeBtn = document.getElementById('closeAddOrganizerModal');
      const cancelBtn = document.getElementById('cancelAddOrganizer');
      const backdrop = document.getElementById('addOrganizerBackdrop');
      const avatarInput = document.getElementById('org-avatar');
      const avatarPreview = document.getElementById('org-avatar-preview');
      const avatarPlaceholder = document.getElementById('org-avatar-placeholder');

      function openModal() {
        modal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }

      openBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      cancelBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);

      // --- Edit Organizer Modal Logic ---
      const editModal = document.getElementById('editOrganizerModal');
      const closeEditBtn = document.getElementById('closeEditOrganizerModal');
      const cancelEditBtn = document.getElementById('cancelEditOrganizer');
      const editBackdrop = document.getElementById('editOrganizerBackdrop');
      const editAvatarInput = document.getElementById('edit-org-avatar');
      const editAvatarPreview = document.getElementById('edit-org-avatar-preview');
      const editAvatarPlaceholder = document.getElementById('edit-org-avatar-placeholder');
      const editForm = document.getElementById('editOrganizerForm');

      function openEditModal(button) {
        // Retrieve data
        const id = button.getAttribute('data-id');
        const name = button.getAttribute('data-name');
        const email = button.getAttribute('data-email');
        const description = button.getAttribute('data-description');
        const avatar = button.getAttribute('data-avatar');

        // Populate fields
        editForm.action = `/admin/organizers/${id}/edit`;
        document.getElementById('edit-org-name').value = name || '';
        document.getElementById('edit-org-email').value = email || '';
        document.getElementById('edit-org-description').value = description || '';
        document.getElementById('edit-org-password').value = '';
        document.getElementById('edit-org-password-confirm').value = '';

        // Handle Avatar Preview
        if (avatar) {
          editAvatarPreview.src = avatar;
          editAvatarPreview.classList.remove('hidden');
          editAvatarPlaceholder.classList.add('hidden');
        } else {
          editAvatarPreview.src = '';
          editAvatarPreview.classList.add('hidden');
          editAvatarPlaceholder.classList.remove('hidden');
        }

        editModal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      }

      function closeEditModal() {
        editModal.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }

      closeEditBtn.addEventListener('click', closeEditModal);
      cancelEditBtn.addEventListener('click', closeEditModal);
      editBackdrop.addEventListener('click', closeEditModal);

      // Event delegation for dynamically paginated edit buttons
      document.addEventListener('click', function(e) {
        if (e.target.closest('.edit-btn')) {
          openEditModal(e.target.closest('.edit-btn'));
        }
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          if (!modal.classList.contains('hidden')) closeModal();
          if (!editModal.classList.contains('hidden')) closeEditModal();
        }
      });

      // Confirm Password validation before submit (Add)
      const form = document.querySelector('form[action="/admin/organizers"]');
      const pass = document.getElementById('org-password');
      const confirmPass = document.getElementById('org-password-confirm');
      
      form.addEventListener('submit', function(e) {
        if (pass.value !== confirmPass.value) {
          e.preventDefault();
          hideLoader(); // Important to kill loader if hijacked
          alert('Passwords do not match!');
          confirmPass.focus();
        }
      });

      // Confirm Password validation before submit (Edit)
      editForm.addEventListener('submit', function(e) {
        const editPass = document.getElementById('edit-org-password');
        const editConfirmPass = document.getElementById('edit-org-password-confirm');
        if (editPass.value || editConfirmPass.value) {
          if (editPass.value !== editConfirmPass.value) {
            e.preventDefault();
            hideLoader(); // Important to kill loader if hijacked
            alert('Passwords do not match!');
            editConfirmPass.focus();
          }
        }
      });

      // Avatar Input Listeners
      avatarInput.addEventListener('change', function () {
        const file = avatarInput.files && avatarInput.files[0];
        if (!file) {
          avatarPreview.classList.add('hidden');
          avatarPlaceholder.classList.remove('hidden');
          avatarPreview.src = '';
          return;
        }
        const reader = new FileReader();
        reader.onload = function (e) {
          avatarPreview.src = e.target.result;
          avatarPreview.classList.remove('hidden');
          avatarPlaceholder.classList.add('hidden');
        };
        reader.readAsDataURL(file);
      });

      editAvatarInput.addEventListener('change', function () {
        const file = editAvatarInput.files && editAvatarInput.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
          editAvatarPreview.src = e.target.result;
          editAvatarPreview.classList.remove('hidden');
          editAvatarPlaceholder.classList.add('hidden');
        };
        reader.readAsDataURL(file);
      });

      // Search & Pagination Logic
      const searchInput = document.getElementById('searchInput');
      const allItems = Array.from(document.querySelectorAll('.organizer-item'));
      const paginationControls = document.getElementById('paginationControls');
      const paginationInfo = document.getElementById('paginationInfo');
      const prevPageBtn = document.getElementById('prevPageBtn');
      const nextPageBtn = document.getElementById('nextPageBtn');
      
      const itemsPerPage = 10;
      let currentPage = 1;
      let filteredItems = [...allItems];

      function renderList() {
        // Hide all
        allItems.forEach(item => item.style.display = 'none');
        
        if (filteredItems.length === 0) {
          paginationControls.classList.add('hidden');
          return;
        }

        const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const startIdx = (currentPage - 1) * itemsPerPage;
        const endIdx = Math.min(startIdx + itemsPerPage, filteredItems.length);

        // Show items for current page
        for (let i = startIdx; i < endIdx; i++) {
          filteredItems[i].style.display = '';
        }

        // Update pagination UI
        paginationControls.classList.remove('hidden');
        paginationInfo.textContent = `Showing ${startIdx + 1} to ${endIdx} of ${filteredItems.length}`;
        
        prevPageBtn.disabled = currentPage === 1;
        nextPageBtn.disabled = currentPage === totalPages;
      }

      function handleSearch() {
        const query = searchInput.value.toLowerCase().trim();
        if (!query) {
          filteredItems = [...allItems];
        } else {
          filteredItems = allItems.filter(item => {
            const name = item.getAttribute('data-name') || '';
            const email = item.getAttribute('data-email') || '';
            return name.includes(query) || email.includes(query);
          });
        }
        currentPage = 1;
        renderList();
      }

      if (searchInput) searchInput.addEventListener('input', handleSearch);
      
      if (prevPageBtn) {
        prevPageBtn.addEventListener('click', () => {
          if (currentPage > 1) { currentPage--; renderList(); }
        });
      }
      
      if (nextPageBtn) {
        nextPageBtn.addEventListener('click', () => {
          const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
          if (currentPage < totalPages) { currentPage++; renderList(); }
        });
      }

      // Initial render
      if (allItems.length > 0) renderList();

    })();
  </script>
</body>
</html>