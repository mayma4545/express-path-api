﻿
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title><%= event.title || event.name %> — Admin Moderation</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: "#f43f5e",
            "brand-dark": "#e11d48",
            "brand-light": "#ffe4e6",
          },
          fontFamily: { sans: ["Inter", "ui-sans-serif", "system-ui"] },
        },
      },
    };
  </script>
  <style>
    * { -webkit-tap-highlight-color: transparent; }
    body { font-family: "Inter", sans-serif; overscroll-behavior-y: none; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp .4s ease forwards; }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
    .slide-in { animation: slideInRight .35s cubic-bezier(.4, 0, .2, 1) forwards; }
    .btn-ripple { position: relative; overflow: hidden; }
    .btn-ripple::after { content: ""; position: absolute; inset: 0; background: white; opacity: 0; transition: opacity .3s; border-radius: inherit; }
    .btn-ripple:active::after { opacity: .25; }
    .tab-btn { transition: all .2s; }
    .tab-btn.active { color: #e11d48; border-bottom: 2px solid #e11d48; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
  </style>
</head>

<body class="bg-gray-50 min-h-screen max-w-md mx-auto overflow-x-hidden shadow-2xl relative" style="padding-bottom: 90px; background-color: #fff !important;">

  <!-- ── Floating Nav Bar ────────────────────────────── -->
  <div class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-md z-40 px-4 pt-5 flex items-center justify-between pointer-events-none" style="max-width:448px;">
    <a href="/admin/events"
      class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 text-gray-700 active:scale-95 transition-all flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </a>
    <div class="pointer-events-auto bg-rose-50 border border-brand/20 backdrop-blur-md shadow-lg rounded-xl px-4 py-2 flex items-center justify-center gap-1.5 shadow-brand/10">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
      <p class="text-xs font-extrabold text-brand tracking-wide text-center uppercase">Admin POV</p>
    </div>
    <div class="pointer-events-auto bg-white/90 backdrop-blur-md shadow-lg rounded-full p-2.5 flex items-center justify-center opacity-0 cursor-default">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"></svg>
    </div>
  </div>

  <!-- ── Hero Image ──────────────────────────────────── -->
  <div class="relative" style="height:300px;">
    <% if (event.image_url) { %>
        <img id="detail-img" src="<%= event.image_url %>" alt="Event Image" class="w-full h-full object-cover" />
    <% } else { %>
        <div class="w-full h-full bg-slate-200 flex items-center justify-center">
            <span class="text-slate-500 font-medium">No Image Provided</span>
        </div>
    <% } %>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 px-5 pb-5 flex items-end justify-between">
      <div>
        <span id="detail-category" class="text-xs font-bold uppercase tracking-widest text-white/90 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full border border-white/30 mb-2 inline-block">
            <%= event.category ? event.category.name : "Uncategorized" %>
        </span>
        <h1 id="detail-name" class="text-2xl font-extrabold text-white leading-tight mt-1 drop-shadow-md"><%= event.title || event.name %></h1>
      </div>
      <div class="flex flex-col items-center bg-white/20 backdrop-blur-sm rounded-2xl px-3 py-2 border border-white/30">
        <span class="badge <%= event.is_ongoing ? "bg-emerald-500" : "bg-slate-500" %> rounded-full px-2 py-1 text-[10px] text-white uppercase font-bold shadow-sm">
            <%= event.is_ongoing ? "Ongoing" : "Scheduled" %>
        </span>
      </div>
    </div>
  </div>

  <!-- ── Alert Banner for Admin ─────────────────────── -->
  <div class="px-5 py-3 bg-brand-light/50 border-b border-brand/10 flex items-start gap-3">
     <div class="mt-0.5">
       <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
         <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
       </svg>
     </div>
     <div>
       <h4 class="text-sm font-extrabold text-slate-800">Admin Moderation Zone</h4>
       <p class="text-xs font-medium text-slate-500 mt-0.5 leading-relaxed">You are viewing this event with administrative privileges. Actions taken here are permanent.</p>
     </div>
  </div>

  <!-- ── Meta pills ──────────────────────────────────── -->
  <div class="fade-up px-5 pt-4 flex flex-wrap gap-2">
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full border border-slate-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span><%= event.event_date %></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full border border-slate-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span><%= event.start_time %> - <%= event.end_time || "Late" %></span>
    </span>
    <span class="flex items-center gap-1.5 text-xs font-semibold bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full border border-slate-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span><%= event.venue %></span>
    </span>
  </div>

  <!-- ── Tabs ─────────────────────────────────────────── -->
  <div class="slide-in mt-5 px-5">
    <div class="flex border-b border-gray-200 mb-4 overflow-x-auto no-scrollbar">
      <button id="tab-about" class="tab-btn active shrink-0 px-4 py-2.5 text-sm font-semibold text-center" onclick="switchTab(`about`)">Details</button>
      <button id="tab-announcements" class="tab-btn shrink-0 px-4 py-2.5 text-sm font-semibold text-gray-400 text-center" onclick="switchTab(`announcements`)">Updates</button>
      <button id="tab-comments" class="tab-btn shrink-0 px-4 py-2.5 text-sm font-semibold text-gray-400 text-center" onclick="switchTab(`comments`)">Feedback</button>
      <button id="tab-gallery" class="tab-btn shrink-0 px-4 py-2.5 text-sm font-semibold text-gray-400 text-center" onclick="switchTab(`gallery`)">Gallery</button>
      <button id="tab-organizer" class="tab-btn shrink-0 px-4 py-2.5 text-sm font-semibold text-gray-400 text-center" onclick="switchTab(`organizer`)">Organizer</button>
    </div>

    <!-- About -->
    <div id="tab-about-content" class="tab-content active pb-6">
      <div class="bg-slate-50 border border-slate-100 rounded-2xl p-4 mb-4">
        <div class="text-[10px] uppercase font-bold text-slate-400 tracking-widest mb-1.5">Description</div>
        <p class="text-sm text-slate-700 leading-relaxed whitespace-pre-line"><%= event.description || "No description provided." %></p>
      </div>
      
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-2">
        <span class="text-[11px] font-bold bg-slate-100 text-slate-500 px-3 py-1 rounded-full"><%= event.category ? event.category.name : "Category Placeholder" %></span>
        <span class="text-[11px] font-bold bg-brand-light text-brand-dark px-3 py-1 rounded-full">Visible to Public</span>
        <span class="text-[11px] font-bold bg-slate-100 text-slate-500 px-3 py-1 rounded-full"><%= event.is_ongoing ? "Active Status" : "Pending Scheduled" %></span>
      </div>
    </div>

    <!-- Announcements -->
    <div id="tab-announcements-content" class="tab-content pb-6">
      <div class="space-y-4">
        <% if (event.announcements && event.announcements.length > 0) { %>
          <% event.announcements.forEach(a => { %>
            <div class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm relative group">
              <h5 class="font-bold text-slate-900 text-sm mb-1"><%= a.title %></h5>
              <p class="text-xs text-slate-600 leading-relaxed mb-2"><%= a.body %></p>
              <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-50">
                <span class="text-[10px] font-bold text-slate-400 bg-slate-50 px-2 py-1 rounded"><%= new Date(a.created_at).toLocaleDateString() %></span>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="py-12 text-center bg-slate-50 rounded-2xl border border-dashed border-slate-200">
            <p class="text-xs font-bold text-slate-400">No announcements posted</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Feedback / Comments -->
    <div id="tab-comments-content" class="tab-content pb-6">
      <div class="space-y-6">
        <% if (event.comments && event.comments.length > 0) { %>
          <% event.comments.filter(c => !c.parent_comment_id).forEach(c => { %>
            <div class="relative pl-2">
              <div class="flex gap-3 mb-3">
                <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center shrink-0 border border-slate-200">
                  <span class="text-xs font-black text-slate-500 uppercase"><%= c.user ? c.user.first_name[0] : 'U' %></span>
                </div>
                <div class="flex-1 bg-white border border-slate-100 rounded-2xl rounded-tl-none p-3 shadow-sm relative group">
                  <div class="flex justify-between items-start mb-1">
                    <p class="text-[11px] font-black text-slate-900"><%= c.user ? (c.user.first_name + ' ' + c.user.last_name) : 'Anonymous' %></p>
                    <button onclick="deleteComment(<%= c.id %>)" class="opacity-0 group-hover:opacity-100 text-rose-500 hover:text-rose-700 transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    </button>
                  </div>
                  <p class="text-xs text-slate-600 mb-2"><%= c.content %></p>
                  <div class="flex items-center gap-3">
                    <span class="text-[9px] font-bold text-slate-400"><%= new Date(c.created_at).toLocaleDateString() %></span>
                    <button onclick="showReplyInput(<%= c.id %>)" class="text-[9px] font-black text-brand uppercase tracking-widest hover:underline">Reply</button>
                  </div>

                  <!-- Reply Input -->
                  <div id="reply-box-<%= c.id %>" class="hidden mt-3 pt-3 border-t border-slate-50">
                    <textarea id="reply-text-<%= c.id %>" class="w-full bg-slate-50 border-none rounded-xl p-2 text-xs focus:ring-1 focus:ring-brand mb-2" rows="2" placeholder="Write an official response..."></textarea>
                    <div class="flex justify-end gap-2">
                      <button onclick="hideReplyInput(<%= c.id %>)" class="text-[9px] font-bold text-slate-400 uppercase px-2 py-1">Cancel</button>
                      <button onclick="submitReply(<%= c.id %>)" class="bg-brand text-white text-[9px] font-black uppercase px-3 py-1 rounded-lg">Send</button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Replies -->
              <% if (c.replies && c.replies.length > 0) { %>
                <div class="ml-10 space-y-3 mt-3">
                  <% c.replies.forEach(r => { %>
                    <div class="flex gap-3">
                      <div class="w-8 h-8 rounded-lg <%= r.user_id === 1 ? 'bg-brand' : 'bg-slate-50' %> flex items-center justify-center shrink-0">
                        <% if(r.user_id === 1) { %>
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                        <% } else { %>
                          <span class="text-[10px] font-black text-slate-400 uppercase"><%= r.user ? r.user.first_name[0] : 'U' %></span>
                        <% } %>
                      </div>
                      <div class="flex-1 bg-slate-50 rounded-xl p-2.5 relative group">
                        <div class="flex justify-between items-start mb-0.5">
                          <p class="text-[10px] font-black <%= r.user_id === 1 ? 'text-brand' : 'text-slate-700' %>"><%= r.user_id === 1 ? 'System Administrator' : (r.user ? (r.user.first_name + ' ' + r.user.last_name) : 'Anonymous') %></p>
                          <button onclick="deleteComment(<%= r.id %>)" class="opacity-0 group-hover:opacity-100 text-rose-500 hover:text-rose-700 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                          </button>
                        </div>
                        <p class="text-xs text-slate-600"><%= r.content %></p>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="py-12 text-center bg-slate-50 rounded-2xl border border-dashed border-slate-200">
            <p class="text-xs font-bold text-slate-400">No community feedback yet</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Gallery -->
    <div id="tab-gallery-content" class="tab-content pb-6">
      <div class="grid grid-cols-2 gap-3">
        <% if (event.photos && event.photos.length > 0) { %>
          <% event.photos.forEach(p => { %>
            <div onclick="openPhotoFullscreen('<%= p.image_url %>', '<%= new Date(p.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) %>')" class="aspect-square rounded-2xl overflow-hidden bg-slate-100 border border-slate-100 relative group cursor-pointer">
              <img src="<%= p.image_url %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-2 py-12 text-center bg-slate-50 rounded-2xl border border-dashed border-slate-200">
            <p class="text-xs font-bold text-slate-400">No additional photos</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Organizer Info -->
    <div id="tab-organizer-content" class="tab-content pb-6">
      <div class="bg-white border border-slate-200 shadow-sm rounded-2xl p-4 flex items-start gap-4">
        <div class="w-14 h-14 rounded-2xl bg-indigo-100 flex items-center justify-center flex-shrink-0 border border-indigo-200">
          <span class="text-indigo-600 text-xl font-extrabold uppercase">
            <% if (event.organizer && event.organizer.name) { %>
              <%= event.organizer.name.charAt(0) %>
            <% } else { %>
              ?
            <% } %>
          </span>
        </div>
        <div class="flex-1">
          <p class="text-[10px] uppercase font-bold text-slate-400 tracking-widest mb-0.5">Event Organizer</p>
          <p class="text-base font-extrabold text-slate-900 leading-tight">
            <% if (event.organizer && event.organizer.name) { %>
                <%= event.organizer.name %>
            <% } else { %>
                Unknown Organizer
            <% } %>
          </p>
          <% if (event.organizer && event.organizer.description) { %>
             <p class="text-xs text-slate-500 mt-1.5 line-clamp-2"><%= event.organizer.description %></p>
          <% } else { %>
             <p class="text-xs text-slate-400 mt-1.5 italic">No profile description.</p>
          <% } %>
        </div>
      </div>
      
      <div class="mt-4 bg-slate-50 border border-slate-100 rounded-2xl p-4">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wider">Contact Log (Admin View)</span>
        </div>
        <p class="text-xs text-slate-600 italic">The organizer has agreed to the platform`s terms and conditions. The organizer user account allows editing of this event directly.</p>
      </div>
    </div>
  </div>

  <!-- ── Sticky CTA (Admin Mode) ──────────────────────────────────── -->
  <div class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-md bg-white/95 backdrop-blur-md border-t border-slate-200/80 px-5 py-4 flex gap-3 z-30" style="max-width:448px;">
    <button onclick="confirmTakedown()" class="w-full btn-ripple bg-rose-600 text-white font-bold py-3.5 rounded-2xl active:scale-95 transition-all shadow-lg shadow-rose-600/30 text-sm flex items-center justify-center gap-2 hover:bg-rose-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Takedown Event
    </button>
  </div>

  <!-- ── Takedown Confirmation Modal ────────────────── -->
  <div id="takedown-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-black/60 backdrop-blur-sm transition-all">
    <div class="bg-white w-full max-w-[320px] rounded-[32px] p-8 shadow-2xl animate-[slideDown_0.3s_ease-out] text-center">
      <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-rose-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">Takedown Event?</h3>
      <p class="text-sm text-gray-500 mb-8 leading-relaxed">
        Are you sure you want to permanently remove <span class="font-bold text-gray-800">"<%= event.title || event.name %>"</span> from the platform? This action cannot be undone.
      </p>
      <div class="flex flex-col gap-3">
        <button onclick="executeTakedown()" class="w-full bg-rose-600 text-white font-bold py-4 rounded-2xl hover:bg-rose-700 active:scale-[0.98] transition-all shadow-lg shadow-rose-200">Yes, Takedown Event</button>
        <button onclick="closeTakedownModal()" class="w-full bg-gray-100 text-gray-600 font-bold py-4 rounded-2xl hover:bg-gray-200 active:scale-[0.98] transition-all">Cancel</button>
      </div>
    </div>
  </div>

  <!-- ── Loading Overlay ───────────────────────────── -->
  <div id="loading-overlay" class="fixed inset-0 z-[110] hidden flex-col items-center justify-center bg-white/80 backdrop-blur-md transition-all">
    <div class="w-16 h-16 border-4 border-rose-100 border-t-rose-600 rounded-full animate-spin mb-4"></div>
    <p class="text-rose-600 font-bold text-sm tracking-widest uppercase animate-pulse">Taking Down Event...</p>
    <p class="text-gray-400 text-xs mt-2">Updating platform data</p>
  </div>

  <script>
    /* ── Tabs ── */
    function switchTab(name) {
      ["about", "announcements", "comments", "gallery", "organizer"].forEach(t => {
        const btn = document.getElementById(`tab-${t}`);
        const content = document.getElementById(`tab-${t}-content`);
        if (btn && content) {
          btn.classList.toggle("active", t === name);
          content.classList.toggle("active", t === name);
          if (t !== name) {
            btn.classList.remove("active");
            btn.classList.add("text-gray-400");
          } else {
            btn.classList.remove("text-gray-400");
          }
        }
      });
    }

    /* ── Moderation Functions ── */
    const eventId = '<%= event.id %>';

    function openPhotoFullscreen(url, date) {
        const modal = document.getElementById('photo-fullscreen-modal');
        const img = document.getElementById('fullscreen-img');
        const dateText = document.getElementById('photo-added-date');
        
        img.src = url;
        dateText.textContent = date;
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closePhotoFullscreen() {
        const modal = document.getElementById('photo-fullscreen-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }

    async function deleteComment(id) {
        if (!confirm('Permanently delete this comment?')) return;
        try {
            const response = await fetch(`/admin/events/${eventId}/comments/${id}`, { method: 'DELETE' });
            const result = await response.json();
            if (result.success) window.location.reload();
            else alert('Error: ' + result.message);
        } catch (e) { alert('Failed to delete comment'); }
    }

    function showReplyInput(id) {
        document.getElementById(`reply-box-${id}`).classList.remove('hidden');
    }

    function hideReplyInput(id) {
        document.getElementById(`reply-box-${id}`).classList.add('hidden');
    }

    async function submitReply(commentId) {
        const content = document.getElementById(`reply-text-${commentId}`).value.trim();
        if (!content) return alert('Reply content cannot be empty');

        try {
            const response = await fetch(`/admin/events/${eventId}/comments/${commentId}/reply`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ content })
            });
            const result = await response.json();
            if (result.success) window.location.reload();
            else alert('Error: ' + result.message);
        } catch (e) { alert('Failed to post reply'); }
    }

    /* ── Takedown Logic ── */
    const takedownModal = document.getElementById('takedown-modal');
    const loadingOverlay = document.getElementById('loading-overlay');

    function confirmTakedown() {
      takedownModal.classList.remove('hidden');
      takedownModal.classList.add('flex');
    }

    function closeTakedownModal() {
      takedownModal.classList.add('hidden');
      takedownModal.classList.remove('flex');
    }

    async function executeTakedown() {
      closeTakedownModal();
      loadingOverlay.classList.remove('hidden');
      loadingOverlay.classList.add('flex');

      try {
        const response = await fetch(`/admin/events/${eventId}/delete`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        const result = await response.json();

        if (result.success) {
          setTimeout(() => {
            window.location.href = '/admin/events?takedown=success';
          }, 800);
        } else {
          throw new Error(result.message || 'Failed to takedown event');
        }
      } catch (error) {
        loadingOverlay.classList.add('hidden');
        loadingOverlay.classList.remove('flex');
        alert('Error: ' + error.message);
      }
    }
  </script>

  <!-- Fullscreen Photo Modal -->
  <div id="photo-fullscreen-modal" class="fixed inset-0 z-[120] hidden items-center justify-center bg-black/95 backdrop-blur-xl transition-all p-4" onclick="closePhotoFullscreen()">
    <div class="relative max-w-4xl w-full h-full flex flex-col items-center justify-center" onclick="event.stopPropagation()">
        <button onclick="closePhotoFullscreen()" class="absolute top-0 right-0 p-4 text-white/50 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <div class="w-full h-full flex flex-col items-center justify-center">
            <img id="fullscreen-img" src="" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
            <div class="mt-8 text-center">
                <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.2em] mb-1">Upload Date</p>
                <p id="photo-added-date" class="text-white font-bold text-sm"></p>
            </div>
            <button onclick="closePhotoFullscreen()" class="mt-10 bg-white/10 hover:bg-white/20 text-white px-8 py-3 rounded-full font-black text-xs uppercase tracking-widest transition-all">Close Viewer</button>
        </div>
    </div>
  </div>
</body>
</html>