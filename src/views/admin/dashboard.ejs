              <path
                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
              ></path>
            </svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a
            href="/admin/organizers"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/activity"
            class="relative p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              />
            </svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a
            href="/admin/events"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </a>
          <a
            href="/admin/reports"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
          </a>
        </nav>
      </div>
      
    </aside>

    <!-- Mobile Bottom Tab Pane -->
    <div
      class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40"
    >
      <a
        href="/admin/dashboard"
        class="flex flex-col items-center gap-1 text-brand"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M11.293 3.293a1 1 0 011.414 0l7 7A1 1 0 0119 12h-1v7a1 1 0 01-1 1h-3a1 1 0 01-1-1v-3a1 1 0 00-1-1h-2a1 1 0 00-1 1v3a1 1 0 01-1 1H6a1 1 0 01-1-1v-7H4a1 1 0 01-.707-1.707l7-7z"
          />
        </svg>
      </a>
      <a
        href="/admin/organizers"
        class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
          />
        </svg>
      </a>
      <a
        href="/admin/activity"
        class="relative flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
          />
        </svg>
      
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-0 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="mobile-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
      <a
        href="/admin/events"
        class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          />
        </svg>
      </a>
      <a
        href="/admin/reports"
        class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
          />
        </svg>
      </a>
    </div>

    <!-- Main Content Wrapper -->
    <main class="max-w-2xl mx-auto p-6 md:py-10">
      <!-- Top Bar -->
      <header class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-3xl font-bold text-textMain tracking-tight">
            Hello,
          </h1>
          <h2 class="text-3xl font-extrabold text-textMain tracking-tight">
            System Admin!
          </h2>
        </div>
        <div class="flex gap-3">
          <a
            href="/admin/logout"
            class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-rose-500 shadow-sm border border-gray-100 hover:bg-rose-50 hover:border-rose-100 transition-all active:scale-95"
            title="Logout"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
              ></path>
            </svg>
          </a>
        </div>
      </header>

      <!-- Overview Stats Card -->
      <div
        class="bg-gradient-to-r from-[#EAE3FF] to-[#D7C9FF] rounded-3xl p-6 mb-8 relative overflow-hidden shadow-sm"
      >
        <div class="relative z-10">
          <div class="flex justify-between items-start mb-5">
            <div>
              <p class="text-brand-dark/70 text-sm font-semibold mb-1">
                Total System Events
              </p>
              <div class="text-4xl font-extrabold text-gray-900 tracking-tight">
                <%= totalEvents || 0 %>
              </div>
            </div>
          </div>
          <div class="flex gap-2 flex-wrap">
            <span
              class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur-sm text-brand-dark text-xs font-semibold px-3 py-1.5 rounded-full"
            >
              <span
                class="w-2 h-2 rounded-full bg-green-400 inline-block"
              ></span
              ><%= ongoingCount || 0 %> Ongoing
            </span>
            <span
              class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur-sm text-brand-dark text-xs font-semibold px-3 py-1.5 rounded-full"
            >
              <span class="w-2 h-2 rounded-full bg-brand inline-block"></span
              ><%= upcomingCount || 0 %> Upcoming
            </span>
          </div>
        </div>
        <div
          class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/20 rounded-full blur-2xl pointer-events-none"
        ></div>
        <div
          class="absolute -left-6 -top-6 w-28 h-28 bg-white/10 rounded-full blur-2xl pointer-events-none"
        ></div>
      </div>

      <!-- ===== ONGOING EVENTS ===== -->
      <div class="mb-10">
        <div class="flex justify-between items-center mb-5">
          <h3 class="text-xl font-extrabold text-gray-900 tracking-tight">Ongoing Events</h3>
          <a href="/admin/events" class="text-sm font-bold text-brand hover:text-brand-dark transition-colors px-3 py-1 bg-brand-light rounded-lg">View All</a>
        </div>
        <div class="grid grid-cols-1 gap-4">
          <% if(ongoingEvents && ongoingEvents.length > 0) { %>
            <% ongoingEvents.forEach(function(evt) { %>
            <div class="bg-white rounded-[2rem] p-5 shadow-sm border border-gray-100 card-hover cursor-pointer group" onclick="window.location.href='/admin/events/<%= evt.id %>'">
              <div class="flex items-center justify-between gap-4 mb-3">
                <div class="flex items-center gap-2">
                  <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                  <span class="text-[10px] font-black uppercase tracking-widest text-emerald-600">Active Now</span>
                </div>
                <div class="p-2 bg-emerald-50 rounded-xl text-emerald-600 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </div>
              </div>
              <h4 class="font-extrabold text-gray-900 text-base truncate mb-1 group-hover:text-brand transition-colors"><%= evt.title %></h4>
              <p class="text-xs font-bold text-gray-400 flex items-center gap-1.5 truncate">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <%= evt.venue || 'TBA' %>
              </p>
            </div>
            <% }); %>
          <% } else { %>
            <div class="py-12 bg-gray-50 rounded-[2rem] border border-dashed border-gray-200 text-center">
              <p class="text-sm font-bold text-gray-400">No ongoing events right now</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- ===== UPCOMING EVENTS ===== -->
      <div class="mb-10">
        <div class="flex justify-between items-center mb-5">
          <h3 class="text-xl font-extrabold text-gray-900 tracking-tight">Upcoming Events</h3>
          <a href="/admin/events" class="text-sm font-bold text-brand hover:text-brand-dark transition-colors px-3 py-1 bg-brand-light rounded-lg">See All</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% if(upcomingEvents && upcomingEvents.length > 0) { %>
            <% upcomingEvents.forEach(function(evt) { %>
            <div class="bg-white rounded-[2rem] p-5 shadow-sm border border-gray-100 card-hover relative overflow-hidden cursor-pointer group" onclick="window.location.href='/admin/events/<%= evt.id %>'">
              <div class="absolute top-0 right-0 w-24 h-24 bg-pink-50 rounded-full -mr-12 -mt-12 group-hover:bg-pink-100 transition-colors"></div>
              <div class="relative z-10">
                <div class="inline-block px-2.5 py-1 rounded-lg bg-pink-50 text-pink-500 text-[10px] font-black uppercase tracking-widest mb-3 border border-pink-100">
                  <%= evt.category ? evt.category.name : 'Event' %>
                </div>
                <h4 class="font-extrabold text-gray-900 text-sm truncate mb-3 group-hover:text-brand transition-colors"><%= evt.title %></h4>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center gap-2 text-[11px] font-bold text-gray-400 truncate">
                    <div class="w-7 h-7 rounded-lg bg-gray-50 flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    </div>
                    <%= new Date(evt.event_date).toLocaleDateString([], {month:'short', day:'numeric', year:'numeric'}) %>
                  </div>
                  <div class="flex items-center gap-2 text-[11px] font-bold text-gray-400 truncate">
                    <div class="w-7 h-7 rounded-lg bg-gray-50 flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </div>
                    <%= evt.venue || 'TBA' %>
                  </div>
                </div>
              </div>
            </div>
            <% }); %>
          <% } else { %>
            <div class="col-span-full py-12 bg-gray-50 rounded-[2rem] border border-dashed border-gray-200 text-center">
              <p class="text-sm font-bold text-gray-400">No upcoming events scheduled</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- ===== MOST VISITED EVENTS ===== -->
      <div class="mb-10">
        <div class="flex justify-between items-center mb-5">
          <h3 class="text-xl font-extrabold text-gray-900 tracking-tight">Most Visited</h3>
          <a href="/admin/reports" class="text-sm font-bold text-brand hover:text-brand-dark transition-colors px-3 py-1 bg-brand-light rounded-lg">Full Report</a>
        </div>
        <div class="flex flex-col gap-4">
          <% if(mostVisitedEvents && mostVisitedEvents.length > 0) { %>
            <% mostVisitedEvents.forEach(function(evt) { %>
            <div class="bg-white rounded-[2rem] p-5 shadow-sm border border-gray-100 flex items-center justify-between gap-4 card-hover cursor-pointer group" onclick="window.location.href='/admin/events/<%= evt.id %>'">
              <div class="flex-1 min-w-0">
                <h4 class="font-extrabold text-gray-900 text-sm truncate mb-1 group-hover:text-brand transition-colors"><%= evt.title %></h4>
                <p class="text-xs font-bold text-gray-400 truncate flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  <%= evt.venue || 'TBA' %>
                </p>
              </div>
              <div class="flex items-center gap-4 bg-gray-50 py-2.5 px-4 rounded-2xl border border-gray-100 shrink-0">
                <div class="text-center">
                  <p class="font-black text-gray-900 text-xl leading-none"><%= evt.analytics ? evt.analytics.page_view_count : 0 %></p>
                  <p class="text-[9px] font-black text-brand uppercase tracking-tighter mt-1">Visits</p>
                </div>
              </div>
            </div>
            <% }); %>
          <% } else { %>
            <div class="py-12 bg-gray-50 rounded-[2rem] border border-dashed border-gray-200 text-center">
              <p class="text-sm font-bold text-gray-400">No popular events data available</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Recent Activities -->
      <div class="mb-10">
        <div class="flex justify-between items-center mb-5">
          <h3 class="text-xl font-extrabold text-gray-900 tracking-tight">Recent Activities</h3>
          <a href="/admin/activity" class="text-sm font-bold text-brand hover:text-brand-dark transition-colors px-3 py-1 bg-brand-light rounded-lg">Logs</a>
        </div>
        <div class="bg-white rounded-[2rem] p-3 shadow-sm border border-gray-100">
          <% if(recentActivities && recentActivities.length > 0) { %>
            <% recentActivities.forEach(function(act, idx) { %>
            <div class="flex items-center justify-between p-4 rounded-2xl hover:bg-gray-50 transition-all cursor-pointer group <%= idx !== recentActivities.length -1 ? 'mb-1' : '' %>">
              <div class="flex items-center gap-4 min-w-0">
                <div class="w-10 h-10 rounded-xl bg-brand-light text-brand flex items-center justify-center shrink-0 font-black text-xs">
                  <%= act.activity_type ? act.activity_type.charAt(0) : 'S' %>
                </div>
                <div class="min-w-0">
                  <p class="font-extrabold text-gray-900 text-sm truncate group-hover:text-brand transition-colors"><%= act.activity_type ? act.activity_type.replace(/_/g, ' ') : 'System Action' %></p>
                  <p class="text-[10px] font-bold text-gray-400 mt-0.5"><%= new Date(act.occurred_at).toLocaleString([], {month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'}) %></p>
                </div>
              </div>
              <div class="text-right shrink-0 ml-4">
                <span class="text-[10px] font-black uppercase tracking-widest text-gray-400 group-hover:text-brand-dark transition-colors"><%= act.organizer_actor ? act.organizer_actor.name : 'System' %></span>
              </div>
            </div>
            <% }); %>
          <% } else { %>
            <div class="p-8 text-center">
              <p class="text-sm font-bold text-gray-400">No recent activity found</p>
            </div>
          <% } %>
        </div>
      </div>
    </main>

    <script>
      function toggleNotif() {
        const overlay = document.getElementById("notif-overlay");
        overlay.classList.toggle("active");
      }

      function closeNotifOnOverlay(e) {
        if (e.target === document.getElementById("notif-overlay")) {
          document.getElementById("notif-overlay").classList.remove("active");
        }
      }

      function markAllRead() {
        document.querySelectorAll(".notif-item.unread").forEach((el) => {
          el.classList.remove("unread");
          const dot = el.querySelector(".notif-dot");
          if (dot) dot.remove();
        });
        document.getElementById("notif-badge").style.display = "none";
        document.querySelector(
          '#notif-modal p[style*="color: #6B7280"]',
        ).textContent = "All caught up";
      }

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          document.getElementById("notif-overlay").classList.remove("active");
        }
      });
    </script>
  </body>
</html>
