      <!-- Overview Stats Card -->
      <div class="bg-gradient-to-r from-[#EAE3FF] to-[#D7C9FF] rounded-3xl p-6 mb-8 relative overflow-hidden shadow-sm">
        <div class="relative z-10">
          <div class="flex justify-between items-start mb-5">
            <div>
              <p class="text-brand-dark/70 text-sm font-semibold mb-1">Total System Events</p>
              <div class="text-4xl font-extrabold text-gray-900 tracking-tight"><%= locals.totalEvents || '1,452' %></div>
            </div>
          </div>
          <div class="flex gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur-sm text-brand-dark text-xs font-semibold px-3 py-1.5 rounded-full">
              <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>38 Ongoing
            </span>
            <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur-sm text-brand-dark text-xs font-semibold px-3 py-1.5 rounded-full">
              <span class="w-2 h-2 rounded-full bg-brand inline-block"></span>124 Upcoming
            </span>
          </div>
        </div>
        <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/20 rounded-full blur-2xl pointer-events-none"></div>
        <div class="absolute -left-6 -top-6 w-28 h-28 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
      </div>

      <!-- ===== ONGOING EVENTS ===== -->
      <div class="mb-8">
        <div class="flex justify-between items-center mb-4">
          <div class="flex items-center gap-2">
            <h3 class="text-lg font-bold">Ongoing Events</h3>
          </div>
          <a href="/admin/events" class="text-sm font-medium text-textMuted hover:text-brand">See all</a>
        </div>

        <div class="flex flex-col gap-3">
