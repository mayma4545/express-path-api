<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: { light: "#E9E4FF", DEFAULT: "#1DA1F2", dark: "#5A26ED" },
              bgWhite: "#FFFFFF",
              bgLight: "#F8F9FE",
              textMain: "#111827",
              textMuted: "#6B7280",
            },
            fontFamily: { sans: ["Plus Jakarta Sans", "sans-serif"] },
            boxShadow: {
              soft: "0 4px 20px -2px rgba(0, 0, 0, 0.05)",
              float: "0 8px 16px -4px rgba(124, 67, 254, 0.4)",
            },
          },
        },
      };
    </script>
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background-color: #f8f9fe;
        -webkit-tap-highlight-color: transparent;
      }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

      @keyframes fillBar {
        from { width: 0%; }
        to { width: var(--fill); }
      }
      .progress-fill {
        animation: fillBar 1.2s ease-out forwards;
        animation-delay: 0.4s;
        width: 0%;
      }

      .card-hover {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 28px -8px rgba(124, 67, 254, 0.15);
      }

      /* Notification Modal */
      #notif-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 100;
        background: rgba(0,0,0,0.25);
        backdrop-filter: blur(2px);
        animation: fadeIn 0.15s ease;
      }
      #notif-overlay.active { display: flex; }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
      }

      #notif-modal {
        position: absolute;
        top: 76px;
        right: 24px;
        width: 360px;
        max-height: 520px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px -10px rgba(0,0,0,0.18), 0 0 0 1px rgba(0,0,0,0.05);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: slideDown 0.2s ease;
      }

      @media (max-width: 768px) {
        #notif-modal {
          right: 16px;
          width: calc(100vw - 32px);
          top: 72px;
        }
      }

      .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        cursor: pointer;
        transition: background 0.15s;
        border-bottom: 1px solid #f3f4f6;
      }
      .notif-item:last-child { border-bottom: none; }
      .notif-item:hover { background: #f9fafb; }
      .notif-item.unread { background: #f5f3ff; }
      .notif-item.unread:hover { background: #ede9fe; }

      .notif-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 15px;
        flex-shrink: 0;
        color: #fff;
      }

      .notif-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #5A26ED;
        flex-shrink: 0;
        margin-top: 6px;
      }

      .notif-list {
        overflow-y: auto;
        flex: 1;
      }
      .notif-list::-webkit-scrollbar { width: 4px; }
      .notif-list::-webkit-scrollbar-track { background: transparent; }
      .notif-list::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 4px; }
    </style>
  </head>
  <body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">

    <!-- ===== NOTIFICATION OVERLAY ===== -->
    <div id="notif-overlay" onclick="closeNotifOnOverlay(event)">
      <div id="notif-modal">
        <!-- Modal Header -->
        <div style="padding: 16px 16px 12px; border-bottom: 1px solid #f3f4f6; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <p style="font-size: 15px; font-weight: 700; color: #111827; margin: 0;">Notifications</p>
            <p style="font-size: 12px; color: #6B7280; margin: 2px 0 0;">3 unread</p>
          </div>
          <button onclick="markAllRead()" style="font-size: 11px; font-weight: 600; color: #5A26ED; background: #EDE9FE; border: none; border-radius: 20px; padding: 5px 12px; cursor: pointer;">Mark all read</button>
        </div>

        <!-- Notification List -->
        <div class="notif-list">

          <!-- Notif 1 — Unread -->
          <div class="notif-item unread">
            <div class="notif-avatar" style="background: linear-gradient(135deg, #1DA1F2, #9333ea);">J</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
                  <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 0;">James Rivera</p>
                  <p style="font-size: 12px; color: #374151; margin: 3px 0 4px; line-height: 1.4;">Created <span style="font-weight: 600; color: #5A26ED;">Tech Summit 2026</span></p>
                  <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                    <span style="font-size: 10px; background: #EDE9FE; color: #5A26ED; border-radius: 20px; padding: 2px 8px; font-weight: 600;">Apr 25, 2026</span>
                    <span style="font-size: 10px; color: #9CA3AF;">Main Auditorium</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;">
                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">Just Now</span>
                  <div class="notif-dot"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Notif 2 — Unread -->
          <div class="notif-item unread">
            <div class="notif-avatar" style="background: linear-gradient(135deg, #f97316, #ec4899);">S</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
                  <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 0;">Sofia Mendes</p>
                  <p style="font-size: 12px; color: #374151; margin: 3px 0 4px; line-height: 1.4;">Created <span style="font-weight: 600; color: #5A26ED;">Design Workshop</span></p>
                  <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                    <span style="font-size: 10px; background: #FFF7ED; color: #ea580c; border-radius: 20px; padding: 2px 8px; font-weight: 600;">May 2, 2026</span>
                    <span style="font-size: 10px; color: #9CA3AF;">Studio B</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;">
                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">1m ago</span>
                  <div class="notif-dot"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Notif 3 — Unread -->
