<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#E9E4FF', DEFAULT: '#7C43FE', dark: '#5A26ED' },
            bgWhite: '#FFFFFF',
            bgLight: '#F8F9FE',
            textMain: '#111827',
            textMuted: '#6B7280'
          }, 
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(124, 67, 254, 0.4)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8F9FE; -webkit-tap-highlight-color: transparent; }
    /* Hide scrollbar for clean horizontal scrolling */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .floating-btn { bottom: 1.5rem; transform: translateY(-30%); z-index: 50; }
  </style>
</head>
<body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">

  <!-- Desktop Sidebar (Icon only for larger screens to mimic tab pane) -->
  <aside class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft">
    <div class="flex flex-col gap-8 items-center">
      <div class="w-10 h-10 rounded-xl bg-brand font-bold text-white flex items-center justify-center text-xl shadow-float">E</div>
      <nav class="flex flex-col gap-6">
        <a href="/admin/dashboard" class="p-3 rounded-xl bg-brand-light text-brand"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg></a>
        <a href="/admin/organizers" class="p-3 rounded-xl text-textMuted hover:bg-gray-50"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg></a>
        <a href="/admin/events" class="p-3 rounded-xl text-textMuted hover:bg-gray-50"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg></a>
      </nav>
    </div>
    <div class="p-3 rounded-xl text-textMuted hover:bg-gray-50 cursor-pointer">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
    </div>
  </aside>

  <!-- Mobile Bottom Tab Pane (Fixed at Bottom) -->
  <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40">
    <a href="/admin/dashboard" class="flex flex-col items-center gap-1 text-brand">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
    </a>
    <a href="/admin/organizers" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
    </a>

    <a href="/admin/events" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
    </a>
    <a href="#" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
    </a>
  </div>

  <!-- Main Content Wrapper -->
  <main class="max-w-2xl mx-auto p-6 md:py-10">
    
    <!-- Top Bar -->
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-textMain tracking-tight">Hello,</h1>
        <h2 class="text-3xl font-extrabold text-textMain tracking-tight">System Admin!</h2>
      </div>
      <div class="flex gap-3">
        <button class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-textMain shadow-sm border border-gray-100 hover:bg-gray-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <button class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-textMain shadow-sm border border-gray-100 hover:bg-gray-50 relative">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
          <span class="absolute top-2 right-2.5 w-2 h-2 rounded-full bg-red-500 border border-white"></span>
        </button>
      </div>
    </header>

    <!-- System Overview Cards -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      
      <!-- Total Events -->
      <div class="bg-gradient-to-br from-brand to-brand-dark rounded-3xl p-5 relative overflow-hidden shadow-float cursor-pointer hover:scale-[1.02] transition">
        <div class="relative z-10">
          <p class="text-white/80 text-sm font-semibold mb-1">Events</p>
          <div class="text-3xl font-extrabold text-white tracking-tight"><%= locals.totalEvents || '0' %></div>
        </div>
        <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-white/10 rounded-full blur-[10px]"></div>
      </div>

      <!-- Total Organizers -->
      <div class="bg-white rounded-3xl p-5 border border-gray-100 shadow-sm relative overflow-hidden cursor-pointer hover:scale-[1.02] transition">
        <div class="relative z-10">
          <p class="text-textMuted text-sm font-semibold mb-1">Organizers</p>
          <div class="text-3xl font-extrabold text-textMain tracking-tight"><%= locals.totalOrganizers || '0' %></div>
        </div>
      </div>

      <!-- Total Users -->
      <div class="bg-white rounded-3xl p-5 border border-gray-100 shadow-sm relative overflow-hidden cursor-pointer hover:scale-[1.02] transition">
        <div class="relative z-10">
          <p class="text-textMuted text-sm font-semibold mb-1">App Users</p>
          <div class="text-3xl font-extrabold text-textMain tracking-tight"><%= locals.totalUsers || '0' %></div>
        </div>
      </div>

      <!-- Total Categories -->
      <div class="bg-gradient-to-r from-[#EAE3FF] to-[#D7C9FF] rounded-3xl p-5 relative overflow-hidden shadow-sm cursor-pointer hover:scale-[1.02] transition">
        <div class="relative z-10">
          <p class="text-brand-dark/70 text-sm font-semibold mb-1">Categories</p>
          <div class="text-3xl font-extrabold text-gray-900 tracking-tight"><%= locals.totalCategories || '0' %></div>
        </div>
        <div class="absolute -right-8 -bottom-8 w-24 h-24 bg-white/30 rounded-full blur-xl"></div>
      </div>

    </div>

    <!-- Upcoming / Pending Review horizontally scrollable area -->
    <div class="mb-8">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-bold">Upcoming Events</h3>
        <a href="/admin/events" class="text-sm font-medium text-textMuted hover:text-brand">See all</a>
      </div>
      <div class="flex gap-4 overflow-x-auto no-scrollbar pb-2 -mx-6 px-6 md:mx-0 md:px-0 scroll-smooth">
        <% if (locals.upcomingEvents && upcomingEvents.length > 0) { %>
          <% upcomingEvents.forEach((event, index) => { %>
            <% const isBrand = index % 2 === 0; %>
            <div class="min-w-[150px] <%= isBrand ? 'bg-brand' : 'bg-white border border-gray-100' %> rounded-3xl p-5 <%= isBrand ? 'text-white shadow-float' : 'shadow-sm' %> relative overflow-hidden group hover:scale-[1.02] transition-transform cursor-pointer">
              <div class="flex justify-between items-start mb-4 relative z-10">
                <div class="w-10 h-10 rounded-xl <%= isBrand ? 'bg-white text-brand' : 'bg-gray-50 text-textMain' %> flex items-center justify-center font-bold text-xl"><%= event.title.charAt(0).toUpperCase() %></div>
                <button class="<%= isBrand ? 'text-white/80 hover:text-white' : 'text-gray-400 hover:text-gray-600' %>"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path></svg></button>
              </div>
              <div class="relative z-10">
                <h4 class="font-bold <%= isBrand ? 'text-white' : 'text-textMain' %> mb-1 truncate w-28" title="<%= event.title %>"><%= event.title %></h4>
                <p class="<%= isBrand ? 'text-white/80' : 'text-textMuted' %> text-xs font-medium mb-3 truncate w-28" title="<%= event.venue %>"><%= event.venue %></p>
                <% 
                  const eventDate = new Date(event.event_date);
                  const today = new Date();
                  today.setHours(0,0,0,0);
                  const diffTime = Math.abs(eventDate - today);
                  let daysLeft = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                  if (eventDate < today) daysLeft = 0;
                %>
                <p class="<%= isBrand ? 'text-white/60' : 'text-textMuted' %> text-[10px]"><%= daysLeft === 0 ? 'Today' : daysLeft + ' days left' %></p>
              </div>
              <% if (isBrand) { %>
                <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-white/10 rounded-full blur-[10px]"></div>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="text-sm text-textMuted w-full py-4 text-center">No upcoming events scheduled.</div>
        <% } %>
      </div>
    </div>

    <!-- Recent Transactions / Activities -->
    <div>
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-bold">Recent Activities</h3>
        <a href="#" class="text-sm font-medium text-textMuted hover:text-brand">See all</a>
      </div>
      <div class="bg-white rounded-3xl p-2 shadow-sm border border-gray-50">
        <% if (locals.activities && activities.length > 0) { %>
          <% activities.forEach((activity, index) => { %>
            <div class="flex items-center justify-between p-3 rounded-2xl hover:bg-gray-50 transition cursor-pointer <%= index > 0 ? 'border-t border-gray-50' : '' %>">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl <%= activity.bgColor %> flex items-center justify-center <%= activity.textColor %> font-bold">
                  <%= activity.icon %>
                </div>
                <div>
                  <p class="font-bold text-textMain text-sm truncate w-40" title="<%= activity.title %>"><%= activity.title %></p>
                  <p class="text-xs text-textMuted mt-0.5 truncate w-40" title="<%= activity.subtitle %>">
                    <% 
                      const dateObj = new Date(activity.date); 
                      const day = ("0" + dateObj.getDate()).slice(-2);
                      const monthStr = dateObj.toLocaleString('en-US', { month: 'short' });
                      const hours = dateObj.getHours();
                      const ampm = hours >= 12 ? 'PM' : 'AM';
                      const formattedHours = ("0" + (hours % 12 || 12)).slice(-2);
                      const minutes = ("0" + dateObj.getMinutes()).slice(-2);
                      const displayDate = `${day} ${monthStr}, ${formattedHours}:${minutes} ${ampm}`;
                    %>
                    <%= displayDate %>
                  </p>
                </div>
              </div>
              <div class="text-right">
                <span class="text-sm font-bold <%= activity.textColor %>"><%= activity.value %></span>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="p-4 text-center text-sm text-textMuted">No recent activities found.</div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
             
             