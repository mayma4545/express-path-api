            <div class="notif-avatar" style="background: linear-gradient(135deg, #14b8a6, #06b6d4);">A</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
