                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">3m ago</span>
                  <div class="notif-dot"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Notif 4 — Read -->
          <div class="notif-item">
            <div class="notif-avatar" style="background: #111827;">M</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
                  <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 0;">Maya Patel</p>
                  <p style="font-size: 12px; color: #374151; margin: 3px 0 4px; line-height: 1.4;">Created <span style="font-weight: 600; color: #374151;">Startup Pitch Night</span></p>
                  <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                    <span style="font-size: 10px; background: #f3f4f6; color: #6B7280; border-radius: 20px; padding: 2px 8px; font-weight: 600;">May 15, 2026</span>
                    <span style="font-size: 10px; color: #9CA3AF;">Hall D</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;">
                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">18m ago</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Notif 5 — Read -->
          <div class="notif-item">
            <div class="notif-avatar" style="background: linear-gradient(135deg, #14b8a6, #06b6d4);">L</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
                  <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 0;">Lena Strauss</p>
                  <p style="font-size: 12px; color: #374151; margin: 3px 0 4px; line-height: 1.4;">Created <span style="font-weight: 600; color: #374151;">Wellness Summit</span></p>
                  <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                    <span style="font-size: 10px; background: #f3f4f6; color: #6B7280; border-radius: 20px; padding: 2px 8px; font-weight: 600;">May 20, 2026</span>
                    <span style="font-size: 10px; color: #9CA3AF;">Rooftop Terrace</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;">
                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">1h ago</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Notif 6 — Read -->
          <div class="notif-item">
            <div class="notif-avatar" style="background: linear-gradient(135deg, #8b5cf6, #6366f1);">R</div>
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                <div style="flex: 1;">
                  <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 0;">Ryan Cole</p>
                  <p style="font-size: 12px; color: #374151; margin: 3px 0 4px; line-height: 1.4;">Created <span style="font-weight: 600; color: #374151;">VIP Meetup</span></p>
                  <div style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;">
                    <span style="font-size: 10px; background: #f3f4f6; color: #6B7280; border-radius: 20px; padding: 2px 8px; font-weight: 600;">Apr 20, 2026</span>
                    <span style="font-size: 10px; color: #9CA3AF;">Room 401</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px; flex-shrink: 0;">
                  <span style="font-size: 10px; color: #9CA3AF; white-space: nowrap;">2h ago</span>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Modal Footer -->
        <div style="padding: 12px 16px; border-top: 1px solid #f3f4f6; text-align: center;">
          <a href="/admin/activity" style="font-size: 12px; font-weight: 600; color: #5A26ED; text-decoration: none;">View all activity</a>
        </div>
      </div>
    </div>

    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft">
      <div class="flex flex-col gap-8 items-center">
        <div class="w-10 h-10 rounded-xl bg-brand font-bold text-white flex items-center justify-center text-xl shadow-float">E</div>
        <nav class="flex flex-col gap-6">
          <a href="/admin/dashboard" class="p-3 rounded-xl bg-brand-light text-brand">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
