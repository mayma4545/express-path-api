<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: { light: "#E9E4FF", DEFAULT: "#1DA1F2", dark: "#5A26ED" },
              bgWhite: "#FFFFFF", bgLight: "#F8F9FE",
              textMain: "#111827", textMuted: "#6B7280",
            },
            fontFamily: { sans: ["Plus Jakarta Sans", "sans-serif"] },
            boxShadow: {
              soft: "0 4px 20px -2px rgba(0, 0, 0, 0.05)",
              float: "0 8px 16px -4px rgba(124, 67, 254, 0.4)",
            },
          },
        },
      };
    </script>
    <style>
      body { font-family: "Plus Jakarta Sans", sans-serif; background-color: #f8f9fe; -webkit-tap-highlight-color: transparent; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

      .search-wrapper {
        padding: 12px 16px 0;
      }
      .search-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
      }
      .search-icon {
        position: absolute;
        left: 12px;
        width: 16px;
        height: 16px;
        stroke: #9ca3af;
        pointer-events: none;
        flex-shrink: 0;
      }
      .search-input {
        width: 100%;
        padding: 10px 36px 10px 36px;
        border-radius: 14px;
        border: 1.5px solid #e5e7eb;
        background: white;
        font-size: 13px;
        font-family: "Plus Jakarta Sans", sans-serif;
        color: #111827;
        outline: none;
        transition: border-color 0.15s ease;
        box-sizing: border-box;
      }
      .search-input::placeholder { color: #9ca3af; }
      .search-input:focus { border-color: #1da1f2; }
      .search-clear {
        position: absolute;
        right: 10px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #e5e7eb;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 0;
        font-family: "Plus Jakarta Sans", sans-serif;
      }
      .search-clear svg { width: 10px; height: 10px; stroke: #6b7280; }
      .search-clear.visible { display: flex; }

      .filter-tabs { display: flex; gap: 8px; padding: 14px 16px 0; overflow-x: auto; }
      .filter-tabs::-webkit-scrollbar { display: none; }
      .tab { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; border: none; cursor: pointer; white-space: nowrap; font-family: "Plus Jakarta Sans", sans-serif; transition: all 0.15s ease; }
      .tab.active { background: #1da1f2; color: white; }
      .tab:not(.active) { background: white; color: #6b7280; border: 1px solid #e5e7eb; }

      .section-header { display: flex; justify-content: space-between; align-items: center; padding: 4px 16px 8px; }
      .section-title { font-size: 14px; font-weight: 700; color: #111827; }
      .see-all { font-size: 12px; color: #1da1f2; font-weight: 600; background: none; border: none; cursor: pointer; font-family: "Plus Jakarta Sans", sans-serif; }

      .log-list { padding: 0 16px; display: flex; flex-direction: column; gap: 8px; }
      .log-item { background: white; border-radius: 18px; padding: 12px 14px; display: flex; align-items: center; gap: 12px; animation: fadeSlideIn 0.2s ease both; }
      @keyframes fadeSlideIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
      .log-icon { width: 44px; height: 44px; border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .log-icon svg { width: 20px; height: 20px; }
      .icon-blue { background: #e8f5fe; } .icon-blue svg { stroke: #1da1f2; }
      .icon-red { background: #fee8e8; } .icon-red svg { stroke: #ef4444; }
      .icon-green { background: #e8fef0; } .icon-green svg { stroke: #22c55e; }
      .icon-gray { background: #f3f4f6; } .icon-gray svg { stroke: #6b7280; }
      .icon-amber { background: #fef7e8; } .icon-amber svg { stroke: #f59e0b; }

      .log-body { flex: 1; min-width: 0; }
      .log-title { font-size: 13px; font-weight: 700; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .log-sub { font-size: 11px; color: #9ca3af; margin-top: 2px; }
      .log-right { text-align: right; flex-shrink: 0; }
      .log-badge { font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 20px; }
      .badge-blue { background: #e8f5fe; color: #1da1f2; }
      .badge-red { background: #fee8e8; color: #ef4444; }
      .badge-green { background: #e8fef0; color: #22c55e; }
      .badge-gray { background: #f3f4f6; color: #6b7280; }
      .badge-amber { background: #fef7e8; color: #f59e0b; }
      .log-time { font-size: 10px; color: #9ca3af; margin-top: 3px; }

      .day-label { padding: 10px 16px 4px; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.06em; }

      .pagination-wrapper { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px 4px; gap: 8px; }
      .pagination-info { font-size: 11px; color: #9ca3af; font-weight: 600; }
      .pagination-controls { display: flex; align-items: center; gap: 4px; }
      .page-btn { width: 30px; height: 30px; border-radius: 10px; border: 1px solid #e5e7eb; background: white; font-size: 12px; font-weight: 700; color: #6b7280; cursor: pointer; display: flex; align-items: center; justify-content: center; font-family: "Plus Jakarta Sans", sans-serif; transition: all 0.15s ease; }
      .page-btn:hover:not(:disabled) { border-color: #1da1f2; color: #1da1f2; }
      .page-btn.active { background: #1da1f2; border-color: #1da1f2; color: white; }
      .page-btn:disabled { opacity: 0.35; cursor: default; }
      .page-btn svg { width: 14px; height: 14px; stroke: currentColor; }

      .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: white; padding: 12px 24px 16px; display: flex; justify-content: space-around; align-items: center; border-top: 1px solid #f0f0f0; border-radius: 24px 24px 0 0; max-width: 380px; margin: 0 auto; box-shadow: 0 -4px 20px rgba(0,0,0,0.06); }
    </style>
  </head>
  <body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">
    <aside class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft">
      <div class="flex flex-col gap-8 items-center">
        <nav class="flex flex-col gap-6">
          <a href="/admin/dashboard" class="p-3 rounded-xl bg-brand-light text-brand">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
          </a>
          <a href="/admin/organizers" class="p-3 rounded-xl text-textMuted hover:bg-gray-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
          </a>
          <a href="/admin/activity" class="relative p-3 rounded-xl text-textMuted hover:bg-gray-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a href="/admin/events" class="p-3 rounded-xl text-textMuted hover:bg-gray-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </a>
          <a href="/admin/reports" class="p-3 rounded-xl text-textMuted hover:bg-gray-50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </a>
        </nav>
      </div>
    </aside>

    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40">
      <a href="/admin/dashboard" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.293 3.293a1 1 0 011.414 0l7 7A1 1 0 0119 12h-1v7a1 1 0 01-1 1h-3a1 1 0 01-1-1v-3a1 1 0 00-1-1h-2a1 1 0 00-1 1v3a1 1 0 01-1 1H6a1 1 0 01-1-1v-7H4a1 1 0 01-.707-1.707l7-7z"/></svg>
      </a>
      <a href="/admin/organizers" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </a>
      <a href="/admin/activity" class="relative flex flex-col items-center gap-1 text-brand">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-0 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="mobile-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
      <a href="/admin/events" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
      <a href="/admin/reports" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </a>
    </div>

    <main class="max-w-2xl mx-auto md:py-10">
      <header class="flex justify-between items-center p-6 pb-0 mb-8">
        <div>
          <h2 class="text-3xl font-extrabold text-textMain tracking-tight">Activity Log</h2>
        </div>
      </header>

      <div class="section-header pb-0">
        <span class="section-title">Organizers</span>
      </div>

      <!-- Search Bar -->
      <div class="search-wrapper">
        <div class="search-input-wrap">
          <svg class="search-icon" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
          </svg>
          <input
            id="organizer-search"
            class="search-input"
            type="text"
            placeholder="Search Organizer..."
            oninput="handleSearch(this)"
            autocomplete="off"
          />
          <button class="search-clear" id="search-clear" onclick="clearSearch()" title="Clear">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Filter Tabs -->
      <div class="filter-tabs pb-3">
        <button class="tab active" onclick="filterByOrganizer(this, 'all')">All</button>
        <button class="tab" onclick="filterByOrganizer(this, 'Baby')">Baby</button>
        <button class="tab" onclick="filterByOrganizer(this, 'Hannah')">Hannah</button>
        <button class="tab" onclick="filterByOrganizer(this, 'Denielle')">Denielle</button>
        <button class="tab" onclick="filterByOrganizer(this, 'Pimentel')">Pimentel</button>
        <button class="tab" onclick="filterByOrganizer(this, 'Teodoro')">Teodoro</button>
      </div>

      <div id="log-container"></div>

      <div class="pagination-wrapper" id="pagination-wrapper">
        <span class="pagination-info" id="pagination-info"></span>
        <div class="pagination-controls" id="pagination-controls"></div>
      </div>

      <div style="height: 16px"></div>
    </main>

    <script>
      const ALL_LOGS = <%- JSON.stringify(locals.activities ? locals.activities.map(a => {
        let icon = 'calendar';
        let iconClass = 'icon-blue';
        let badgeClass = 'badge-blue';
        
        let type = a.activity_type || 'System Action';
        let title = type.replace(/_/g, ' ');
        
        let extraInfo = '';
        if (a.metadata && a.metadata.title) {
            extraInfo = ' · ' + a.metadata.title;
        } else if (a.target_type === 'Event' && a.target_id) {
            extraInfo = ' · Event ID ' + a.target_id;
        }
        let sub = (a.organizer_actor ? a.organizer_actor.name : 'System') + extraInfo;

        let badge = a.target_type || 'Action';
        
        if (title.includes('CANCEL') || title.includes('DELETE') || title.includes('REJECT')) {
            icon = 'cancel'; iconClass = 'icon-red'; badgeClass = 'badge-red';
        } else if (title.includes('WARN') || title.includes('FLAG') || title.includes('ERROR')) {
            icon = 'warn'; iconClass = 'icon-amber'; badgeClass = 'badge-amber';
        } else if (title.includes('APPROVE') || title.includes('VERIFY') || title.includes('CREATE')) {
            icon = 'check'; iconClass = 'icon-green'; badgeClass = 'badge-green';
        } else if (title.includes('USER') || title.includes('LOGIN')) {
            icon = 'user';
        }
        
        let dateObj = new Date(a.occurred_at);
        let today = new Date();
        let yesterday = new Date(today);
        yesterday.setDate(yesterday.getDate() - 1);
        
        let day;
        if (dateObj.toDateString() === today.toDateString()) {
            day = 'Today';
        } else if (dateObj.toDateString() === yesterday.toDateString()) {
            day = 'Yesterday';
        } else {
            day = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }
        
        let time = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        let organizer = a.organizer_actor ? a.organizer_actor.name : 'System';
        
        return {
            id: a.id,
            is_read: a.is_read,
            day: day,
            icon: icon,
            iconClass: iconClass,
            title: title,
            sub: sub,
            badge: badge,
            badgeClass: badgeClass,
            time: time,
            organizer: organizer
        };
      }) : []) %>;

      function markAsRead(id, element) {
        if (!element.classList.contains('unread-log')) return;
        
        fetch('/admin/activity/' + id + '/read', { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              element.classList.remove('unread-log');
              element.style.backgroundColor = '';
              const titleEl = element.querySelector('.log-title');
              if (titleEl) {
                titleEl.style.fontWeight = '';
                titleEl.style.color = '';
              }
              // Update badge count
              const badges = document.querySelectorAll('.activity-badge');
              badges.forEach(b => {
                let count = parseInt(b.innerText, 10);
                if (!isNaN(count) && count > 0) {
                    count--;
                    if (count === 0) {
                        b.style.display = 'none';
                    } else {
                        b.innerText = count;
                    }
                }
              });
              // Update in ALL_LOGS
              const log = ALL_LOGS.find(l => l.id === id);
              if (log) log.is_read = true;
            }
          })
          .catch(err => console.error(err));
      }


      const ICONS = {
        calendar: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
        user: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
        warn: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>`,
        cancel: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M12 3a9 9 0 100 18A9 9 0 0012 3z"/></svg>`,
        check: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        users: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
      };

      const PAGE_LIMIT = 10;
      let currentPage = 1;
      let activeFilter = "all";
      let searchQuery = "";

      function filteredLogs() {
        let logs = activeFilter === "all" ? ALL_LOGS : ALL_LOGS.filter(l => l.organizer === activeFilter);
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          logs = logs.filter(l => l.organizer.toLowerCase().includes(q));
        }
        return logs;
      }

      function groupByDay(logs) {
        const map = {}, order = [];
        logs.forEach(l => {
          if (!map[l.day]) { map[l.day] = []; order.push(l.day); }
          map[l.day].push(l);
        });
        return { map, order };
      }

      function render() {
        const logs = filteredLogs();
        const total = logs.length;
        const pages = Math.max(1, Math.ceil(total / PAGE_LIMIT));
        if (currentPage > pages) currentPage = pages;

        const start = (currentPage - 1) * PAGE_LIMIT;
        const slice = logs.slice(start, start + PAGE_LIMIT);
        const { map, order } = groupByDay(slice);

        let html = "";
        order.forEach(day => {
          html += `<div class="day-label">${day}</div>`;
          html += `<div class="section-header"><span class="section-title">Recent</span></div>`;
          html += `<div class="log-list">`;
          map[day].forEach((l, i) => {
            html += `
              <div class="log-item" style="animation-delay:${i * 40}ms">
                <div class="log-icon ${l.iconClass}">${ICONS[l.icon]}</div>
                <div class="log-body">
                  <div class="log-title">${l.title}</div>
                  <div class="log-sub">${l.sub}</div>
                </div>
                <div class="log-right">
                  <span class="log-badge ${l.badgeClass}">${l.badge}</span>
                  <div class="log-time">${l.time}</div>
                </div>
              </div>`;
          });
          html += `</div>`;
        });

        if (total === 0) {
          html = `<div class="log-list" style="padding-top:24px;padding-bottom:8px;">
            <div style="text-align:center;color:#9ca3af;font-size:13px;font-weight:600;padding:32px 0;">No activity found.</div>
          </div>`;
        }

        document.getElementById("log-container").innerHTML = html;

        const from = total === 0 ? 0 : start + 1;
        const to = Math.min(start + PAGE_LIMIT, total);
        document.getElementById("pagination-info").textContent = total === 0 ? "0 items" : `${from}–${to} of ${total}`;

        renderPaginationControls(pages);
      }

      function renderPaginationControls(pages) {
        const ctrl = document.getElementById("pagination-controls");
        if (pages <= 1) { ctrl.innerHTML = ""; return; }

        let start = Math.max(1, currentPage - 2);
        let end = Math.min(pages, start + 4);
        if (end - start < 4) start = Math.max(1, end - 4);

        let html = `<button class="page-btn" onclick="goPage(${currentPage - 1})" ${currentPage === 1 ? "disabled" : ""} title="Previous">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>`;
        for (let p = start; p <= end; p++) {
          html += `<button class="page-btn ${p === currentPage ? "active" : ""}" onclick="goPage(${p})">${p}</button>`;
        }
        html += `<button class="page-btn" onclick="goPage(${currentPage + 1})" ${currentPage === pages ? "disabled" : ""} title="Next">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>`;
        ctrl.innerHTML = html;
      }

      function goPage(p) {
        const pages = Math.ceil(filteredLogs().length / PAGE_LIMIT);
        if (p < 1 || p > pages) return;
        currentPage = p;
        render();
        document.getElementById("log-container").scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function filterByOrganizer(btn, organizer) {
        document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
        btn.classList.add("active");
        activeFilter = organizer;
        currentPage = 1;
        render();
      }

      function handleSearch(input) {
        searchQuery = input.value.trim();
        const clearBtn = document.getElementById("search-clear");
        if (searchQuery) {
          clearBtn.classList.add("visible");
        } else {
          clearBtn.classList.remove("visible");
        }
        currentPage = 1;
        render();
      }

      function clearSearch() {
        const input = document.getElementById("organizer-search");
        input.value = "";
        searchQuery = "";
        document.getElementById("search-clear").classList.remove("visible");
        currentPage = 1;
        render();
        input.focus();
      }

      render();
    </script>
  </body>
</html>