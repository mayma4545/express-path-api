      <!-- ── Stat Cards ── -->
      <div class="stat-grid">
        <!-- Total Users -->
        <div class="stat-card" style="animation: fadeSlideIn 0.2s ease both">
          <div class="bg-blob" style="background: #1da1f2"></div>
          <div class="stat-icon" style="background: #e8f5fe">
            <svg
              fill="none"
              stroke="#1da1f2"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
          </div>
          <div class="stat-label">Total Users</div>
          <div class="stat-value" id="stat-users">0</div>
          <div class="stat-delta delta-up">Platform Registered</div>
        </div>
        <!-- Total Events -->
        <div
          class="stat-card"
          style="animation: fadeSlideIn 0.2s ease 60ms both"
        >
          <div class="bg-blob" style="background: #7c43fe"></div>
          <div class="stat-icon" style="background: #f0ebff">
            <svg
              fill="none"
              stroke="#7c43fe"
              stroke-width="1.8"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </div>
          <div class="stat-label">Total Events</div>
          <div class="stat-value" id="stat-events">0</div>
          <div class="stat-delta delta-up">System Published</div>
        </div>
      </div>

      <!-- ── User Growth Chart ── -->
      <div class="section-wrap">
        <div class="section-title-row">
          <span class="section-title">User Growth (Last 6 Months)</span>
        </div>
        <div class="chart-card">
          <canvas id="growthChart"></canvas>
        </div>
      </div>

      <!-- ── Event Categories Chart ── -->
      <div class="section-wrap">
        <div class="section-title-row">
          <span class="section-title">Events by Category</span>
        </div>
        <div
          class="chart-card"
          style="display: flex; align-items: center; gap: 16px"
        >
          <div style="flex: 0 0 130px; height: 130px">
            <canvas id="categoryChart"></canvas>
          </div>
          <div
            id="category-legend"
            style="flex: 1; display: flex; flex-direction: column; gap: 8px"
          ></div>
        </div>
      </div>

      <!-- ── Top Organizers ── -->
      <div class="section-wrap">
        <div class="section-title-row">
          <span class="section-title">Top Rated Organizers</span>
          <a href="/admin/organizers" class="see-all">See all</a>
        </div>
        <div class="org-list" id="org-list"></div>
      </div>

      <!-- ── Most Popular Events ── -->
      <div class="section-wrap" style="padding-bottom: 0">
        <div class="section-title-row">
          <span class="section-title">Most Popular Events</span>
          <a href="/admin/events" class="see-all">See all</a>
        </div>
        <div class="event-list" id="event-list"></div>
      </div>

      <div style="height: 24px"></div>
    </main>

    <script>
      // ── Data from Server ──────────────────────────────────────────────────────
      const STATS = { 
        users: <%= stats.totalUsers %>, 
        events: <%= stats.totalEvents %> 
      };

      const ORGANIZERS = <%- JSON.stringify(topOrganizers.map(o => ({
        name: o.name,
        initial: o.name.charAt(0).toUpperCase(),
        color: '#1da1f2',
        events: o.getDataValue('eventCount'),
        rating: o.average_rating || '0.0',
        badge: 'pill-blue',
        category: o.description ? o.description.substring(0, 15) + '...' : 'Partner'
      }))) %>;

      const EVENTS = <%- JSON.stringify(popularEvents.map(e => ({
        name: e.title,
        id: e.id,
        icon: 'star',
        color: '#e8f5fe',
        stroke: '#1da1f2',
        pill: 'pill-blue',
        pillLabel: e.category ? e.category.name : 'Event',
        visits: e.getDataValue('visitCount') || 0
      }))) %>;

      const GROWTH_DATA = <%- JSON.stringify(growthData) %>;

      const CATEGORIES = <%- JSON.stringify(categoryData) %>;

      const ICON_SVG = {
        laptop: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
        sun: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8-9h1M3 12H2m15.364-6.364l.707.707M6.343 17.657l-.707.707m12.728 0l-.707.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>`,
        code: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
        star: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
        mic: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4M12 3a4 4 0 00-4 4v4a4 4 0 008 0V7a4 4 0 00-4-4z"/></svg>`,
      };

      // ── Animate Counters ──────────────────────────────────────────────────────
      function animateCount(el, target, prefix = "", suffix = "") {
        if (!el) return;
        const start = 0,
          dur = 900,
          step = 16;
        let current = start;
        const inc = target / (dur / step);
        const timer = setInterval(() => {
          current = Math.min(current + inc, target);
          const display =
            prefix + Math.round(current).toLocaleString() + suffix;
          el.textContent = display;
          if (current >= target) clearInterval(timer);
        }, step);
      }

      window.addEventListener("DOMContentLoaded", () => {
        animateCount(document.getElementById("stat-users"), STATS.users);
        animateCount(document.getElementById("stat-events"), STATS.events);

        renderOrgList();
        renderEventList();
        renderGrowthChart();
        renderCategoryChart();
      });

      // ── Organizer List ─────────────────────────────────────────────────────────
      function renderOrgList() {
        const RANK_COLORS = ["#f59e0b", "#9ca3af", "#cd7f32"];
        const RANK_EMOJI = ["🥇", "🥈", "🥉"];
        const list = document.getElementById("org-list");
        if (!list) return;
        list.innerHTML = ORGANIZERS.map(
          (o, i) => `
          <div class="org-item" style="animation-delay:${i * 50}ms">
            <div class="relative flex-shrink-0">
              <div class="org-avatar" style="background:${o.color};">${o.initial}</div>
              ${i < 3 ? `<div class="rank-badge" style="background:${RANK_COLORS[i]}20;color:${RANK_COLORS[i]};font-size:13px;width:22px;height:22px;">${RANK_EMOJI[i]}</div>` : ""}
            </div>
            <div class="org-body">
              <div class="org-name">${o.name}</div>
              <div class="org-meta">${o.events} events · <span class="${o.badge}" style="font-size:10px;padding:1px 7px;">${o.category}</span></div>
              <div class="bar-track" style="width:100%">
                <div class="bar-fill" style="width:${(parseFloat(o.rating) / 5) * 100}%;background:${o.color};"></div>
              </div>
            </div>
            <div class="org-right">
              <div class="org-score">${o.rating}</div>
              <div class="org-score-label">/ 5.0</div>
            </div>
          </div>
        `,
        ).join("");
      }

      // ── Event List ─────────────────────────────────────────────────────────────
      function renderEventList() {
        const list = document.getElementById("event-list");
        if (!list) return;
        
        // Find max visits for normalization
        const maxVisits = Math.max(...EVENTS.map(e => e.visits), 1);

        list.innerHTML = EVENTS.map((e, i) => {
          const pct = Math.round((e.visits / maxVisits) * 100);
          return `
          <div class="event-item" style="animation-delay:${i * 50}ms" onclick="window.location.href='/admin/events/${e.id}'">
            <div class="event-icon" style="background:${e.color};">
              <svg style="stroke:${e.stroke}" fill="none" viewBox="0 0 24 24" stroke-width="1.8">${ICON_SVG[e.icon].replace(/<svg[^>]*>/, "").replace("</svg>", "")}</svg>
            </div>
            <div class="event-body">
              <div class="event-name">${e.name}</div>
              <div class="event-meta"><span class="pill ${e.pill}">${e.pillLabel}</span></div>
              <div class="bar-track">
                <div class="bar-fill" style="width:${pct}%;background:${e.stroke};"></div>
              </div>
            </div>
            <div class="event-right">
              <div class="event-count">${e.visits.toLocaleString()}</div>
              <div class="event-label">Total Visits</div>
            </div>
          </div>`;
        }).join("");
      }

      // ── Growth Chart ───────────────────────────────────────────────────────────
      let growthChart = null;
      function renderGrowthChart() {
        const labels = GROWTH_DATA.map(d => d.label);
        const data = GROWTH_DATA.map(d => d.value);
        
        const ctx = document.getElementById("growthChart").getContext("2d");
        const grad = ctx.createLinearGradient(0, 0, 0, 180);
        grad.addColorStop(0, "rgba(29,161,242,0.18)");
        grad.addColorStop(1, "rgba(29,161,242,0)");

        if (growthChart) growthChart.destroy();
        growthChart = new Chart(ctx, {
          type: "line",
          data: {
            labels,
            datasets: [
              {
                label: 'New Users',
                data,
                borderColor: "#1da1f2",
                borderWidth: 2.5,
                backgroundColor: grad,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: "#fff",
                pointBorderColor: "#1da1f2",
                pointBorderWidth: 2,
                pointHoverRadius: 6,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: "#111827",
                titleFont: {
                  family: "Plus Jakarta Sans",
                  size: 11,
                  weight: "700",
                },
                bodyFont: {
                  family: "Plus Jakarta Sans",
                  size: 12,
                  weight: "800",
                },
                padding: 10,
                cornerRadius: 12,
              },
            },
            scales: {
              x: {
                grid: { display: false },
                ticks: {
                  font: {
                    family: "Plus Jakarta Sans",
                    size: 10,
                    weight: "700",
                  },
                  color: "#9ca3af",
                },
                border: { display: false },
              },
              y: {
                beginAtZero: true,
                grid: { color: "#f3f4f6" },
                ticks: {
                  font: { family: "Plus Jakarta Sans", size: 10 },
                  color: "#9ca3af",
                  stepSize: 1
                },
                border: { display: false },
              },
            },
          },
        });
      }

      // ── Category Donut Chart ───────────────────────────────────────────────────
      function renderCategoryChart() {
        const ctx = document.getElementById("categoryChart").getContext("2d");
        
        // Calculate percentages
        const total = CATEGORIES.reduce((acc, c) => acc + c.value, 0) || 1;
        const processedCategories = CATEGORIES.map(c => ({
          ...c,
          pct: Math.round((c.value / total) * 100)
        }));

        new Chart(ctx, {
          type: "doughnut",
          data: {
            labels: processedCategories.map((c) => c.label),
            datasets: [
              {
                data: processedCategories.map((c) => c.value),
                backgroundColor: processedCategories.map((c) => c.color),
                borderWidth: 0,
                hoverOffset: 4,
              },
            ],
          },
          options: {
            cutout: "68%",
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: "#111827",
                titleFont: {
                  family: "Plus Jakarta Sans",
                  size: 11,
                  weight: "700",
                },
                bodyFont: {
                  family: "Plus Jakarta Sans",
                  size: 12,
                  weight: "800",
                },
                padding: 10,
                cornerRadius: 12,
                callbacks: { label: (ctx) => ` ${ctx.parsed} events` },
              },
            },
          },
        });

        const legend = document.getElementById("category-legend");
        legend.innerHTML = processedCategories.map(
          (c) => `
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:10px;height:10px;border-radius:3px;background:${c.color};flex-shrink:0;"></div>
            <span style="font-size:12px;font-weight:600;color:#111827;flex:1;">${c.label}</span>
            <span style="font-size:12px;font-weight:800;color:#111827;">${c.pct}%</span>
          </div>
        `,
        ).join("");
      }
    </script>
  </body>
</html>