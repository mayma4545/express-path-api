<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Reports</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: { light: "#E9E4FF", DEFAULT: "#1DA1F2", dark: "#5A26ED" },
              bgWhite: "#FFFFFF",
              bgLight: "#F8F9FE",
              textMain: "#111827",
              textMuted: "#6B7280",
            },
            fontFamily: { sans: ["Plus Jakarta Sans", "sans-serif"] },
            boxShadow: {
              soft: "0 4px 20px -2px rgba(0,0,0,0.05)",
              float: "0 8px 16px -4px rgba(124,67,254,0.4)",
            },
          },
        },
      };
    </script>
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background-color: #f8f9fe;
        -webkit-tap-highlight-color: transparent;
      }

      /* ── Stat Cards ── */
      .stat-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        padding: 0 16px;
      }
      .stat-card {
        background: white;
        border-radius: 20px;
        padding: 16px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
      }
      .stat-card .bg-blob {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        opacity: 0.08;
        right: -16px;
        bottom: -16px;
      }
      .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .stat-value {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
        line-height: 1.1;
        margin: 4px 0 2px;
      }
      .stat-delta {
        font-size: 11px;
        font-weight: 700;
      }
      .delta-up {
        color: #22c55e;
      }
      .delta-down {
        color: #ef4444;
      }
      .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
      }
      .stat-icon svg {
        width: 18px;
        height: 18px;
      }

      /* ── Section ── */
      .section-wrap {
        padding: 20px 16px 0;
      }
      .section-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
      }
      .section-title {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
      }
      .see-all {
        font-size: 12px;
        color: #1da1f2;
        font-weight: 600;
        background: none;
        border: none;
        cursor: pointer;
        font-family: "Plus Jakarta Sans", sans-serif;
      }

      /* ── Chart Card ── */
      .chart-card {
        background: white;
        border-radius: 20px;
        padding: 16px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
      }
      .chart-card canvas {
        max-height: 180px;
      }

      /* ── Organizer List ── */
      .org-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .org-item {
        background: white;
        border-radius: 18px;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
        animation: fadeSlideIn 0.25s ease both;
      }
      @keyframes fadeSlideIn {
        from {
          opacity: 0;
          transform: translateY(6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .org-avatar {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        font-size: 16px;
        font-weight: 800;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .org-body {
        flex: 1;
        min-width: 0;
      }
      .org-name {
        font-size: 13px;
        font-weight: 700;
        color: #111827;
      }
      .org-meta {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 2px;
      }
      .org-right {
        text-align: right;
        flex-shrink: 0;
      }
      .org-score {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
      }
      .org-score-label {
        font-size: 10px;
        color: #9ca3af;
      }

      /* rank badge */
      .rank-badge {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        font-size: 10px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: -4px;
        right: -4px;
      }

      /* ── Event List ── */
      .event-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .event-item {
        background: white;
        border-radius: 18px;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
        animation: fadeSlideIn 0.25s ease both;
      }
      .event-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .event-icon svg {
        width: 20px;
        height: 20px;
      }
      .event-body {
        flex: 1;
        min-width: 0;
      }
      .event-name {
        font-size: 13px;
        font-weight: 700;
        color: #111827;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .event-meta {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 2px;
      }
      .event-right {
        text-align: right;
        flex-shrink: 0;
      }
      .event-count {
        font-size: 16px;
        font-weight: 800;
        color: #111827;
      }
      .event-label {
        font-size: 10px;
        color: #9ca3af;
      }

      .pill {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 20px;
        margin-bottom: 2px;
      }
      .pill-blue {
        background: #e8f5fe;
        color: #1da1f2;
      }
      .pill-green {
        background: #e8fef0;
        color: #22c55e;
      }
      .pill-amber {
        background: #fef7e8;
        color: #f59e0b;
      }
      .pill-purple {
        background: #f0ebff;
        color: #7c43fe;
      }

      /* bar track */
      .bar-track {
        height: 5px;
        border-radius: 99px;
        background: #f3f4f6;
        margin-top: 6px;
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* period toggle */
      .period-toggle {
        display: flex;
        gap: 4px;
        background: #f3f4f6;
        border-radius: 12px;
        padding: 3px;
      }
      .period-btn {
        padding: 4px 10px;
        border-radius: 9px;
        font-size: 11px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        background: none;
        color: #9ca3af;
        font-family: "Plus Jakarta Sans", sans-serif;
        transition: all 0.15s ease;
      }
      .period-btn.active {
        background: white;
        color: #111827;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
      }
    </style>
  </head>
