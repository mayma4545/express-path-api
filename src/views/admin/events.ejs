﻿<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#E9E4FF', DEFAULT: '#1DA1F2', dark: '#5A26ED' },
            bgWhite: '#FFFFFF',
            bgLight: '#F8F9FE',
            textMain: '#111827',
            textMuted: '#6B7280'
          }, 
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(124, 67, 254, 0.4)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8F9FE; -webkit-tap-highlight-color: transparent; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">

  <!-- Desktop Sidebar -->
    <aside
      class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft"
    >
      <div class="flex flex-col gap-8 items-center">
        <nav class="flex flex-col gap-6">
          <a
            href="/admin/dashboard"
            class="p-3 rounded-xl bg-brand-light text-brand"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path
                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/organizers"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/activity"
            class="relative p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              />
            </svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a
            href="/admin/events"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </a>
          <a
            href="/admin/reports"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
          </a>
        </nav>
      </div>
      
    </aside>

  <!-- Mobile Bottom Tab Pane -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40">
      <a href="/admin/dashboard" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.293 3.293a1 1 0 011.414 0l7 7A1 1 0 0119 12h-1v7a1 1 0 01-1 1h-3a1 1 0 01-1-1v-3a1 1 0 00-1-1h-2a1 1 0 00-1 1v3a1 1 0 01-1 1H6a1 1 0 01-1-1v-7H4a1 1 0 01-.707-1.707l7-7z"/></svg>
      </a>
      <a href="/admin/organizers" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </a>
      <a href="/admin/activity" class="relative flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-0 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="mobile-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
      <a href="/admin/events" class="flex flex-col items-center gap-1 text-brand">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
      <a href="/admin/reports" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </a>
    </div>

  <!-- Main Content Wrapper -->
  <main class="max-w-2xl mx-auto p-4 sm:p-6 md:py-10">
    
    <!-- Top Bar -->
    <header class="flex flex-col sm:flex-row justify-between sm:items-center gap-4 mb-6 sm:mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-textMain tracking-tight">Events Review</h1>
        <p class="text-xs sm:text-sm font-medium text-textMuted mt-1">Oversight across all ongoing and scheduled activities.</p>
      </div>
      <div class="flex w-full sm:w-64 relative">
        <svg class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input type="text" id="searchInput" placeholder="Search events..." class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:border-brand shadow-sm transition">
      </div>
    </header>

    <div class="space-y-4 relative z-10">
      <% events.forEach(evt => { %>
        <div onclick="window.location.href='/admin/events/<%= evt.id %>'" class="cursor-pointer bg-white border border-gray-50 rounded-3xl p-4 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-2xl bg-[#F0F2FF] overflow-hidden flex items-center justify-center flex-shrink-0 border border-white shadow-sm">
              <% if(evt.image_url) { %>
                <img src="<%= evt.image_url %>" class="w-full h-full object-cover">
              <% } else { %>
                <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-extrabold text-textMain text-sm leading-tight line-clamp-2 mb-1"><%= evt.title || evt.name %></p>
              <div class="flex items-center text-xs font-medium text-textMuted mb-1">
                <svg class="w-3 h-3 mr-1 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="truncate"><%= evt.venue %></span>
              </div>
              <div class="flex items-center text-xs font-medium text-textMuted">
                <div class="w-3.5 h-3.5 rounded-full bg-brand-light text-brand flex items-center justify-center text-[8px] font-bold mr-1 flex-shrink-0">O</div>
                <span class="truncate">
                  <% if (evt.Organizer && evt.Organizer.name) { %>
                    <%= evt.Organizer.name %>
                  <% } else if (evt.organizer && evt.organizer.name) { %>
                    <%= evt.organizer.name %>
                  <% } else { %>
                    <span class="italic">Unknown</span>
                  <% } %>
                </span>
              </div>
            </div>
          </div>
          
          <div class="bg-gray-50 border border-gray-100 rounded-xl px-3 py-2.5 mb-4 flex justify-between items-center">
            <div class="flex items-center">
              <svg class="w-3.5 h-3.5 mr-1.5 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <span class="text-[13px] font-bold text-textMain"><%= evt.event_date %></span>
            </div>
            <span class="text-xs font-medium text-textMuted bg-white border border-gray-200 px-2 py-0.5 rounded-md"><%= evt.start_time %> - <%= evt.end_time %></span>
          </div>
          
          <div class="pt-3 border-t border-gray-50 flex justify-end">
            <button onclick="event.stopPropagation(); window.location.href='/admin/events/<%= evt.id %>'" class="text-xs font-bold text-red-500 bg-[#FFF0F0] hover:bg-red-100 transition-all px-4 py-2 rounded-xl active:scale-95 flex items-center justify-center gap-1.5 w-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              Moderate Event
            </button>
          </div>
        </div>
      <% }); %>
      <% if (events.length === 0) { %>
        <div class="py-10 flex flex-col items-center justify-center text-textMuted bg-white rounded-3xl border border-gray-50 shadow-sm p-4">
          <svg class="w-10 h-10 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <span class="text-sm font-medium">No events found.</span>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>