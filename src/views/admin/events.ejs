﻿<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: { 
        extend: { 
          colors: { 
            brand: { light: '#E9E4FF', DEFAULT: '#1DA1F2', dark: '#5A26ED' },
            bgWhite: '#FFFFFF',
            bgLight: '#F8F9FE',
            textMain: '#111827',
            textMuted: '#6B7280'
          }, 
          fontFamily: { sans: ['Plus Jakarta Sans', 'sans-serif'] },
          boxShadow: {
            'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
            'float': '0 8px 16px -4px rgba(124, 67, 254, 0.4)',
          }
        } 
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F8F9FE; -webkit-tap-highlight-color: transparent; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="text-textMain pb-24 md:pb-0 md:pl-20 overflow-x-hidden">

  <!-- Desktop Sidebar -->
    <aside
      class="hidden md:flex flex-col w-20 bg-white fixed top-0 bottom-0 left-0 border-r border-gray-100 z-40 items-center py-8 justify-between shadow-soft"
    >
      <div class="flex flex-col gap-8 items-center">
        <nav class="flex flex-col gap-6">
          <a
            href="/admin/dashboard"
            class="p-3 rounded-xl bg-brand-light text-brand"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
              <path
                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/organizers"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
              ></path>
            </svg>
          </a>
          <a
            href="/admin/activity"
            class="relative p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              />
            </svg>
          
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-2 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="desktop-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
          <a
            href="/admin/events"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </a>
          <a
            href="/admin/reports"
            class="p-3 rounded-xl text-textMuted hover:bg-gray-50"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
          </a>
        </nav>
      </div>
      
    </aside>

  <!-- Mobile Bottom Tab Pane -->
    <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white px-6 py-4 flex justify-between items-center rounded-t-3xl shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.1)] z-40">
      <a href="/admin/dashboard" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.293 3.293a1 1 0 011.414 0l7 7A1 1 0 0119 12h-1v7a1 1 0 01-1 1h-3a1 1 0 01-1-1v-3a1 1 0 00-1-1h-2a1 1 0 00-1 1v3a1 1 0 01-1 1H6a1 1 0 01-1-1v-7H4a1 1 0 01-.707-1.707l7-7z"/></svg>
      </a>
      <a href="/admin/organizers" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </a>
      <a href="/admin/activity" class="relative flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      
  <% if(locals.unreadActivityCount > 0) { %>
    <span class="absolute top-0 right-2 flex items-center justify-center w-4 h-4 text-[10px] font-bold text-white bg-red-500 rounded-full activity-badge" id="mobile-activity-badge"><%= locals.unreadActivityCount %></span>
  <% } %>
</a>
      <a href="/admin/events" class="flex flex-col items-center gap-1 text-brand">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </a>
      <a href="/admin/reports" class="flex flex-col items-center gap-1 text-textMuted hover:text-textMain transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </a>
    </div>

  <!-- Main Content Wrapper -->
  <main class="max-w-2xl mx-auto p-4 sm:p-6 md:py-10">

    <!-- Top Bar -->
    <header class="mb-8">
      <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-6 mb-8">
        <div>
          <h1 class="text-3xl font-extrabold text-textMain tracking-tight">Events Review</h1>
          <p class="text-sm font-medium text-textMuted mt-1">Moderate and monitor all campus activities.</p>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 bg-white p-4 rounded-3xl border border-gray-100 shadow-sm">
        <div class="md:col-span-7 relative">
          <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-textMuted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          <input type="text" id="searchInput" placeholder="Search events, venues, organizers..." class="w-full pl-12 pr-4 py-3 bg-gray-50 border-none rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-light focus:bg-white transition-all">
        </div>
        <div class="md:col-span-5 flex gap-3">
          <div class="flex-1 relative">
            <select id="sortFilter" class="w-full appearance-none bg-gray-50 border-none rounded-2xl pl-4 pr-10 py-3 text-sm font-bold text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand-light transition-all cursor-pointer">
              <option value="newest">Newest Created</option>
              <option value="rating">Highest Rated</option>
              <option value="visits">Most Visited</option>
              <option value="bookmarks">Most Bookmarked</option>
              <option value="date">Event Date</option>
            </select>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Success Popup -->
    <div id="success-popup" class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] hidden items-center gap-3 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-xl shadow-emerald-200/50 animate-[slideDown_0.3s_ease-out]">
      <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <p class="font-bold text-sm">Event successfully taken down!</p>
    </div>

    <div id="eventList" class="space-y-4 relative z-10">
      <!-- Events will be rendered here via JS -->
    </div>

    <div id="noResults" class="hidden py-20 flex flex-col items-center justify-center text-textMuted bg-white rounded-[2rem] border border-dashed border-gray-200 shadow-sm p-4">
      <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
      </div>
      <span class="text-sm font-bold text-gray-400">No events match your criteria</span>
    </div>

    <script>
      const allEvents = <%- JSON.stringify(events) %>;
      const eventListContainer = document.getElementById('eventList');
      const noResults = document.getElementById('noResults');
      const searchInput = document.getElementById('searchInput');
      const sortFilter = document.getElementById('sortFilter');

      function renderEvents(eventsToRender) {
        eventListContainer.innerHTML = '';
        if (eventsToRender.length === 0) {
          noResults.classList.remove('hidden');
          return;
        }
        noResults.classList.add('hidden');

        eventsToRender.forEach(evt => {
          const div = document.createElement('div');
          div.className = 'cursor-pointer bg-white border border-gray-50 rounded-[2rem] p-5 shadow-sm hover:shadow-lg transition-all relative overflow-hidden group card-hover';
          div.onclick = () => window.location.href = `/admin/events/${evt.id}`;
          
          const avgRating = evt.avgRating || 0;
          const visitCount = evt.visitCount || 0;
          const bookmarkCount = evt.bookmarkCount || 0;
          const organizerName = evt.organizer?.name || evt.Organizer?.name || 'Unknown';

          div.innerHTML = `
            <div class="flex items-start gap-5 mb-5">
              <div class="w-20 h-20 rounded-2xl bg-brand-light overflow-hidden flex items-center justify-center flex-shrink-0 border border-white shadow-sm group-hover:scale-105 transition-transform">
                ${evt.image_url 
                  ? `<img src="${evt.image_url}" class="w-full h-full object-cover">` 
                  : `<svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`
                }
              </div>
              <div class="flex-1 min-w-0 pt-1">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="px-2 py-0.5 rounded-md bg-brand-light text-brand text-[9px] font-black uppercase tracking-widest border border-brand/10">${evt.category?.name || 'Event'}</span>
                  ${avgRating > 0 ? `<div class="flex items-center gap-0.5 text-amber-500 font-bold text-[10px]"><svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>${avgRating.toFixed(1)}</div>` : ''}
                </div>
                <h4 class="font-black text-gray-900 text-base leading-tight truncate mb-2 group-hover:text-brand transition-colors">${evt.title || evt.name}</h4>
                <div class="flex flex-wrap items-center gap-y-1 gap-x-3">
                  <div class="flex items-center text-[11px] font-bold text-gray-400">
                    <svg class="w-3 h-3 mr-1 text-brand shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span class="truncate max-w-[120px]">${evt.venue}</span>
                  </div>
                  <div class="flex items-center text-[11px] font-bold text-gray-400">
                    <div class="w-4 h-4 rounded-full bg-brand-light text-brand flex items-center justify-center text-[8px] font-black mr-1 shrink-0">O</div>
                    <span class="truncate max-w-[100px]">${organizerName}</span>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-3 gap-3 mb-5">
              <div class="bg-gray-50 rounded-2xl p-2.5 border border-gray-100 flex flex-col items-center">
                <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Visits</span>
                <span class="text-sm font-black text-gray-900">${visitCount}</span>
              </div>
              <div class="bg-gray-50 rounded-2xl p-2.5 border border-gray-100 flex flex-col items-center">
                <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Saved</span>
                <span class="text-sm font-black text-gray-900">${bookmarkCount}</span>
              </div>
              <div class="bg-gray-50 rounded-2xl p-2.5 border border-gray-100 flex flex-col items-center text-center">
                <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1 truncate w-full">Date</span>
                <span class="text-sm font-black text-gray-900 truncate w-full">${new Date(evt.event_date).toLocaleDateString([], {month:'short', day:'numeric'})}</span>
              </div>
            </div>
            
            <div class="pt-4 border-t border-gray-50">
              <button onclick="event.stopPropagation(); window.location.href='/admin/events/${evt.id}'" class="w-full text-xs font-black text-rose-500 bg-rose-50 hover:bg-rose-100 transition-all py-3.5 rounded-2xl active:scale-[0.98] flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                MODERATE EVENT
              </button>
            </div>
          `;
          eventListContainer.appendChild(div);
        });
      }

      function handleSearchAndSort() {
        const query = searchInput.value.toLowerCase();
        const sortBy = sortFilter.value;

        let filtered = allEvents.filter(e => {
          const title = (e.title || e.name || '').toLowerCase();
          const venue = (e.venue || '').toLowerCase();
          const org = (e.organizer?.name || e.Organizer?.name || '').toLowerCase();
          return title.includes(query) || venue.includes(query) || org.includes(query);
        });

        filtered.sort((a, b) => {
          if (sortBy === 'rating') return (b.avgRating || 0) - (a.avgRating || 0);
          if (sortBy === 'visits') return (b.visitCount || 0) - (a.visitCount || 0);
          if (sortBy === 'bookmarks') return (b.bookmarkCount || 0) - (a.bookmarkCount || 0);
          if (sortBy === 'date') return new Date(a.event_date) - new Date(b.event_date);
          if (sortBy === 'newest') return new Date(b.created_at) - new Date(a.created_at);
          return 0;
        });

        renderEvents(filtered);
      }

      searchInput.addEventListener('input', handleSearchAndSort);
      sortFilter.addEventListener('change', handleSearchAndSort);

      // Success Popup Logic
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('takedown') === 'success') {
        const popup = document.getElementById('success-popup');
        popup.classList.remove('hidden');
        popup.classList.add('flex');
        setTimeout(() => {
          popup.style.transition = 'all 0.5s ease';
          popup.style.opacity = '0';
          popup.style.transform = 'translate(-50%, -20px)';
          setTimeout(() => popup.remove(), 500);
        }, 4000);
        const newUrl = window.location.pathname;
        window.history.replaceState({}, '', newUrl);
      }

      // Initial Render
      renderEvents(allEvents);
    </script>

  </main>
</body>
</html>